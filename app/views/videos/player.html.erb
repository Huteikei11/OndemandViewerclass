    async initializeCamera() {
      // 既に初期化中または初期化済みの場合
      if (this.cameraInitializing || this.mediaPipeInitialized) {
        console.log('カメラは既に初期化中または初期化済みです - トラッキングを確認');
        // トラッキングが開始されていない場合は開始する
        if (!this.trackingInterval) {
          console.log('トラッキングが停止しています - 再開します');
          this.startTracking();
        }
        return;
      }
      
      this.cameraInitializing = true;
      
      try {
        console.log('カメラ初期化開始...');
        
        const stream = await navigator.mediaDevices.getUserMedia({ 
          video: { 
            width: 640, 
            height: 480,
            facingMode: 'user'
          } 
        });
        
        // 隠しvideo要素を作成してカメラ映像を表示
        this.cameraVideo = document.createElement('video');
        this.cameraVideo.srcObject = stream;
        this.cameraVideo.autoplay = true;
        this.cameraVideo.muted = true;
        this.cameraVideo.style.display = 'none';
        document.body.appendChild(this.cameraVideo);
        
        // Canvas要素を作成して顔検出用に使用
        this.canvas = document.createElement('canvas');
        this.canvas.width = 640;
        this.canvas.height = 480;
        this.ctx = this.canvas.getContext('2d');
        
        // MediaPipeの初期化
        await this.initializeMediaPipe();
        
        this.cameraInitializing = false;
        console.log('✅ カメラ初期化完了 (MediaPipe有効)');
      } catch (error) {
        this.cameraInitializing = false;
        console.error('❌ カメラ/MediaPipe初期化エラー:', error);
        console.error('エラー詳細:', error.message, error.stack);
        console.log('MediaPipeを無効にしてフォールバックモードで続行');
        this.useMediaPipe = false;
        this.mediaPipeInitialized = false;
      }
    }
    
    async initializeMediaPipe() {
      try {
        console.log('MediaPipe初期化開始...');
        
        // MediaPipeライブラリが読み込まれているかチェック
        if (typeof FaceMesh === 'undefined') {
          throw new Error('MediaPipe FaceMeshライブラリが読み込まれていません');
        }
        
        // 既存のFaceMeshインスタンスがある場合はクリーンアップ
        if (this.faceMesh) {
          console.log('既存のFaceMeshインスタンスをクリーンアップ');
          try {
            await this.faceMesh.close();
          } catch (e) {
            console.warn('FaceMeshのクローズ処理でエラー:', e);
          }
          this.faceMesh = null;
        }
        
        // グローバルなFaceMesh初期化フラグをチェック
        if (window.faceMeshInitializing) {
          console.log('FaceMeshは既に初期化中です。待機します...');
          // 既に初期化中なら最大10秒待機
          for (let i = 0; i < 100; i++) {
            await new Promise(resolve => setTimeout(resolve, 100));
            if (!window.faceMeshInitializing) {
              console.log('FaceMesh初期化完了を確認しました');
              // 他のインスタンスが初期化したので、このインスタンスもtrueにする
              this.mediaPipeInitialized = true;
              return;
            }
          }
          console.warn('FaceMesh初期化待機タイムアウト');
          // タイムアウトした場合は無限ループを防ぐためにフラグをリセット
          window.faceMeshInitializing = false;
          // このインスタンスでは初期化失敗として扱う
          throw new Error('FaceMesh初期化待機タイムアウト');
        }
        
        window.faceMeshInitializing = true;
        
        // 少し待機してからFaceMeshを初期化（WASMの準備時間を確保）
        await new Promise(resolve => setTimeout(resolve, 500));
        
        // FaceMeshモデルの初期化
        this.faceMesh = new FaceMesh({
          locateFile: (file) => {
            return `https://cdn.jsdelivr.net/npm/@mediapipe/face_mesh/${file}`;
          }
        });
        
        // FaceMeshの設定
        this.faceMesh.setOptions({
          maxNumFaces: 1,
          refineLandmarks: true, // より詳細なランドマーク検出を有効
          refineIris: true, // 虹彩検出を有効化（視線推定精度向上）
          minDetectionConfidence: 0.8, // 検出精度を向上（0.7 → 0.8）
          minTrackingConfidence: 0.7  // トラッキング精度を向上（0.5 → 0.7）
        });
        
        // 結果処理のコールバック設定
        this.faceMesh.onResults(this.onFaceMeshResults.bind(this));
        
        // mediaPipeInitializedをtrueに設定してからカメラ起動
        this.mediaPipeInitialized = true;
        
        // カメラからの映像送信開始
        if (typeof Camera !== 'undefined') {
          this.camera = new Camera(this.cameraVideo, {
            onFrame: async () => {
              if (this.faceMesh) {
                try {
                  await this.faceMesh.send({ image: this.cameraVideo });
                } catch (error) {
                  console.error('FaceMesh送信エラー:', error);
                }
              }
            },
            width: 1280,  // 解像度: 1280x720
            height: 720,
            fps: 30       // フレームレート指定
          });
          
          await this.camera.start();
          console.log('✅ MediaPipeカメラ起動完了');
        }
        
        window.faceMeshInitializing = false;
        console.log('✅ MediaPipe初期化完了');
        
      } catch (error) {
        console.error('❌ MediaPipe初期化エラー:', error);
        console.error('エラー詳細:', error.message, error.stack);
        window.faceMeshInitializing = false;
        this.useMediaPipe = false;
        this.mediaPipeInitialized = false;
        console.log('フォールバックモードに切り替え');
        throw error; // エラーを上位に伝播させる
      }
    }
    
