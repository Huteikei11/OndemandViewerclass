        // 減点系
        faceNotDetectedPenalty: 2,      // 顔未検出時の減点
        movementStopPenalty: 2,         // 目線停止時の減点（秒あたり）
        responseDelayPenalty: 5,        // 回答遅延時の減点（秒あたり）
        
        // 加点系
        centerGazeBonus: 0,           // 中央注視時の加点
        // 集中注視: 学習者が画面の中央（動画やコンテンツがある場所）に視線を向けている状態
        questionConfirmBonus: 15,        // 問題確認時の加点
        quickResponseBonus: 15,          // 素早い回答時の加点
        noteInputBonus: 3,              // メモ入力時の加点
        frontFacingBonus: 1,            // 正面注視時の加点　
        // 正面注視: 学習者が画面から離れたり、横を向いたりせず、正面を向いて学習している状態
        
        // 時間間隔設定
        movementStopThreshold: 5,      // 目線停止と判定する時間（秒）
        responseDelayThreshold: 20,     // 回答遅延と判定する時間（秒）
        quickResponseThreshold: 10,      // 素早い回答と判定する時間（秒）
        questionConfirmWindow: 4,       // 問題確認判定の時間窓（秒）
        frontFacingInterval: 5000,      // 正面注視加点の間隔（ミリ秒）
        centerGazeInterval: 5000,       // 集中注視加点の間隔（ミリ秒）
        
        // その他設定
        movementDetectionThreshold: 8, // 目線停止・目線動き検出の閾値（ピクセル）
