    importSettings(file) {
      if (!file) return;
      
      const reader = new FileReader();
      reader.onload = (e) => {
        try {
          const importedSettings = JSON.parse(e.target.result);
          
          // 設定を検証
          const validKeys = Object.keys(this.scoreSettings);
          const filteredSettings = {};
          
          Object.keys(importedSettings).forEach(key => {
            if (validKeys.includes(key) && typeof importedSettings[key] === 'number') {
              filteredSettings[key] = importedSettings[key];
            }
          });
          
          // 設定を適用
          Object.assign(this.scoreSettings, filteredSettings);
          
          // UIに反映
          this.loadSettingsToUI();
          
          this.showSettingsMessage('設定をインポートしました', 'success');
          
        } catch (error) {
          console.error('設定のインポート中にエラーが発生しました:', error);
          this.showSettingsMessage('インポート中にエラーが発生しました', 'error');
        }
      };
      
      reader.readAsText(file);
    }
    
    showSettingsMessage(message, type) {
      // 簡易的なメッセージ表示
      const existingMessage = document.querySelector('.settings-message');
      if (existingMessage) {
        existingMessage.remove();
      }
      
      const messageEl = document.createElement('div');
      messageEl.className = `settings-message settings-message-${type}`;
      messageEl.textContent = message;
      messageEl.style.cssText = `
        position: absolute;
        top: 10px;
        right: 10px;
        padding: 8px 12px;
        border-radius: 4px;
        font-size: 12px;
        z-index: 1000;
        ${type === 'success' ? 'background: #28a745; color: white;' : ''}
        ${type === 'error' ? 'background: #dc3545; color: white;' : ''}
        ${type === 'info' ? 'background: #17a2b8; color: white;' : ''}
      `;
      
      document.body.appendChild(messageEl);
      
      // 3秒後に自動で削除
      setTimeout(() => {
        if (messageEl.parentNode) {
          messageEl.parentNode.removeChild(messageEl);
        }
      }, 3000);
    }
  }
  
  // 集中度トラッカーをシングルトンとして初期化
  // 既存のインスタンスがあれば再利用、なければ新規作成
  if (!window.concentrationTracker) {
    console.log('ConcentrationTrackerの新規インスタンスを作成します');
    window.concentrationTracker = new ConcentrationTracker();
  } else {
    console.log('既存のConcentrationTrackerインスタンスを再利用します');
  }
  const concentrationTracker = window.concentrationTracker;
  
  // JSONデータの確認
  let rawQuestionData;
  try {
    rawQuestionData = <%= raw @questions.to_json(include: :options) %>;
    console.log('生の質問データを取得しました');
  } catch (e) {
    console.error('質問データの解析中にエラーが発生しました:', e);
    rawQuestionData = [];
  }
  
  // Initialize questions with a 'shown' property to track which ones have been displayed
  // セッションストレージで管理：タブを閉じるまで問題表示状態を維持
  const videoId = '<%= @video.id %>';
  const sessionKey = `video_${videoId}_shown_questions`;
  const tabIdKey = `video_${videoId}_tab_id`;
  
  // タブIDを生成または取得（タブ複製を検出するため）
  let currentTabId = sessionStorage.getItem(tabIdKey);
  const newTabId = Date.now() + '_' + Math.random().toString(36).substr(2, 9);
  
  if (!currentTabId) {
    // 新しいタブ：タブIDを生成して保存
    currentTabId = newTabId;
    sessionStorage.setItem(tabIdKey, currentTabId);
    console.log('新しいタブを検出、タブIDを生成:', currentTabId);
  } else {
    // タブIDが既に存在する場合、タブが複製された可能性がある
    // 複製を検出するため、ページ読み込みごとにタブIDを更新し、古いデータをクリア
    console.log('既存のタブID:', currentTabId);
    console.log('タブ複製の可能性があるため、shownフラグをクリアします');
    sessionStorage.removeItem(sessionKey);
    currentTabId = newTabId;
    sessionStorage.setItem(tabIdKey, currentTabId);
    console.log('新しいタブID:', currentTabId);
  }
  
  // セッションストレージからshownフラグを取得
  let shownQuestions = {};
  try {
    const stored = sessionStorage.getItem(sessionKey);
    if (stored) {
      shownQuestions = JSON.parse(stored);
      console.log('セッションストレージからshownフラグを読み込みました:', shownQuestions);
    } else {
      console.log('新しいセッション：shownフラグは空です');
    }
  } catch (e) {
    console.warn('shownフラグの読み込みに失敗:', e);
  }
  
  const questions = (rawQuestionData || []).map(q => ({
    ...q,
    shown: shownQuestions[q.id] || false
  }));
  
  // shownフラグをセッションストレージに保存する関数
  function saveShownFlag(questionId) {
    shownQuestions[questionId] = true;
    try {
      sessionStorage.setItem(sessionKey, JSON.stringify(shownQuestions));
      console.log(`問題ID ${questionId} のshownフラグをセッションストレージに保存しました`);
    } catch (e) {
      console.warn('shownフラグの保存に失敗:', e);
    }
  }
  
  console.log('質問データ:', questions);
  console.log('質問数:', questions.length);
  console.log('セッション中のshownフラグを維持します');
  
  // 質問データの詳細ログ
  questions.forEach((q, index) => {
    console.log(`質問${index + 1}:`, {
      id: q.id,
      content: q.content,
      time_position: q.time_position,
      question_type: q.question_type,
      shown: q.shown
    });
  });
  
  // デバッグ用：現在の問題の状態を確認する関数
  window.checkShownQuestions = function() {
    console.log('問題の状態:', questions.map(q => ({ 
      id: q.id, 
      content: q.content.substring(0, 20) + '...', 
      time: q.time_position + '秒',
      shown: q.shown 
    })));
  };
  
  const waitingMessage = document.getElementById('waiting-message');
  const questionDisplay = document.getElementById('question-display');
  const questionText = document.getElementById('question-text');
  const questionIndicator = document.getElementById('question-indicator');
  
  const trueFalseForm = document.getElementById('true-false-form');
  const multipleChoiceForm = document.getElementById('multiple-choice-form');
  const freeResponseForm = document.getElementById('free-response-form');
  const mcOptions = document.getElementById('mc-options');
  
  const tfSubmit = document.getElementById('tf-submit');
  const mcSubmit = document.getElementById('mc-submit');
  const frSubmit = document.getElementById('fr-submit');
  const resultMessage = document.getElementById('result-message');
  
  const noteTextarea = document.getElementById('note-textarea');
  const saveNoteBtn = document.getElementById('save-note-btn');
  const savedNotes = document.getElementById('saved-notes');
  
  // メモ入力時のイベント追加
  let noteInputTimer;
  noteTextarea.addEventListener('input', function() {
    // 連続した入力をまとめるために500ms待つ
    clearTimeout(noteInputTimer);
    noteInputTimer = setTimeout(() => {
      concentrationTracker.onNoteInput();
    }, 500);
  });
  
  let activeQuestion = null;
  let questionCloseTimer = null; // 問題を閉じるタイマーID
  let videoCheckInterval;
  let questionIndicatorTimeout;
  let questionStartTime = null; // 質問表示開始時間を記録
  let lastShownQuestionId = null; // 最後に表示した問題ID（連続表示防止用）
  let lastQuestionCloseTime = 0; // 最後に問題を閉じた時刻
  let isCheckingQuestions = false; // checkVideoTime()の再入防止フラグ
  let upcomingQuestionNotified = {}; // 「間もなく問題」を通知済みかを管理
  let savedPlaybackPosition = 0; // エラー時の再生位置保存用
  let videoErrorCount = 0; // エラー発生回数
  let lastErrorTime = 0; // 最後のエラー発生時刻

  if (videoPlayer) {
    // 動画の読み込み状態をデバッグログで確認
    console.log('初期動画状態:', {
      readyState: videoPlayer.readyState,
      paused: videoPlayer.paused,
      duration: videoPlayer.duration,
      currentSrc: videoPlayer.currentSrc
    });
    
    // 動画エラーハンドリング
    videoPlayer.addEventListener('error', function(e) {
      const now = Date.now();
      const error = videoPlayer.error;
      
      console.error('動画エラー発生:', {
        code: error?.code,
        message: error?.message,
        currentTime: videoPlayer.currentTime,
        src: videoPlayer.currentSrc
      });
      
      // 現在の再生位置を保存
      if (videoPlayer.currentTime > 0) {
        savedPlaybackPosition = videoPlayer.currentTime;
        console.log('再生位置を保存しました:', savedPlaybackPosition);
      }
      
      // 短時間に連続してエラーが発生する場合の対策
      if (now - lastErrorTime < 5000) {
        videoErrorCount++;
      } else {
        videoErrorCount = 1;
      }
      lastErrorTime = now;
      
      // エラーの種類に応じた処理
      if (error) {
        let errorMessage = '';
        switch (error.code) {
          case 1: // MEDIA_ERR_ABORTED
            errorMessage = '動画の読み込みが中断されました';
            break;
          case 2: // MEDIA_ERR_NETWORK
            errorMessage = 'ネットワークエラーが発生しました';
            break;
          case 3: // MEDIA_ERR_DECODE
            errorMessage = '動画のデコードに失敗しました';
            break;
          case 4: // MEDIA_ERR_SRC_NOT_SUPPORTED
            errorMessage = '動画ファイルがサポートされていないか、URLの有効期限が切れています';
            break;
          default:
            errorMessage = '動画の読み込み中にエラーが発生しました';
        }
        
        // エラーが頻発する場合はページリロードを提案
        if (videoErrorCount >= 3) {
          errorMessage += '\n\nエラーが繰り返し発生しています。ページを再読み込みしてください。';
          alert(errorMessage);
        } else {
          console.warn(errorMessage);
          
          // Active StorageのURLエラーの場合、ページリロードを提案
          if (error.code === 4 || error.code === 2) {
            const shouldReload = confirm(
              errorMessage + '\n\n動画を再読み込みしますか？\n（再生位置: ' + 
              Math.floor(savedPlaybackPosition) + '秒）'
            );
            
            if (shouldReload) {
              // 再生位置をセッションストレージに保存してリロード
              sessionStorage.setItem('resumeVideoAt', savedPlaybackPosition.toString());
              sessionStorage.setItem('resumeVideoId', '<%= @video.id %>');
              location.reload();
            }
          }
        }
      }
    });
    
    // stalled イベント（データ取得が停止）のハンドリング
    videoPlayer.addEventListener('stalled', function() {
      console.warn('動画データの取得が停止しました（stalled）');
      savedPlaybackPosition = videoPlayer.currentTime;
    });
    
    // suspend イベント（ブラウザが意図的にデータ取得を停止）
    videoPlayer.addEventListener('suspend', function() {
      console.log('動画データの取得が一時停止されました（suspend）');
    });
    
    // waiting イベント（次のフレームのバッファリング待ち）
    let waitingStartTime = 0;
    videoPlayer.addEventListener('waiting', function() {
      waitingStartTime = Date.now();
      console.log('動画バッファリング中（waiting）');
    });
    
    // playing イベント（バッファリングから復帰）
    videoPlayer.addEventListener('playing', function() {
      if (waitingStartTime > 0) {
        const waitDuration = Date.now() - waitingStartTime;
        console.log('バッファリング完了（待機時間: ' + waitDuration + 'ms）');
        waitingStartTime = 0;
      }
    });
    
    // ページ読み込み時に保存された再生位置を復元
    const resumeTime = sessionStorage.getItem('resumeVideoAt');
    const resumeVideoId = sessionStorage.getItem('resumeVideoId');
    
    if (resumeTime && resumeVideoId === '<%= @video.id %>') {
      const resumePosition = parseFloat(resumeTime);
      console.log('保存された再生位置を復元します:', resumePosition);
      
      videoPlayer.addEventListener('loadedmetadata', function restorePosition() {
        videoPlayer.currentTime = resumePosition;
        videoPlayer.removeEventListener('loadedmetadata', restorePosition);
        
        // セッションストレージをクリア
        sessionStorage.removeItem('resumeVideoAt');
        sessionStorage.removeItem('resumeVideoId');
        
        alert('前回の再生位置（' + Math.floor(resumePosition) + '秒）から再開します');
      });
    }
    
    // 動画の読み込み完了を待つ
    videoPlayer.addEventListener('loadedmetadata', function() {
      console.log('動画メタデータ読み込み完了');
    });
    
    // 動画の再生可能状態を待つ
    videoPlayer.addEventListener('canplay', function() {
      console.log('動画再生可能:', {
        readyState: videoPlayer.readyState,
        duration: videoPlayer.duration
      });
      
      // 動画が再生可能になったら問題チェック開始
      if (!videoCheckInterval) {
        console.log('問題チェックタイマー開始');
        videoCheckInterval = setInterval(checkVideoTime, 1000);
      }
    });
    
    // 動画の時間更新イベントで問題をチェック（より頻繁なチェック）
    let lastLoggedTime = 0;
    videoPlayer.addEventListener('timeupdate', function() {
      const currentTime = videoPlayer.currentTime;
      
      // 再生位置を定期的に保存（1秒ごと）
      if (currentTime > 0 && Math.floor(currentTime) !== Math.floor(lastLoggedTime)) {
        savedPlaybackPosition = currentTime;
        lastLoggedTime = currentTime;
      }
      
      // 再生位置が大きく後退した場合に警告（5秒以上）
      if (savedPlaybackPosition - currentTime > 5) {
        console.error('⚠️ 警告: 再生位置が大幅に後退しました!', {
          from: savedPlaybackPosition,
          to: currentTime,
          difference: savedPlaybackPosition - currentTime,
          readyState: videoPlayer.readyState,
          networkState: videoPlayer.networkState
        });
      }
      
      checkVideoTime();
    });
    
    // 再生開始時の追加チェック
    videoPlayer.addEventListener('play', function() {
      console.log('動画再生開始 - currentTime:', videoPlayer.currentTime);
      checkVideoTime(); // 即座にチェック（再入防止フラグで保護されている）
    });
    
    // 安全策として、DOMContentLoadedの後に少し遅延させて問題チェックを開始
    setTimeout(() => {
      if (!videoCheckInterval && videoPlayer.readyState >= 2) {
        console.log('遅延問題チェックタイマー開始');
        videoCheckInterval = setInterval(checkVideoTime, 1000);
      }
    }, 1000);
    
    // 再生位置の変更を監視（seeking開始）
    videoPlayer.addEventListener('seeking', function() {
      console.log('🔍 シーク開始:', {
        from: savedPlaybackPosition,
        to: videoPlayer.currentTime,
        stackTrace: new Error().stack
      });
    });
    
    // Reset questions when video is seeked
    videoPlayer.addEventListener('seeked', function() {
      const currentTime = videoPlayer.currentTime;
      console.log('✅ シーク完了:', currentTime);
      
      // 0秒に戻った場合は警告
      if (currentTime < 1 && savedPlaybackPosition > 5) {
        console.error('⚠️ 警告: 動画が意図せず0秒に戻りました!', {
          previousPosition: savedPlaybackPosition,
          currentPosition: currentTime,
          readyState: videoPlayer.readyState,
          networkState: videoPlayer.networkState,
          error: videoPlayer.error
        });
      }
      
      // 一度出題した問題は巻き戻しても再度出現しないように、
      // shown フラグのリセットは行わない
      
      // Hide the indicator until the next check
      questionIndicator.style.display = 'none';
      if (questionIndicatorTimeout) {
        clearTimeout(questionIndicatorTimeout);
      }
    });
    
    // 動画が終了しても問題のshownフラグはリセットしない
    // これにより、同じセッション内で動画を最初から再生しても、
    // 既に出題した問題は再度表示されない
    videoPlayer.addEventListener('ended', function() {
      console.log('動画終了（問題は再表示されません）');
    });
    
    // 初回の問題チェックを動画と質問データの両方が揃ったタイミングで実行
    let initialQuestionCheckDone = false;
    function tryInitialQuestionCheck() {
      if (!initialQuestionCheckDone && videoPlayer.readyState >= 2 && questions.length > 0) {
        console.log('初回の問題チェックを強制実行します');
        checkVideoTime();
        initialQuestionCheckDone = true;
      }
    }
    
    document.addEventListener('DOMContentLoaded', tryInitialQuestionCheck);
    videoPlayer.addEventListener('loadedmetadata', tryInitialQuestionCheck);
    videoPlayer.addEventListener('canplay', tryInitialQuestionCheck);
    
    function checkVideoTime() {
      // 既に実行中の場合はスキップ（再入防止）
      if (isCheckingQuestions) {
        console.log('⏭️  checkVideoTime: 既に実行中のためスキップ');
        return;
      }
      
      // 動画が読み込まれていない場合は何もしない
      if (videoPlayer.readyState < 2) {
        console.log('動画がまだ十分に読み込まれていません:', videoPlayer.readyState);
        return;
      }
      
      isCheckingQuestions = true; // 実行開始フラグ
      
      try {
        const currentTime = videoPlayer.currentTime;
        
        // 再生中またはチェックする必要がある場合
        if (!videoPlayer.paused || activeQuestion !== null) {
          // Check for upcoming questions
          const upcomingQuestionWindow = 5; // Show indicator 5 seconds before question
        
        let hasUpcomingQuestion = false;
        for (let i = 0; i < questions.length; i++) {
          const question = questions[i];
          
          // Check if there's a question coming up soon but not yet shown
          if (currentTime < question.time_position && 
              currentTime >= question.time_position - upcomingQuestionWindow && 
              !question.shown) {
            hasUpcomingQuestion = true;
            
            // 「間もなく問題」を1回だけ通知
            if (!upcomingQuestionNotified[question.id]) {
              console.log('間もなく問題:', question.content);
              upcomingQuestionNotified[question.id] = true;
            }
            
            // Show indicator if not already showing
            if (questionIndicator.style.display !== 'block') {
              questionIndicator.style.display = 'block';
              
              // Clear any existing timeout
              if (questionIndicatorTimeout) {
                clearTimeout(questionIndicatorTimeout);
              }
            }
          }
          
          // If the current time is past or equal to the question time and within a larger window (2s)
          // and no question is currently active
          // セッションストレージから直接shown状態をチェック
          // 連続表示防止：最後に表示した問題と同じ場合、かつ問題を閉じてから1秒以内の場合はスキップ
          const timeSinceLastClose = Date.now() - lastQuestionCloseTime;
          const isSameAsLastQuestion = lastShownQuestionId === question.id && timeSinceLastClose < 1000;
          
          // 重複表示を防ぐための複数チェック
          if (isSameAsLastQuestion) {
            console.log('🔒 連続表示防止:', question.id, `前回から${timeSinceLastClose}ms`);
            continue; // この問題をスキップして次の問題へ
          }
          
          // 既に表示済みかを確認（sessionStorageを含む3つの場所をチェック）
          const isShownInStorage = sessionStorage.getItem(`video_${videoId}_shown_${question.id}`) === 'true';
          const isShown = shownQuestions[question.id] === true || question.shown === true || isShownInStorage;
          
          // デバッグ：チェック状態を詳細ログ
          if (currentTime >= question.time_position && currentTime <= question.time_position + 2.0) {
            console.log(`[問題チェック] ID:${question.id}, isShown:${isShown}, storage:${isShownInStorage}, obj:${shownQuestions[question.id]}, prop:${question.shown}, activeQ:${activeQuestion}`);
          }
          
          // 既に表示済みの問題はスキップ
          if (isShown) {
            continue;
          }
          
          if (currentTime >= question.time_position && 
              currentTime <= question.time_position + 2.0 && 
              activeQuestion === null) {
            
            // 🚨 最優先：フラグを即座に設定（他の処理より前に実行）
            question.shown = true;
            shownQuestions[question.id] = true;
            lastShownQuestionId = question.id;
            saveShownFlag(question.id);
            
            console.log('問題検出:', question);
            console.log('現在の時間:', currentTime, '問題時間:', question.time_position);
            console.log('時間差:', currentTime - question.time_position);
            console.log('問題ID', question.id, 'を表示済みとしてマークしました');
            
            // Hide the indicator
            questionIndicator.style.display = 'none';
            if (questionIndicatorTimeout) {
              clearTimeout(questionIndicatorTimeout);
            }
            try {
              console.log('showQuestion関数を呼び出します');
              showQuestion(question);
              videoPlayer.pause();
              console.log('動画を一時停止しました');
            } catch (error) {
              console.error('問題表示中にエラーが発生しました:', error);
              // エラーが発生した場合はshownフラグをリセット
              question.shown = false;
            }
            break;
          }
        }
        
        // If no upcoming questions, hide the indicator
        if (!hasUpcomingQuestion && questionIndicator.style.display === 'block') {
          // Set a small delay before hiding to prevent flickering
          questionIndicatorTimeout = setTimeout(() => {
            questionIndicator.style.display = 'none';
          }, 500);
        }
      }
      } finally {
        // 処理完了後、必ず実行中フラグを解除
        isCheckingQuestions = false;
      }
    }
    
    function showQuestion(question) {
      console.log('showQuestion関数開始:', question);
      
      // 既にactiveQuestionがある場合は警告
      if (activeQuestion) {
        console.warn('⚠️ 既にactiveQuestionが存在します:', activeQuestion);
        console.warn('新しい問題:', question);
      }
      
      // 既存の問題を閉じるタイマーがあればキャンセル
      if (questionCloseTimer) {
        console.log('既存のquestionCloseTimerをキャンセルします');
        clearTimeout(questionCloseTimer);
        questionCloseTimer = null;
      }
      
      // 問題表示開始時間を記録
      questionStartTime = Date.now();
      
      // 集中度トラッカーに問題表示を通知
      if (window.concentrationTracker) {
        concentrationTracker.onQuestionDisplayed();
      } else {
        console.warn('ConcentrationTrackerが利用できません');
      }
      
      // 問題データの検証
      if (!question || !question.content) {
        console.error('問題データが不正です:', question);
        return;
      }
      
      console.log('問題データ検証完了');
      
      console.log('activeQuestionを設定します:', question.id);
      activeQuestion = question;
      console.log('activeQuestion設定完了');
      
      try {
        // UI要素の存在確認
        if (!waitingMessage) {
          console.error('waitingMessage要素が見つかりません');
          return;
        }
        if (!questionDisplay) {
          console.error('questionDisplay要素が見つかりません');
          return;
        }
        if (!questionText) {
          console.error('questionText要素が見つかりません');
          return;
        }
        
        console.log('UI要素の存在確認完了');
        
        // Hide waiting message, show question
        waitingMessage.style.display = 'none';
        questionDisplay.style.display = 'block';
        
        console.log('UI表示切り替え完了');
        
        // Set question text with timestamp
        const timeFormatted = formatTimePosition(question.time_position || 0);
        console.log('フォーマット済み時間:', timeFormatted);
        console.log('問題内容:', question.content);
        
        // 問題文を表示
        questionText.textContent = ''; // 一旦クリア
        
        const timestampDiv = document.createElement('div');
        timestampDiv.className = 'question-timestamp';
        timestampDiv.textContent = timeFormatted;
        questionText.appendChild(timestampDiv);
        
        const contentDiv = document.createElement('div');
        contentDiv.className = 'question-content-text';
        contentDiv.textContent = question.content;
        questionText.appendChild(contentDiv);
        
        // Reset previous result message
        resultMessage.style.display = 'none';
        resultMessage.className = 'result-message';
        
        // Show appropriate form based on question type
        trueFalseForm.style.display = 'none';
        multipleChoiceForm.style.display = 'none';
        freeResponseForm.style.display = 'none';
        
        if (question.question_type === 'true_false') {
          trueFalseForm.style.display = 'block';
          // Reset selection
          const radios = trueFalseForm.querySelectorAll('input[type="radio"]');
          radios.forEach(radio => radio.checked = false);
        } 
        else if (question.question_type === 'multiple_choice') {
          multipleChoiceForm.style.display = 'block';
          
          // Clear previous options
          mcOptions.innerHTML = '';
          
          // Add new options
          if (question.options && question.options.length > 0) {
            question.options.forEach((option, index) => {
              if (!option || !option.content) return;
              
              const label = document.createElement('label');
              label.className = 'option-label';
              
              const input = document.createElement('input');
              input.type = 'radio';
              input.name = 'mc-answer';
              input.value = option.id;
              
              label.appendChild(input);
              label.appendChild(document.createTextNode(' ' + option.content));
              mcOptions.appendChild(label);
            });
          } else {
            console.error('選択肢がありません:', question);
          }
        } 
        else if (question.question_type === 'free_response') {
          freeResponseForm.style.display = 'block';
          document.getElementById('free-response-answer').value = '';
        }
        
        // 送信ボタンを有効化（新しい問題なので送信可能にする）
        if (tfSubmit) tfSubmit.disabled = false;
        if (mcSubmit) mcSubmit.disabled = false;
        if (frSubmit) frSubmit.disabled = false;
        
      } catch (error) {
        console.error('問題表示中にエラーが発生しました:', error);
      }
    }
    
    // Helper function to format time position
    function formatTimePosition(timeInSeconds) {
      const minutes = Math.floor(timeInSeconds / 60);
      const seconds = Math.floor(timeInSeconds % 60);
      return `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
    }
    
    // Handle true/false submission - 重複登録を防止
    if (tfSubmit && !tfSubmit.dataset.listenerAdded) {
      tfSubmit.addEventListener('click', function() {
        console.log('○×問題の送信ボタンがクリックされました。activeQuestion:', activeQuestion);
        if (!activeQuestion) {
          alert('すでに回答済みです');
          return;
        }
        
        const selectedAnswer = document.querySelector('input[name="tf-answer"]:checked');
        
        if (selectedAnswer) {
          // 集中度トラッカーに回答開始を通知
          concentrationTracker.onResponseStarted();
          submitAnswer(selectedAnswer.value, null);
        } else {
          alert('回答を選択してください');
        }
      });
      tfSubmit.dataset.listenerAdded = 'true';
      console.log('○×問題の送信ボタンのイベントリスナーを登録しました');
    }
    
    // Handle multiple choice submission - 重複登録を防止
    if (mcSubmit && !mcSubmit.dataset.listenerAdded) {
      mcSubmit.addEventListener('click', function() {
        console.log('選択問題の送信ボタンがクリックされました。activeQuestion:', activeQuestion);
        if (!activeQuestion) {
          alert('すでに回答済みです');
          return;
        }
        
        const selectedOption = document.querySelector('input[name="mc-answer"]:checked');
        
        if (selectedOption) {
          // 集中度トラッカーに回答開始を通知
          concentrationTracker.onResponseStarted();
          const optionId = selectedOption.value;
          submitAnswer(null, optionId);
        } else {
          alert('回答を選択してください');
        }
      });
      mcSubmit.dataset.listenerAdded = 'true';
      console.log('選択問題の送信ボタンのイベントリスナーを登録しました');
    }
    
    // Handle free response submission - 重複登録を防止
    if (frSubmit && !frSubmit.dataset.listenerAdded) {
      frSubmit.addEventListener('click', function() {
        console.log('記述問題の送信ボタンがクリックされました。activeQuestion:', activeQuestion);
        if (!activeQuestion) {
          alert('すでに回答済みです');
          return;
        }
        
        const answer = document.getElementById('free-response-answer').value.trim();
        
        // 集中度トラッカーに回答開始を通知
        concentrationTracker.onResponseStarted();
        // 記述問題では空欄も有効な回答として受け付ける
        submitAnswer(answer, null);
      });
      frSubmit.dataset.listenerAdded = 'true';
      console.log('記述問題の送信ボタンのイベントリスナーを登録しました');
    }
    
    function submitAnswer(userAnswer, optionId) {
      console.log('submitAnswer開始:', { userAnswer, optionId, activeQuestion });
      
      // activeQuestionのチェック
      if (!activeQuestion) {
        console.error('activeQuestionがnullです。すでに回答済みです。');
        alert('すでに回答済みです');
        return;
      }
      
      // 既に送信済みまたは送信中の場合は処理しない
      if (activeQuestion.submitted || activeQuestion.submitting) {
        console.log('この問題は既に送信済みまたは送信中です');
        return;
      }
      
      // 送信中フラグを立てる
      activeQuestion.submitting = true;
      
      // すべての送信ボタンを無効化
      if (tfSubmit) tfSubmit.disabled = true;
      if (mcSubmit) mcSubmit.disabled = true;
      if (frSubmit) frSubmit.disabled = true;
      
      // 回答時間を計算（ミリ秒）
      const responseTime = questionStartTime ? Date.now() - questionStartTime : 0;
      console.log('回答時間:', responseTime, 'ms');
      
      // タイムスタンプ記録
      if (window.concentrationTracker) {
        window.concentrationTracker.addTimestamp('answer_submit', '回答送信', {
          userAnswer: userAnswer,
          optionId: optionId,
          responseTimeMs: responseTime,
          responseTimeS: responseTime / 1000
        });
      }
      
      const formData = new FormData();
      
      if (userAnswer) {
        formData.append('user_response[user_answer]', userAnswer);
      }
      
      if (optionId) {
        formData.append('option_id', optionId);
      }
      
      // 回答時間を追加
      formData.append('user_response[response_time]', responseTime.toString());
      
      // CSRFトークンを取得
      const csrfToken = document.querySelector('meta[name="csrf-token"]');
      const headers = {
        'Accept': 'application/json'
      };
      if (csrfToken) {
        headers['X-CSRF-Token'] = csrfToken.content;
      }
      
      // Store the current question for reference after the request
      const currentQuestion = activeQuestion;
      
      // 送信前にデバッグ情報
      console.log('送信データ:', {
        url: `/videos/<%= @video.id %>/questions/${currentQuestion.id}/user_responses`,
        userAnswer: userAnswer,
        optionId: optionId
      });
      
      // Send response to the server
      fetch(`/videos/<%= @video.id %>/questions/${currentQuestion.id}/user_responses`, {
        method: 'POST',
        body: formData,
        headers: headers
      })
      .then(response => {
        console.log('レスポンスステータス:', response.status);
        console.log('レスポンスヘッダー:', {
          contentType: response.headers.get('Content-Type'),
          accept: response.headers.get('Accept')
        });
        
        if (!response.ok) {
          // エラーレスポンスの場合、JSONで詳細を取得
          const contentType = response.headers.get('Content-Type');
          if (contentType && contentType.includes('application/json')) {
            return response.json().then(errorData => {
              console.error('サーバーエラー詳細:', errorData);
              const error = new Error(`Server error: ${response.status}`);
              error.response = response;
              error.data = errorData;
              throw error;
            });
          } else {
            return response.text().then(text => {
              console.error('エラーレスポンス:', text);
              const error = new Error(`Network response was not ok: ${response.status}`);
              error.response = response;
              throw error;
            });
          }
        }
        
        // Check if the response is JSON
        const contentType = response.headers.get('Content-Type');
        if (!contentType || !contentType.includes('application/json')) {
          return response.text().then(text => {
            console.error('予期せぬレスポース形式:', contentType, text);
            throw new Error('Expected JSON response but got ' + contentType);
          });
        }
        
        return response.json();
      })
      .then(data => {
        console.log('サーバーレスポンス:', data);
        
        // Display result
        resultMessage.style.display = 'block';
        
        console.log('回答結果データ:', {
          correct: data.correct,
          show_answer: data.show_answer,
          correct_answer: data.correct_answer
        });
        
        let resultText = '';
        
        if (data.correct) {
          resultMessage.className = 'result-message correct';
          resultText = '正解です！';
          
          // 解答表示設定が有効な場合、正解も表示
          if (data.show_answer && data.correct_answer) {
            resultText += ` 正解: ${data.correct_answer}`;
          }
        } else {
          resultMessage.className = 'result-message incorrect';
          resultText = '不正解です。';
          
          // 解答表示設定が有効な場合のみ正解を表示
          if (data.show_answer && data.correct_answer) {
            resultText += ` 正解: ${data.correct_answer}`;
          }
        }
        
        // 回答時間を表示
        if (data.response_time) {
          resultText += ` (回答時間: ${data.response_time.toFixed(1)}秒)`;
        }
        
        resultMessage.textContent = resultText;
        
        // 送信済みフラグを立てる
        if (currentQuestion) {
          currentQuestion.submitted = true;
          currentQuestion.submitting = false;
        }
        
        // Reset active question after 3 seconds and resume video
        questionCloseTimer = setTimeout(() => {
          console.log('✅ questionCloseTimer実行: 問題を閉じます');
          questionCloseTimer = null;
          console.log('activeQuestionをnullに設定します。現在:', activeQuestion);
          activeQuestion = null;
          lastQuestionCloseTime = Date.now(); // 問題を閉じた時刻を記録
          
          // ConcentrationTrackerのタイミング変数もリセット
          if (window.concentrationTracker) {
            window.concentrationTracker.questionDisplayTime = null;
            window.concentrationTracker.responseStartTime = null;
            window.concentrationTracker.responseProcessed = false;
          }
          
          // 問題表示と結果メッセージを非表示にする
          resultMessage.style.display = 'none';
          waitingMessage.style.display = 'block';
          questionDisplay.style.display = 'none';
          videoPlayer.play();
        }, 3000);
      })
      .catch(error => {
        console.error('Error:', error);
        
        let errorMessage = '回答の送信中にエラーが発生しました。';
        
        // サーバーからのエラーデータがある場合
        if (error.data) {
          console.error('Server error details:', error.data);
          
          if (error.data.errors && error.data.errors.length > 0) {
            errorMessage += '\n詳細: ' + error.data.errors.join(', ');
          }
          
          if (error.data.debug_info) {
            console.log('Debug info:', error.data.debug_info);
          }
        } else if (error.message) {
          errorMessage += '\n詳細: ' + error.message;
        }
        
        alert(errorMessage);
        
        // エラー時は送信中フラグをリセット（再試行可能にする）
        if (currentQuestion) {
          currentQuestion.submitting = false;
        }
        
        // ボタンを再度有効化
        if (tfSubmit) tfSubmit.disabled = false;
        if (mcSubmit) mcSubmit.disabled = false;
        if (frSubmit) frSubmit.disabled = false;
        
        // In case of error, still reset the question and continue playing
        questionCloseTimer = setTimeout(() => {
          console.log('⚠️ エラー後のquestionCloseTimer実行: 問題を閉じます');
          questionCloseTimer = null;
          console.log('activeQuestionをnullに設定します。現在:', activeQuestion);
          activeQuestion = null;
          lastQuestionCloseTime = Date.now(); // 問題を閉じた時刻を記録
          console.log('activeQuestion = null 設定完了');
          
          // ConcentrationTrackerのタイミング変数もリセット
          if (window.concentrationTracker) {
            window.concentrationTracker.questionDisplayTime = null;
            window.concentrationTracker.responseStartTime = null;
            window.concentrationTracker.responseProcessed = false;
          }
          
          // 問題表示と結果メッセージを非表示にする
          resultMessage.style.display = 'none';
          waitingMessage.style.display = 'block';
          questionDisplay.style.display = 'none';
          videoPlayer.play();
        }, 1000);
      });
    }
    
    // Note system
    saveNoteBtn.addEventListener('click', function() {
      const noteContent = noteTextarea.value.trim();
      
      if (noteContent) {
        // 集中度トラッカーにメモ入力を通知
        concentrationTracker.onNoteInput();
        
        // 現在の動画時刻を取得
        const currentTime = Math.floor(videoPlayer.currentTime);
        const minutes = Math.floor(currentTime / 60);
        const seconds = Math.floor(currentTime % 60);
        const timeString = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
        
        // txtファイルの内容を生成
        const videoTitle = '<%= @video.title.gsub("'", "\\'") %>';
        const timestamp = new Date().toLocaleString('ja-JP');
        const txtContent = `動画タイトル: ${videoTitle}\n作成日時: ${timestamp}\n動画時刻: ${timeString}\n\n${noteContent}`;
        
        // Blobを作成してダウンロード
        const blob = new Blob([txtContent], { type: 'text/plain;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `memo_${videoTitle.replace(/[\\/:*?"<>|]/g, '_')}_${timeString.replace(':', '-')}.txt`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        
        // 保存成功メッセージ
        alert('メモをtxtファイルとしてダウンロードしました！');
      } else {
        alert('メモを入力してください');
      }
    });
    
    // Clean up interval when leaving the page
    window.addEventListener('beforeunload', function() {
      clearInterval(videoCheckInterval);
      // 動画ページを離れるときにsessionStorageをクリア（次回アクセス時にリロードするため）
      sessionStorage.removeItem('videoPageLoaded');
    });
  }
}

