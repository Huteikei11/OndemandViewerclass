          if (timeFromQuestion < this.scoreSettings.questionConfirmWindow) {
            console.log(`🔍 [onFaceMeshResults呼び出し] 経過:${timeFromQuestion.toFixed(2)}秒, 顔検出:${results.multiFaceLandmarks?.length > 0}`);
          }
