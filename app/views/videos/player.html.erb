          const landmarks = results.multiFaceLandmarks[0];
          
          // 視線方向を計算
          this.calculateGazeFromLandmarks(landmarks);
          
        } else {
          this.faceDetected = false;
          // 顔が検出されない場合はデフォルト値
          this.gazeX = 0;
          this.gazeY = 0;
        }
        
        // 正面向き割合の更新
        this.updateFrontFacingRatio();
        
        // 最新の顔検出状態を記録（30fpsで更新されるが、addGazeData()はstartTracking()から呼ばれる）
        this.lastFaceMeshUpdate = Date.now();
        
        // 速い問題確認の判定を実行
