      this.smoothingWindowSize = 8; // 移動平均のウィンドウサイズ
      this.noiseThreshold = 3; // ノイズ除去の閾値（ピクセル）
      this.lastValidGaze = { x: 0, y: 0, timestamp: Date.now() }; // 最後の有効な視線データ
      
      // 顔の向きの追跡
