      }
    }
    
    calculateGazeFromLandmarks(landmarks) {
      try {
        // 眼球の詳細なランドマークを取得
        const leftEyeData = this.getDetailedEyeData(landmarks, 'left');
        const rightEyeData = this.getDetailedEyeData(landmarks, 'right');
        
        // 両目のデータが有効な場合のみ処理
        if (leftEyeData.isValid && rightEyeData.isValid) {
          // 両目の眼球位置の平均を計算
          const avgPupilX = (leftEyeData.pupilRatio.x + rightEyeData.pupilRatio.x) / 2;
          const avgPupilY = (leftEyeData.pupilRatio.y + rightEyeData.pupilRatio.y) / 2;
          
          // 眼球の動きを視線方向に変換（-1 to 1の範囲）
          // カメラ映像が左右反転されているため、X座標も反転
          // 左右の動き: 負の値が右、正の値が左（反転）
          const normalizedGazeX = -((avgPupilX - 0.5) * 2);
          // 上下の動き: 負の値が上、正の値が下（変更なし）
          const normalizedGazeY = (avgPupilY - 0.5) * 2;
          
          // スケールして生の値を計算（-50 to 50の範囲）
          const rawGazeX = Math.max(-50, Math.min(50, normalizedGazeX * 50));
          const rawGazeY = Math.max(-50, Math.min(50, normalizedGazeY * 50));
          
          // 平滑化を適用
          this.updateGazeWithSmoothing(rawGazeX, rawGazeY);
          
          // 眼球の詳細データを保存（デバッグ用）
          this.eyeballData = {
            left: leftEyeData,
            right: rightEyeData,
            avgPupilRatio: { x: avgPupilX, y: avgPupilY },
            rawGaze: { x: normalizedGazeX, y: normalizedGazeY }
          };
        } else {
          // フォールバック: 顔の向きベースの計算
          this.calculateGazeFromFaceOrientation(landmarks);
        }
        
        // 視線データのスムージング処理
        this.applySmoothingToGaze();
        
        // 眼球動きの変化量を計算（スムージング後のデータを使用）
        this.calculateGazeMovementDelta();
        
        // 動きがあった場合は記録（ただし、急激な変化はまばたきとして除外）
        const positionChange = Math.sqrt(
          Math.pow(this.gazeX - this.previousGaze.x, 2) + 
          Math.pow(this.gazeY - this.previousGaze.y, 2)
        );
        const velocityMagnitude = Math.sqrt(
          Math.pow(this.gazeVelocity.x, 2) + 
          Math.pow(this.gazeVelocity.y, 2)
        );
        
        // 位置が閾値を超えていて、かつ速度が異常に高くない場合のみ動きとして記録
        if ((Math.abs(this.gazeX) > this.scoreSettings.movementDetectionThreshold || 
             Math.abs(this.gazeY) > this.scoreSettings.movementDetectionThreshold) &&
            velocityMagnitude < 20) { // 20px/s以下の変化のみ有効な動きとする
          this.lastMovementTime = Date.now();
        }
        
        // 顔の向きを計算
        this.calculateHeadPoseFromLandmarks(landmarks);
        
      } catch (error) {
        console.error('視線計算エラー:', error);
        // エラー時はデフォルト値
        this.gazeX = 0;
        this.gazeY = 0;
        // 変化量もリセット
        this.gazeVelocity = { x: 0, y: 0 };
        this.headPoseX = 0;
        this.headPoseY = 0;
        this.headPoseVelocity = { x: 0, y: 0 };
      }
    }
    
    getDetailedEyeData(landmarks, eye) {
      try {
        let eyeIndices, irisIndices;
        
        if (eye === 'left') {
          // 左目のランドマーク（468点Face Meshより）
          eyeIndices = [33, 7, 163, 144, 145, 153, 154, 155, 133, 173, 157, 158, 159, 160, 161, 246];
          // 左目の虹彩周辺のランドマーク
          irisIndices = [468, 469, 470, 471, 472]; // MediaPipe iris landmarksの一部
        } else {
          // 右目のランドマーク
          eyeIndices = [362, 382, 381, 380, 374, 373, 390, 249, 263, 466, 388, 387, 386, 385, 384, 398];
          // 右目の虹彩周辺のランドマーク
          irisIndices = [473, 474, 475, 476, 477]; // MediaPipe iris landmarksの一部
        }
        
        // 目のバウンディングボックスを計算
        const eyePoints = eyeIndices.map(i => landmarks[i]).filter(p => p);
        if (eyePoints.length === 0) {
          return { isValid: false };
        }
        
        const minX = Math.min(...eyePoints.map(p => p.x));
        const maxX = Math.max(...eyePoints.map(p => p.x));
        const minY = Math.min(...eyePoints.map(p => p.y));
        const maxY = Math.max(...eyePoints.map(p => p.y));
        
        const eyeWidth = maxX - minX;
        const eyeHeight = maxY - minY;
        const eyeCenter = { x: (minX + maxX) / 2, y: (minY + maxY) / 2 };
        
        // 瞳孔位置の推定（虹彩中心または目の重心）
        let pupilCenter;
        
        // 虹彩ランドマークが利用可能な場合
        const irisPoints = irisIndices.map(i => landmarks[i]).filter(p => p);
        if (irisPoints.length > 0) {
          // 虹彩の中心を計算
          pupilCenter = {
            x: irisPoints.reduce((sum, p) => sum + p.x, 0) / irisPoints.length,
            y: irisPoints.reduce((sum, p) => sum + p.y, 0) / irisPoints.length
          };
        } else {
          // フォールバック: 目の内側の点を使用して瞳孔位置を推定
          const innerCorner = eye === 'left' ? landmarks[133] : landmarks[362];
          const outerCorner = eye === 'left' ? landmarks[33] : landmarks[263];
          const upperLid = eye === 'left' ? landmarks[159] : landmarks[386];
          const lowerLid = eye === 'left' ? landmarks[145] : landmarks[374];
          
          if (innerCorner && outerCorner && upperLid && lowerLid) {
            // 目の開閉度を計算
            const eyeOpenness = Math.abs(upperLid.y - lowerLid.y);
            const eyeWidth = Math.abs(outerCorner.x - innerCorner.x);
            const openRatio = eyeOpenness / (eyeWidth * 0.3); // 正常な開眼時の比率
            
            // 目が十分開いている場合のみ瞳孔位置を推定
            if (openRatio > 0.3) {
              // まぶたの曲線から瞳孔位置を推定
              const lidCenterX = (innerCorner.x + outerCorner.x) / 2;
              const lidCenterY = (upperLid.y + lowerLid.y) / 2;
              
              // 目の形状に基づく微調整
              // 通常、瞳孔は目の中央よりわずかに内側寄りにある
              const adjustX = eye === 'left' ? 0.45 : 0.55; // 左目は内側寄り、右目は外側寄り
              const adjustY = 0.4; // 瞳孔は通常上まぶた寄り
              
              pupilCenter = {
                x: innerCorner.x + (outerCorner.x - innerCorner.x) * adjustX,
                y: upperLid.y + (lowerLid.y - upperLid.y) * adjustY
              };
            } else {
              // 目が閉じている場合は中央を使用
              pupilCenter = eyeCenter;
            }
          } else {
            pupilCenter = eyeCenter;
          }
        }
        
        // 瞳孔の相対位置を計算（0-1の範囲）
        const pupilRatio = {
          x: eyeWidth > 0 ? (pupilCenter.x - minX) / eyeWidth : 0.5,
          y: eyeHeight > 0 ? (pupilCenter.y - minY) / eyeHeight : 0.5
        };
        
        // 結果を返す
        return {
          isValid: true,
          eyeCenter,
          pupilCenter,
          pupilRatio,
          eyeBounds: { minX, maxX, minY, maxY, width: eyeWidth, height: eyeHeight },
          confidence: irisPoints.length > 0 ? 0.9 : 0.6 // 虹彩データがある場合は高い信頼度
        };
        
      } catch (error) {
        console.error(`${eye}目のデータ取得エラー:`, error);
        return { isValid: false };
      }
    }
    
    calculateGazeFromFaceOrientation(landmarks) {
      // フォールバック: 従来の顔の向きベースの計算
      try {
        const leftEye = this.getEyeCenter(landmarks, [33, 7, 163, 144, 145, 153, 154, 155, 133, 173, 157, 158, 159, 160, 161, 246]);
        const rightEye = this.getEyeCenter(landmarks, [362, 382, 381, 380, 374, 373, 390, 249, 263, 466, 388, 387, 386, 385, 384, 398]);
        const faceCenter = landmarks[9];
        
        const eyeCenter = {
          x: (leftEye.x + rightEye.x) / 2,
          y: (leftEye.y + rightEye.y) / 2
        };
        
        const faceWidth = Math.abs(leftEye.x - rightEye.x);
        const faceHeight = Math.abs(landmarks[10].y - landmarks[152].y);
        
        // カメラ映像が左右反転されているため、X座標も反転
        const normalizedGazeX = -((eyeCenter.x - faceCenter.x) / (faceWidth * 0.5));
        const normalizedGazeY = (eyeCenter.y - faceCenter.y) / (faceHeight * 0.5);
        
        const rawGazeX = Math.max(-50, Math.min(50, normalizedGazeX * 50));
        const rawGazeY = Math.max(-50, Math.min(50, normalizedGazeY * 50));
        
        // 平滑化を適用
        this.updateGazeWithSmoothing(rawGazeX, rawGazeY);
        
      } catch (error) {
        console.error('フォールバック視線計算エラー:', error);
        this.gazeX = 0;
        this.gazeY = 0;
      }
    }
    
    getEyeCenter(landmarks, eyeIndices) {
      let sumX = 0, sumY = 0;
      for (const index of eyeIndices) {
        if (landmarks[index]) {
          sumX += landmarks[index].x;
          sumY += landmarks[index].y;
        }
      }
      return {
        x: sumX / eyeIndices.length,
        y: sumY / eyeIndices.length
      };
    }
    
    applySmoothingToGaze() {
      const currentTime = Date.now();
      
      // 生の視線データを履歴に追加
      this.gazeRawHistory.push({
        x: this.gazeX,
        y: this.gazeY,
        timestamp: currentTime
      });
      
      // 履歴のサイズを制限
      if (this.gazeRawHistory.length > this.smoothingWindowSize) {
        this.gazeRawHistory.shift();
      }
      
      // ノイズ除去: 極端な値を検出して除去
      const filteredHistory = this.removeNoiseFromGazeData();
      
      if (filteredHistory.length >= 3) {
        // 移動平均を計算
        const smoothedX = filteredHistory.reduce((sum, data) => sum + data.x, 0) / filteredHistory.length;
        const smoothedY = filteredHistory.reduce((sum, data) => sum + data.y, 0) / filteredHistory.length;
        
        // 重み付き平均（新しいデータにより大きな重みを付ける）
        const weights = filteredHistory.map((_, index) => Math.pow(1.2, index)); // 新しいデータほど重い
        const totalWeight = weights.reduce((sum, weight) => sum + weight, 0);
        
        const weightedX = filteredHistory.reduce((sum, data, index) => sum + data.x * weights[index], 0) / totalWeight;
        const weightedY = filteredHistory.reduce((sum, data, index) => sum + data.y * weights[index], 0) / totalWeight;
        
        // スムージング結果を保存
        this.gazeSmoothed.x = weightedX;
        this.gazeSmoothed.y = weightedY;
        
        // スムージング後のデータで元の値を更新
        this.gazeX = weightedX;
        this.gazeY = weightedY;
        
        // 有効なデータとして記録
        this.lastValidGaze = { x: weightedX, y: weightedY, timestamp: currentTime };
      } else if (this.lastValidGaze.timestamp > 0 && (currentTime - this.lastValidGaze.timestamp) < 500) {
        // データが不足している場合は前回の有効なデータを使用（0.5秒以内）
        this.gazeX = this.lastValidGaze.x;
        this.gazeY = this.lastValidGaze.y;
      }
    }
    
    calculateHeadPoseFromLandmarks(landmarks) {
      try {
        // 顔の主要な特徴点を使用して向きを計算
        const noseTip = landmarks[1]; // 鼻先
        const faceCenter = landmarks[9]; // 顔の中心
        const leftEyeCorner = landmarks[33]; // 左目尻
        const rightEyeCorner = landmarks[263]; // 右目尻
        const chinCenter = landmarks[18]; // 顎の中心
        const foreheadCenter = landmarks[10]; // 額の中心
        
        if (!noseTip || !faceCenter || !leftEyeCorner || !rightEyeCorner || !chinCenter || !foreheadCenter) {
          return;
        }
        
        // 顔の基準サイズを計算
        const faceWidth = Math.abs(leftEyeCorner.x - rightEyeCorner.x);
        const faceHeight = Math.abs(foreheadCenter.y - chinCenter.y);
        
        // 水平方向の向き（左右の回転）
        // 鼻先と顔の中心の水平方向のずれで判定
        const horizontalOffset = (noseTip.x - faceCenter.x) / (faceWidth * 0.5);
        
        // 垂直方向の向き（上下の傾き）
        // 鼻先と顔の中心の垂直方向のずれで判定
        const verticalOffset = (noseTip.y - faceCenter.y) / (faceHeight * 0.5);
        
        // カメラ映像が左右反転されているため、X座標も反転
        this.headPoseX = Math.max(-50, Math.min(50, -horizontalOffset * 50));
        this.headPoseY = Math.max(-50, Math.min(50, verticalOffset * 50));
        
        // 顔の向きの変化量を計算
        this.calculateHeadPoseMovementDelta();
        
      } catch (error) {
        console.error('顔の向き計算エラー:', error);
        this.headPoseX = 0;
        this.headPoseY = 0;
      }
    }
    
    calculateHeadPoseMovementDelta() {
      const currentTime = Date.now();
      const currentHeadPose = { x: this.headPoseX, y: this.headPoseY };
      
      // 前回の記録からの時間差（秒）
      const deltaTime = (currentTime - this.previousHeadPose.timestamp) / 1000;
      
      if (deltaTime > 0 && deltaTime < 1.0) { // 1秒以内の変化のみ有効
        // 速度計算（角度/秒）
        let velocityX = (currentHeadPose.x - this.previousHeadPose.x) / deltaTime;
        let velocityY = (currentHeadPose.y - this.previousHeadPose.y) / deltaTime;
        
        // 速度値の異常チェック（急激な変化を制限）
        const maxVelocity = 100; // 最大速度制限
        velocityX = Math.max(-maxVelocity, Math.min(maxVelocity, velocityX));
        velocityY = Math.max(-maxVelocity, Math.min(maxVelocity, velocityY));
        
        // 速度にスムージングを適用
        const velocitySmoothing = 0.4; // スムージング係数
        this.headPoseVelocity.x = this.headPoseVelocity.x * (1 - velocitySmoothing) + velocityX * velocitySmoothing;
        this.headPoseVelocity.y = this.headPoseVelocity.y * (1 - velocitySmoothing) + velocityY * velocitySmoothing;
      } else {
        // 時間差が大きい場合は速度をリセット
        this.headPoseVelocity.x = 0;
        this.headPoseVelocity.y = 0;
      }
      
      // 前回の位置を更新
      this.previousHeadPose = { 
        x: currentHeadPose.x, 
        y: currentHeadPose.y, 
        timestamp: currentTime 
      };
    }
    
    removeNoiseFromGazeData() {
      if (this.gazeRawHistory.length < 3) {
        return this.gazeRawHistory;
      }
      
      const filtered = [];
      
      for (let i = 0; i < this.gazeRawHistory.length; i++) {
        const current = this.gazeRawHistory[i];
        let isNoise = false;
        
        // 前後のデータと比較してノイズを検出
        if (i > 0 && i < this.gazeRawHistory.length - 1) {
          const prev = this.gazeRawHistory[i - 1];
          const next = this.gazeRawHistory[i + 1];
          
          // 前後のデータとの差が閾値を超える場合はノイズと判定
          const diffPrev = Math.sqrt(Math.pow(current.x - prev.x, 2) + Math.pow(current.y - prev.y, 2));
          const diffNext = Math.sqrt(Math.pow(current.x - next.x, 2) + Math.pow(current.y - next.y, 2));
          const diffPrevNext = Math.sqrt(Math.pow(prev.x - next.x, 2) + Math.pow(prev.y - next.y, 2));
          
          // 現在の値が前後から大きく離れている場合はノイズ
          if (diffPrev > this.noiseThreshold && diffNext > this.noiseThreshold && diffPrevNext < this.noiseThreshold) {
            isNoise = true;
          }
        }
        
        // 極端に大きな値もノイズとして除去
        if (Math.abs(current.x) > 100 || Math.abs(current.y) > 100) {
          isNoise = true;
        }
        
        if (!isNoise) {
          filtered.push(current);
        }
      }
      
      return filtered.length > 0 ? filtered : this.gazeRawHistory;
    }
    
    calculateGazeMovementDelta() {
      const currentTime = Date.now();
      const currentGaze = { x: this.gazeX, y: this.gazeY }; // すでにスムージング済み
      
      // 前回の記録からの時間差（秒）
      const deltaTime = (currentTime - this.previousGaze.timestamp) / 1000;
      
      if (deltaTime > 0 && deltaTime < 1.0) { // 1秒以内の変化のみ有効
        // 速度計算（ピクセル/秒）
        let velocityX = (currentGaze.x - this.previousGaze.x) / deltaTime;
        let velocityY = (currentGaze.y - this.previousGaze.y) / deltaTime;
        
        // 速度値の異常チェック（急激な変化を制限）
        const maxVelocity = 200; // 最大速度制限（ピクセル/秒）
        velocityX = Math.max(-maxVelocity, Math.min(maxVelocity, velocityX));
        velocityY = Math.max(-maxVelocity, Math.min(maxVelocity, velocityY));
        
        // 速度にもスムージングを適用（前回の速度との平均）
        const velocitySmoothing = 0.3; // スムージング係数
        this.gazeVelocity.x = this.gazeVelocity.x * (1 - velocitySmoothing) + velocityX * velocitySmoothing;
        this.gazeVelocity.y = this.gazeVelocity.y * (1 - velocitySmoothing) + velocityY * velocitySmoothing;
        
        // 動き履歴を更新（最新5フレーム分）
        this.eyeMovementHistory.push({
          position: { ...currentGaze },
          velocity: { x: velocityX, y: velocityY },
          timestamp: currentTime
        });
        
        // 履歴の長さを制限
        if (this.eyeMovementHistory.length > 5) {
          this.eyeMovementHistory.shift();
        }
      } else {
        // 時間差が大きい場合は速度をリセット
        this.gazeVelocity.x = 0;
        this.gazeVelocity.y = 0;
      }
      
      // 前回の位置を更新
      this.previousGaze = { 
        x: currentGaze.x, 
        y: currentGaze.y, 
        timestamp: currentTime 
      };
    }
    
    updateGazeWithSmoothing(newGazeX, newGazeY) {
      // 視線データを履歴に追加
      this.gazeHistory.push({x: newGazeX, y: newGazeY});
      
      // 最新3フレームのみ保持
      if (this.gazeHistory.length > 3) {
        this.gazeHistory.shift();
      }
      
      // 平均値を計算（平滑化）
      const avgX = this.gazeHistory.reduce((sum, g) => sum + g.x, 0) / this.gazeHistory.length;
      const avgY = this.gazeHistory.reduce((sum, g) => sum + g.y, 0) / this.gazeHistory.length;
      
      // 平滑化された値を設定
      this.gazeX = avgX;
      this.gazeY = avgY;
    }
    
    // 新しい集中度システム: 5秒窓のデータ追加
    addGazeData() {
      const now = Date.now();
      
      // 直近300ms以内に顔が検出されていればtrueとする（30fpsでは約33msごとなので、300msで約9フレーム分）
      const faceDetectedRecently = this.lastFaceDetectedTime && (now - this.lastFaceDetectedTime < 300);
      
      // デバッグ: データ追加をログ出力（10秒に1回）
      if (!this.lastAddGazeLog || now - this.lastAddGazeLog > 10000) {
        console.log(`[addGazeData] データ追加中`, {
          recentDataLength: this.recentGazeData.length,
          faceDetectedRecently: faceDetectedRecently,
          lastFaceDetectedTime: this.lastFaceDetectedTime,
          timeSinceLastFace: this.lastFaceDetectedTime ? now - this.lastFaceDetectedTime : 'never',
          gazeX: this.gazeX.toFixed(1),
          gazeY: this.gazeY.toFixed(1),
          mediaPipeInit: this.mediaPipeInitialized
        });
        this.lastAddGazeLog = now;
      }
      
      // 現在の状態を記録（頭の角度も含める）
      this.recentGazeData.push({
        timestamp: now,
        gazeX: this.gazeX,
        gazeY: this.gazeY,
        headPoseY: this.headPoseY || 0,
        faceDetected: faceDetectedRecently // 直近300msの検出状態を使用
      });
      
      // 5秒より古いデータを削除
      const cutoff = now - (this.concentrationSettings.stabilityWindow * 1000);
      this.recentGazeData = this.recentGazeData.filter(d => d.timestamp > cutoff);
      
      // メモリリーク防止: 配列が異常に大きくなった場合は強制クリア
      if (this.recentGazeData.length > 300) {
        console.warn('⚠️ recentGazeDataが異常に蓄積されました。クリアします。', this.recentGazeData.length);
        this.recentGazeData = this.recentGazeData.slice(-150);
      }
    }
    
    // 新しい集中度システム: 画面正面を見ているかを評価
    determineConcentrationLevel() {
      // データが不足している場合は中立
      if (this.recentGazeData.length === 0) {
        // デバッグ: なぜデータがないかをログ出力（5秒に1回）
        if (!this.lastNoDataLog || Date.now() - this.lastNoDataLog > 5000) {
          console.log(`⚠️ [スコア50固定] recentGazeData.length = 0`, {
            mediaPipeInit: this.mediaPipeInitialized,
            useMediaPipe: this.useMediaPipe,
            lastFaceDetectedTime: this.lastFaceDetectedTime,
            timeSinceLastFace: this.lastFaceDetectedTime ? Date.now() - this.lastFaceDetectedTime : 'never',
            gazeX: this.gazeX,
            gazeY: this.gazeY
          });
          this.lastNoDataLog = Date.now();
        }
        return {
          level: 2,
          label: '計測中',
          score: 50,
          detail: 'データ収集中...'
        };
      }
      
      // 顔検出率を計算
      const faceDetectedCount = this.recentGazeData.filter(d => d.faceDetected).length;
      const faceDetectionRate = faceDetectedCount / this.recentGazeData.length;
      
      // デバッグ: スコアが0になる場合をログ出力（5秒に1回程度）
      if (faceDetectionRate < this.concentrationSettings.faceDetectionMinRate) {
        if (!this.lastZeroScoreLog || Date.now() - this.lastZeroScoreLog > 5000) {
          console.log(`⚠️ [集中度0] 顔検出率低下: ${(faceDetectionRate * 100).toFixed(0)}% (${faceDetectedCount}/${this.recentGazeData.length}) 閾値:${(this.concentrationSettings.faceDetectionMinRate * 100).toFixed(0)}%`);
          this.lastZeroScoreLog = Date.now();
        }
      }
      
      // レベル1: 離席判定（顔検出率が低い）
      if (faceDetectionRate < this.concentrationSettings.faceDetectionMinRate) {
        return {
          level: 1,
          label: '離席',
          score: 0,
          detail: `顔検出率: ${(faceDetectionRate * 100).toFixed(0)}%`
        };
      }
      
      // 視線と頭の角度の平均を計算（顔が検出されているデータのみ）
      const validData = this.recentGazeData.filter(d => d.faceDetected);
      if (validData.length === 0) {
        return {
          level: 1,
          label: '離席',
          score: 0,
          detail: '有効な視線データなし'
        };
      }
      
      const avgGazeX = validData.reduce((sum, d) => sum + d.gazeX, 0) / validData.length;
      const avgGazeY = validData.reduce((sum, d) => sum + d.gazeY, 0) / validData.length;
      
      // 頭の角度の平均も計算（5秒窓から）
      const avgHeadPoseY = validData.reduce((sum, d) => sum + (d.headPoseY || 0), 0) / validData.length;
      
      // 視線の中央からの距離を計算
      const gazeDistance = Math.sqrt(avgGazeX * avgGazeX + avgGazeY * avgGazeY);
      
      // 頭の角度ペナルティ（40～45度の範囲が正常、範囲外で減点）
      let headDownPenalty = 0;
      if (avgHeadPoseY < 40) {
        // 40度未満（上向きすぎ）
        headDownPenalty = 40 - avgHeadPoseY;
      } else if (avgHeadPoseY > 45) {
        // 45度超（下向きすぎ）
        headDownPenalty = avgHeadPoseY - 45;
      }
      
      // スコア計算: 中央からの距離が近いほど高得点
      // gazeDistance: 0 = 100点、50 = 0点（線形）
      let score = Math.max(0, 100 - (gazeDistance * 2));
      
      // 頭が正常範囲外の場合はペナルティ（1度につき10点減点）
      score = Math.max(0, score - (headDownPenalty * 10));
      
      // 顔検出率が低い場合もペナルティ（50%未満で減点）
      if (faceDetectionRate < 0.5) {
        score = score * (faceDetectionRate * 2);
      }
      
      // レベル判定
      let level, label;
      if (score >= 70) {
        level = 3;
        label = '正面視';
      } else if (score >= 30) {
        level = 2;
        label = '視線ズレ';
      } else {
        level = 1;
        label = '画面外';
      }
      
      // 詳細情報
      const direction = this.getGazeDirectionText(avgGazeX, avgGazeY);
      const headAngle = avgHeadPoseY >= 40 && avgHeadPoseY <= 45 ? `${avgHeadPoseY.toFixed(0)}°(正常)` :
                        avgHeadPoseY > 45 ? `${avgHeadPoseY.toFixed(0)}°(下向きすぎ)` :
                        avgHeadPoseY < 40 ? `${avgHeadPoseY.toFixed(0)}°(上向きすぎ)` : '正面';
      
      // 計算詳細を保存
      const baseScore = Math.max(0, 100 - (gazeDistance * 2));
      const headPenalty = headDownPenalty * 10;
      const faceRatePenalty = faceDetectionRate < 0.5 ? baseScore - (baseScore * faceDetectionRate * 2) : 0;
      
      return {
        level: level,
        label: label,
        score: Math.round(score),
        detail: `視線: ${direction} (距離: ${gazeDistance.toFixed(1)}) | 頭: ${headAngle} | 顔検出: ${(faceDetectionRate * 100).toFixed(0)}%`,
        calculation: {
          gazeDistance: gazeDistance,
          baseScore: baseScore,
          headAngle: avgHeadPoseY,
          headPenalty: headPenalty,
          faceRate: faceDetectionRate,
          faceRatePenalty: faceRatePenalty,
          finalScore: score
        }
      };
    }
    
    // 視線方向をテキストで取得
    getGazeDirectionText(gazeX, gazeY) {
      let vertical = '中央';
      let horizontal = '中央';
      
      if (gazeY < -5) vertical = '上';
      else if (gazeY > 5) vertical = '下';
      
      if (gazeX < -5) horizontal = '左';
      else if (gazeX > 5) horizontal = '右';
      
      if (vertical === '中央' && horizontal === '中央') {
        return '中央';
      }
      return `${vertical}/${horizontal}`;
    }
    
    // 新しい集中度システム: 1分窓に状態を追加
    addToStateHistory(state) {
      const now = Date.now();
      
      this.stateHistory.push({
        timestamp: now,
        level: state.level,
        score: state.score,
        label: state.label,
        detail: state.detail
      });
      
      // 61秒以上前のデータを削除
      const cutoff = now - (this.concentrationSettings.windowSize + 1) * 1000;
      this.stateHistory = this.stateHistory.filter(s => s.timestamp > cutoff);
      
      // メモリリーク防止: 配列が異常に大きくなった場合は強制クリア
      if (this.stateHistory.length > 500) {
        console.warn('⚠️ stateHistoryが異常に蓄積されました。クリアします。', this.stateHistory.length);
        this.stateHistory = this.stateHistory.slice(-250);
      }
    }
    
    // 新しい集中度システム: 現在窓のスコアを計算
    calculateWindowScore() {
      if (this.stateHistory.length === 0) return 50;
      
      // 単純平均
      const sum = this.stateHistory.reduce((acc, s) => acc + s.score, 0);
      return sum / this.stateHistory.length;
    }
    
    // 新しい集中度システム: 5秒窓スコアをタイムスタンプに記録
    recordConcentrationTimestamp(state) {
      const changeStr = state.score - this.lastRecordedScore;
      const changeSymbol = changeStr > 0 ? '+' : '';
      
      this.addTimestamp('concentration_5sec', `集中度: ${state.score}点 [${state.label}] (${changeSymbol}${changeStr.toFixed(0)})`, {
        score: state.score,
        level: state.level,
        label: state.label,
        detail: state.detail,
        scoreChange: changeStr,
        previousScore: this.lastRecordedScore,
        calculation: state.calculation
      });
    }
    
    // 新しい集中度システム: 1分窓のスコアを確定
    finalizeWindowScore() {
      const previousScore = this.displayScore;
      
      // 前回の1分間が確定
      this.displayScore = this.currentWindowScore;
      
      // ログに記録
      const levelCounts = {1: 0, 2: 0, 3: 0};
      this.stateHistory.forEach(s => {
        if (levelCounts[s.level] !== undefined) {
          levelCounts[s.level]++;
        }
      });
      
      const total = this.stateHistory.length;
      const breakdown = `集中:${((levelCounts[3]/total)*100).toFixed(0)}% よそ見:${((levelCounts[2]/total)*100).toFixed(0)}% 離席:${((levelCounts[1]/total)*100).toFixed(0)}%`;
      
      this.addLog([], 0, 0); // ログ追加用のダミー
      const logText = `[1分間集中度] ${this.displayScore.toFixed(0)}点 (${breakdown})`;
      this.logs.unshift({
        text: logText,
        detail: `過去1分間の集中度が確定されました`,
        reasons: [],
        type: this.displayScore >= 70 ? 'positive' : this.displayScore >= 40 ? 'neutral' : 'negative',
        timestamp: Date.now(),
        change: 0
      });
      
      this.updateLogDisplay();
      
      // タイムスタンプ記録: 1分ごとの集中度確定
      const scoreChange = this.displayScore - previousScore;
      const changeStr = scoreChange > 0 ? `+${scoreChange.toFixed(1)}` : scoreChange.toFixed(1);
      
      this.addTimestamp('concentration_window', `1分間集中度確定: ${this.displayScore.toFixed(0)}点 (${changeStr}) ${breakdown}`, {
        windowScore: this.displayScore,
        previousWindowScore: previousScore,
        scoreChange: scoreChange,
        levelBreakdown: {
          concentration: levelCounts[3],
          distraction: levelCounts[2],
          absence: levelCounts[1]
        },
        totalSamples: total
      });
      
      // 次の更新時刻を記録
      this.lastWindowUpdate = Date.now();
    }
    
    updateFrontFacingRatio() {
      // 正面向きかどうかの判定
      const isFrontFacing = Math.abs(this.gazeX) < 20 && Math.abs(this.gazeY) < 20;
      this.frontFacingRatio = isFrontFacing ? 
        Math.min(100, this.frontFacingRatio + 2) : 
        Math.max(60, this.frontFacingRatio - 1);
    }
    
    startGazeOverlayUpdates() {
      // 視線オーバーレイの更新を開始（30fps）
      if (this.gazeOverlayInterval) {
        clearInterval(this.gazeOverlayInterval);
      }
      this.gazeOverlayInterval = setInterval(() => {
        this.updateGazeOverlay();
      }, 33); // 約30fps
    }
    
    stopGazeOverlayUpdates() {
      // 視線オーバーレイの更新を停止
      if (this.gazeOverlayInterval) {
        clearInterval(this.gazeOverlayInterval);
        this.gazeOverlayInterval = null;
      }
    }
    
    startTracking() {
      // 既にトラッキングが開始されている場合は重複起動を防ぐ
      if (this.trackingInterval) {
        console.log('[startTracking] 既にトラッキングが開始されています');
        return;
      }
      
      console.log('[startTracking] トラッキングを開始します');
      this.trackingInterval = setInterval(() => {
        this.updateFaceTracking();
        
        // 新しい集中度システム: 5秒窓にデータ追加
        this.addGazeData();
        
        // 新しい集中度システム: 3段階判定
        const state = this.determineConcentrationLevel();
        this.currentState = state; // インジケーター表示用に保存
        
        // 新しい集中度システム: 1分窓に状態追加
        this.addToStateHistory(state);
        
        // 新しい集中度システム: 現在窓のスコア計算
        this.currentWindowScore = this.calculateWindowScore();
        
        // 新しい集中度システム: 5秒窓スコアのタイムスタンプ記録
        const now = Date.now();
        const timeSinceLastRecord = now - this.lastTimestampRecord;
        const scoreChange = Math.abs(state.score - this.lastRecordedScore);
        
        // 5秒経過、またはスコアが大きく変化した場合に記録
        if (timeSinceLastRecord >= this.concentrationSettings.timestampInterval || 
            scoreChange >= this.concentrationSettings.scoreChangeThreshold) {
          this.recordConcentrationTimestamp(state);
          this.lastTimestampRecord = now;
          this.lastRecordedScore = state.score;
        }
        
        // 新しい集中度システム: 1分ごとにスコア確定
        if (now - this.lastWindowUpdate >= this.concentrationSettings.windowUpdateInterval) {
          this.finalizeWindowScore();
        }
        
        this.updateGauge();
        this.updateDebugInfo();
      }, 200); // 200msごとに更新（5秒窓に25サンプル）
    }
    
    updateFaceTracking() {
      // MediaPipeが使用設定されている場合は、初期化完了を待つ
      if (this.useMediaPipe) {
        if (!this.mediaPipeInitialized) {
          // MediaPipe初期化中は何もしない（フォールバック処理も実行しない）
          if (!this.lastMediaPipeWarning || Date.now() - this.lastMediaPipeWarning > 3000) {
            console.log('[updateFaceTracking] MediaPipe初期化中...');
            this.lastMediaPipeWarning = Date.now();
          }
          return;
        }
        // MediaPipe初期化済みの場合は、onFaceMeshResultsで処理されるため何もしない
        return;
      }
      
      // MediaPipeを使用しない場合のみ、フォールバック処理を実行
      if (!this.cameraVideo || !this.canvas) return;
      
      try {
        
        // カメラ映像をcanvasに描画
        this.ctx.drawImage(this.cameraVideo, 0, 0, 640, 480);
        const imageData = this.ctx.getImageData(0, 0, 640, 480);
        
        // 簡易的な顔検出（フォールバック）
        this.faceDetected = this.detectFace(imageData);
        
        if (this.faceDetected) {
          // シミュレーション方式の目線方向計算
          const time = Date.now() / 1000;
          this.gazeX = Math.sin(time * 0.5) * 30 + Math.random() * 10 - 5; // -35 to 35
          this.gazeY = Math.cos(time * 0.3) * 20 + Math.random() * 10 - 5; // -25 to 25
          
          // 動きがあった場合は記録
          if (Math.abs(this.gazeX) > 10 || Math.abs(this.gazeY) > 10) {
            this.lastMovementTime = Date.now();
          }
        }
        
        // 正面向き割合の更新
        this.updateFrontFacingRatio();
        
        // デバッグCanvasに描画
        this.updateGazeOverlay();

      } catch (error) {
        console.error('顔追跡エラー:', error);
      }
    }
    
    updateGazeOverlay() {
      const overlayCanvas = document.getElementById('gaze-overlay-canvas');
      if (!overlayCanvas) return;
      
      const ctx = overlayCanvas.getContext('2d');
      ctx.clearRect(0, 0, 320, 240);
      
      // キャンバスを左右反転（ビデオに合わせる）
      ctx.save();
      ctx.scale(-1, 1);
      ctx.translate(-320, 0);
      
      if (this.faceDetected) {
        // カメラ映像の中心を基準点とする
        const centerX = 160; // 320/2
        const centerY = 120; // 240/2
        
        // 目線方向を正規化ベクトルとして計算
        // gazeX, gazeYの範囲は-50〜50なので、これを正規化
        const magnitude = Math.sqrt(this.gazeX * this.gazeX + this.gazeY * this.gazeY);
        
        if (magnitude > 0) {
          // 正規化ベクトル
          const normalizedX = this.gazeX / magnitude;
          const normalizedY = this.gazeY / magnitude;
          
          // 矢印の長さ（画面サイズに比例）
          const arrowLength = Math.min(magnitude * 2, 80); // 最大80ピクセル
          
          // 矢印の終点
          const endX = centerX + normalizedX * arrowLength;
          const endY = centerY + normalizedY * arrowLength;
          
          // 矢印本体を描画
          ctx.strokeStyle = '#00ff00'; // 明るい緑
          ctx.lineWidth = 4;
          ctx.beginPath();
          ctx.moveTo(centerX, centerY);
          ctx.lineTo(endX, endY);
          ctx.stroke();
          
          // 矢印の先端を描画
          if (arrowLength > 10) {
            const arrowHeadLength = 15;
            const arrowHeadAngle = Math.PI / 6; // 30度
            
            // 矢印の角度
            const angle = Math.atan2(normalizedY, normalizedX);
            
            // 矢印の先端の2つの線
            ctx.beginPath();
            ctx.moveTo(endX, endY);
            ctx.lineTo(
              endX - arrowHeadLength * Math.cos(angle - arrowHeadAngle),
              endY - arrowHeadLength * Math.sin(angle - arrowHeadAngle)
            );
            ctx.moveTo(endX, endY);
            ctx.lineTo(
              endX - arrowHeadLength * Math.cos(angle + arrowHeadAngle),
              endY - arrowHeadLength * Math.sin(angle + arrowHeadAngle)
            );
            ctx.stroke();
          }
          
          // 中心点を表示
          ctx.fillStyle = '#ff0000'; // 赤い中心点
          ctx.beginPath();
          ctx.arc(centerX, centerY, 4, 0, 2 * Math.PI);
          ctx.fill();
          
          // ベクトル情報をテキストで表示（テキストは反転させない）
          ctx.save();
          ctx.scale(-1, 1);
          ctx.translate(-320, 0);
          
          ctx.fillStyle = '#ffffff';
          ctx.font = '12px Arial';
          ctx.strokeStyle = '#000000';
          ctx.lineWidth = 2;
          
          const vectorText = `視線V(${normalizedX.toFixed(2)}, ${normalizedY.toFixed(2)})`;
          const magnitudeText = `|V|=${magnitude.toFixed(1)}`;
          
          // テキストに縁取りを付けて見やすくする
          ctx.strokeText(vectorText, 10, 20);
          ctx.fillText(vectorText, 10, 20);
          ctx.strokeText(magnitudeText, 10, 40);
          ctx.fillText(magnitudeText, 10, 40);
          
          ctx.restore();
        } else {
          // 中心点のみ表示（視線が正面の場合）
          ctx.fillStyle = '#00ff00';
          ctx.beginPath();
          ctx.arc(centerX, centerY, 6, 0, 2 * Math.PI);
          ctx.fill();
          
          // 正面視線のテキスト（テキストは反転させない）
          ctx.save();
          ctx.scale(-1, 1);
          ctx.translate(-320, 0);
          
          ctx.fillStyle = '#ffffff';
          ctx.font = '12px Arial';
          ctx.strokeStyle = '#000000';
          ctx.lineWidth = 2;
          ctx.strokeText('正面視線', 10, 20);
          ctx.fillText('正面視線', 10, 20);
          
          ctx.restore();
        }
        
        // 眼球動きの変化量ベクトルを描画
        this.drawMovementVectors(ctx, centerX, centerY);
        
      } else {
        // 顔未検出時の表示
        ctx.strokeStyle = '#ff0000';
        ctx.lineWidth = 3;
        ctx.font = '16px Arial';
        ctx.fillStyle = '#ffffff';
        
        // X印を描画
        ctx.beginPath();
        ctx.moveTo(140, 100);
        ctx.lineTo(180, 140);
        ctx.moveTo(180, 100);
        ctx.lineTo(140, 140);
        ctx.stroke();
        
        // テキスト表示（テキストは反転させない）
        ctx.save();
        ctx.scale(-1, 1);
        ctx.translate(-320, 0);
        
        ctx.strokeText('顔未検出', 130, 160);
        ctx.fillText('顔未検出', 130, 160);
        
        ctx.restore();
      }
      
      // キャンバス変換を復元
      ctx.restore();
    }
    
    drawMovementVectors(ctx, centerX, centerY) {
      // 視線速度ベクトルの描画（青色）
      const velocityMagnitude = Math.sqrt(this.gazeVelocity.x * this.gazeVelocity.x + this.gazeVelocity.y * this.gazeVelocity.y);
      
      if (velocityMagnitude > 1) { // 閾値以上の速度のみ表示
        const velocityScale = 2; // 速度ベクトルの表示スケール
        const velocityLength = Math.min(velocityMagnitude * velocityScale, 60);
        
        // 正規化された速度ベクトル
        const normalizedVelX = this.gazeVelocity.x / velocityMagnitude;
        const normalizedVelY = this.gazeVelocity.y / velocityMagnitude;
        
        // 速度ベクトルの終点
        const velEndX = centerX + normalizedVelX * velocityLength;
        const velEndY = centerY + normalizedVelY * velocityLength;
        
        // 速度ベクトルを描画（青色）
        ctx.strokeStyle = '#0099ff';
        ctx.lineWidth = 3;
        ctx.setLineDash([5, 3]); // 破線で表示
        ctx.beginPath();
        ctx.moveTo(centerX, centerY);
        ctx.lineTo(velEndX, velEndY);
        ctx.stroke();
        
        // 速度ベクトルの矢印
        if (velocityLength > 15) {
          const arrowHeadLength = 10;
          const arrowHeadAngle = Math.PI / 5;
          const velAngle = Math.atan2(normalizedVelY, normalizedVelX);
          
          ctx.beginPath();
          ctx.moveTo(velEndX, velEndY);
          ctx.lineTo(
            velEndX - arrowHeadLength * Math.cos(velAngle - arrowHeadAngle),
            velEndY - arrowHeadLength * Math.sin(velAngle - arrowHeadAngle)
          );
          ctx.moveTo(velEndX, velEndY);
          ctx.lineTo(
            velEndX - arrowHeadLength * Math.cos(velAngle + arrowHeadAngle),
            velEndY - arrowHeadLength * Math.sin(velAngle + arrowHeadAngle)
          );
          ctx.stroke();
        }
        
        ctx.setLineDash([]); // 破線を解除
      }
      
      // 顔の向きベクトルの描画（オレンジ色）
      const headPoseMagnitude = Math.sqrt(this.headPoseX * this.headPoseX + this.headPoseY * this.headPoseY);
      
      if (headPoseMagnitude > 2) { // 閾値以上の顔の向きのみ表示
        const headPoseScale = 1.5; // 顔の向きベクトルの表示スケール
        const headPoseLength = Math.min(headPoseMagnitude * headPoseScale, 50);
        
        // 正規化された顔の向きベクトル
        const normalizedHeadPoseX = this.headPoseX / headPoseMagnitude;
        const normalizedHeadPoseY = this.headPoseY / headPoseMagnitude;
        
        // 顔の向きベクトルの終点（少しオフセットして表示）
        const offsetX = 25;
        const offsetY = 25;
        const headPoseStartX = centerX + offsetX;
        const headPoseStartY = centerY + offsetY;
        const headPoseEndX = headPoseStartX + normalizedHeadPoseX * headPoseLength;
        const headPoseEndY = headPoseStartY + normalizedHeadPoseY * headPoseLength;
        
        // 顔の向きベクトルを描画（オレンジ色）
        ctx.strokeStyle = '#ff6600';
        ctx.lineWidth = 2;
        ctx.setLineDash([4, 3]); // 点線
        ctx.beginPath();
        ctx.moveTo(headPoseStartX, headPoseStartY);
        ctx.lineTo(headPoseEndX, headPoseEndY);
        ctx.stroke();
        
        // 顔の向きベクトルの矢印
        if (headPoseLength > 10) {
          const arrowHeadLength = 8;
          const arrowHeadAngle = Math.PI / 4;
          const headPoseAngle = Math.atan2(normalizedHeadPoseY, normalizedHeadPoseX);
          
          ctx.beginPath();
          ctx.moveTo(headPoseEndX, headPoseEndY);
          ctx.lineTo(
            headPoseEndX - arrowHeadLength * Math.cos(headPoseAngle - arrowHeadAngle),
            headPoseEndY - arrowHeadLength * Math.sin(headPoseAngle - arrowHeadAngle)
          );
          ctx.moveTo(headPoseEndX, headPoseEndY);
          ctx.lineTo(
            headPoseEndX - arrowHeadLength * Math.cos(headPoseAngle + arrowHeadAngle),
            headPoseEndY - arrowHeadLength * Math.sin(headPoseAngle + arrowHeadAngle)
          );
          ctx.stroke();
        }
        
        ctx.setLineDash([]); // 破線を解除
      }
      
      // 顔の向き速度ベクトルの描画（紫色）
      const headPoseVelocityMagnitude = Math.sqrt(this.headPoseVelocity.x * this.headPoseVelocity.x + this.headPoseVelocity.y * this.headPoseVelocity.y);
      
      if (headPoseVelocityMagnitude > 1) { // 閾値以上の顔の向き速度のみ表示
        const headPoseVelScale = 3; // 顔の向き速度ベクトルの表示スケール
        const headPoseVelLength = Math.min(headPoseVelocityMagnitude * headPoseVelScale, 45);
        
        // 正規化された顔の向き速度ベクトル
        const normalizedHeadPoseVelX = this.headPoseVelocity.x / headPoseVelocityMagnitude;
        const normalizedHeadPoseVelY = this.headPoseVelocity.y / headPoseVelocityMagnitude;
        
        // 顔の向き速度ベクトルの終点（さらにオフセット）
        const velOffsetX = -25;
        const velOffsetY = 25;
        const headPoseVelStartX = centerX + velOffsetX;
        const headPoseVelStartY = centerY + velOffsetY;
        const headPoseVelEndX = headPoseVelStartX + normalizedHeadPoseVelX * headPoseVelLength;
        const headPoseVelEndY = headPoseVelStartY + normalizedHeadPoseVelY * headPoseVelLength;
        
        // 顔の向き速度ベクトルを描画（紫色）
        ctx.strokeStyle = '#9966ff';
        ctx.lineWidth = 2;
        ctx.setLineDash([2, 4]); // 短い破線
        ctx.beginPath();
        ctx.moveTo(headPoseVelStartX, headPoseVelStartY);
        ctx.lineTo(headPoseVelEndX, headPoseVelEndY);
        ctx.stroke();
        
        // 顔の向き速度ベクトルの矢印
        if (headPoseVelLength > 10) {
          const arrowHeadLength = 7;
          const arrowHeadAngle = Math.PI / 5;
          const headPoseVelAngle = Math.atan2(normalizedHeadPoseVelY, normalizedHeadPoseVelX);
          
          ctx.beginPath();
          ctx.moveTo(headPoseVelEndX, headPoseVelEndY);
          ctx.lineTo(
            headPoseVelEndX - arrowHeadLength * Math.cos(headPoseVelAngle - arrowHeadAngle),
            headPoseVelEndY - arrowHeadLength * Math.sin(headPoseVelAngle - arrowHeadAngle)
          );
          ctx.moveTo(headPoseVelEndX, headPoseVelEndY);
          ctx.lineTo(
            headPoseVelEndX - arrowHeadLength * Math.cos(headPoseVelAngle + arrowHeadAngle),
            headPoseVelEndY - arrowHeadLength * Math.sin(headPoseVelAngle + arrowHeadAngle)
          );
          ctx.stroke();
        }
        
        ctx.setLineDash([]); // 破線を解除
      }
      
      // 変化量の数値情報を表示（テキストは反転させない）
      ctx.save();
      ctx.scale(-1, 1);
      ctx.translate(-320, 0);
      
      ctx.fillStyle = '#ffffff';
      ctx.font = '10px Arial';
      ctx.strokeStyle = '#000000';
      ctx.lineWidth = 1;
      
      const gazeVelocityText = `視線速度: (${this.gazeVelocity.x.toFixed(1)}, ${this.gazeVelocity.y.toFixed(1)}) px/s`;
      const gazeVelocityMagText = `|視線速度|=${velocityMagnitude.toFixed(1)}`;
      const headPoseText = `顔向き: (${this.headPoseX.toFixed(1)}, ${this.headPoseY.toFixed(1)})`;
      const headPoseVelocityText = `顔向き速度: (${this.headPoseVelocity.x.toFixed(1)}, ${this.headPoseVelocity.y.toFixed(1)}) deg/s`;
      
      // 右側に情報を表示
      ctx.strokeText(gazeVelocityText, 10, 60);
      ctx.fillText(gazeVelocityText, 10, 60);
      ctx.strokeText(gazeVelocityMagText, 10, 75);
      ctx.fillText(gazeVelocityMagText, 10, 75);
      ctx.strokeText(headPoseText, 10, 90);
      ctx.fillText(headPoseText, 10, 90);
      ctx.strokeText(headPoseVelocityText, 10, 105);
      ctx.fillText(headPoseVelocityText, 10, 105);
      
      // 凡例を表示
      ctx.font = '8px Arial';
      ctx.strokeText('━ 視線方向(緑) ┅ 視線速度(青) ┄ 顔向き(橙) ┈ 顔向き速度(紫)', 10, 220);
      ctx.fillText('━ 視線方向(緑) ┅ 視線速度(青) ┄ 顔向き(橙) ┈ 顔向き速度(紫)', 10, 220);
      
      ctx.restore();
    }
    
    detectFace(imageData) {
      // 簡易的な顔検出（明度ベース）
      // 実際の実装では顔検出ライブラリを使用
      const data = imageData.data;
      let brightness = 0;
      for (let i = 0; i < data.length; i += 4) {
        brightness += (data[i] + data[i + 1] + data[i + 2]) / 3;
      }
      const avgBrightness = brightness / (data.length / 4);
      return avgBrightness > 50; // 明度が50以上なら顔があると判定
    }
    
    // 速い問題確認の判定（問題表示後の視線の動きを検出）
    checkQuickQuestionConfirmation() {
      // デバッグ: MediaPipeが動作していることを確認
      if (this.questionDisplayTime) {
        const timeFromQuestion = (Date.now() - this.questionDisplayTime) / 1000;
        if (timeFromQuestion < this.scoreSettings.questionConfirmWindow && Math.floor(timeFromQuestion * 10) % 10 === 0) {
          console.log(`[MediaPipe動作確認] 経過:${timeFromQuestion.toFixed(2)}秒, questionDisplayTime:${!!this.questionDisplayTime}, responseStartTime:${!!this.responseStartTime}, questionConfirmed:${this.questionConfirmed}`);
        }
      }
      
      if (this.questionDisplayTime && !this.responseStartTime && !this.questionConfirmed) {
        const timeFromQuestion = (Date.now() - this.questionDisplayTime) / 1000;
        
        // デバッグ: 定期的に状態をログ出力（0.1秒ごと）
        if (Math.floor(timeFromQuestion * 10) % 10 === 0) { // 0.1秒ごとにチェック
          console.log(`[速い問題確認チェック] 経過時間:${timeFromQuestion.toFixed(2)}秒, 視線速度X:${Math.abs(this.gazeVelocity.x).toFixed(2)}px/s, 閾値:${this.scoreSettings.gazeVelocityThreshold}px/s, 判定窓:${this.scoreSettings.questionConfirmWindow}秒`);
        }
        
        if (timeFromQuestion < this.scoreSettings.questionConfirmWindow) {
          // 視線速度の絶対値をチェック
          const absVelocityX = Math.abs(this.gazeVelocity.x);
          
          if (absVelocityX > this.scoreSettings.gazeVelocityThreshold) {
            this.questionConfirmed = true; // フラグを立てて一度だけ実行
            
            // タイムスタンプとして記録（スコアには反映しない）
            this.addTimestamp('quick_question_check', '速い問題確認', {
              timeFromQuestion: timeFromQuestion.toFixed(2),
              gazeVelocityX: absVelocityX.toFixed(2),
              gazeVelocityY: Math.abs(this.gazeVelocity.y).toFixed(2),
              threshold: this.scoreSettings.gazeVelocityThreshold,
              videoTime: videoPlayer.currentTime
            });
            
            console.log(`✅ [速い問題確認] 検出成功！ 問題表示後${timeFromQuestion.toFixed(1)}秒で視線速度${absVelocityX.toFixed(1)}px/sを検出しました`);
          }
        }
      }
    }
    
    // 旧システム（削除予定 - 新しい集中度システムを使用）
    calculateConcentrationOld() {
      const oldScore = this.score;
      let newScore = this.score; // 現在のスコアから開始
      const reasons = [];
      
      // 顔が検出されない場合は減点
      if (!this.faceDetected) {
        const penalty = this.scoreSettings.faceNotDetectedPenalty;
        newScore -= penalty;
        reasons.push({ 
          text: '顔未検出', 
          change: -penalty, 
          type: 'negative',
          category: 'カメラ',
          detail: 'カメラに顔が映っていません'
        });
      } else {
        // 正面向きの評価（間隔制御付き加点）
        const currentTime = Date.now();
        if (this.frontFacingRatio > 80 && 
            (currentTime - this.lastFrontFacingBonus) >= this.scoreSettings.frontFacingInterval) {
          const bonus = this.scoreSettings.frontFacingBonus;
          newScore += bonus;
          this.lastFrontFacingBonus = currentTime;
          reasons.push({ 
            text: '正面注視', 
            change: bonus, 
            type: 'positive',
            category: '姿勢',
            detail: `正面を向いています (正面率:${this.frontFacingRatio.toFixed(1)}%)`
          });
        }
        
        // 目線方向による評価（間隔制御付き加点）
        if (Math.abs(this.gazeX) < this.scoreSettings.centerGazeThreshold && 
            Math.abs(this.gazeY) < this.scoreSettings.centerGazeThreshold &&
            (currentTime - this.lastCenterGazeBonus) >= this.scoreSettings.centerGazeInterval) {
          const bonus = this.scoreSettings.centerGazeBonus;
          newScore += bonus;
          this.lastCenterGazeBonus = currentTime;
          reasons.push({ 
            text: '集中注視', 
            change: bonus, 
            type: 'positive',
            category: '目線',
            detail: '画面中央を注視しています'
          });
        }
        // 目線をそらすこと自体は減点対象から除外
        
        // 問題表示後の目線の動き（速い問題確認の検出）
        // デバッグ: MediaPipeが動作していることを確認
        if (this.questionDisplayTime) {
          const timeFromQuestion = (Date.now() - this.questionDisplayTime) / 1000;
          if (timeFromQuestion < this.scoreSettings.questionConfirmWindow && Math.floor(timeFromQuestion * 10) % 10 === 0) {
            console.log(`[MediaPipe動作確認] 経過:${timeFromQuestion.toFixed(2)}秒, questionDisplayTime:${!!this.questionDisplayTime}, responseStartTime:${!!this.responseStartTime}, questionConfirmed:${this.questionConfirmed}`);
          }
        }
        
        if (this.questionDisplayTime && !this.responseStartTime && !this.questionConfirmed) {
          const timeFromQuestion = (Date.now() - this.questionDisplayTime) / 1000;
          
          // デバッグ: 定期的に状態をログ出力（0.1秒ごと）
          if (Math.floor(timeFromQuestion * 10) % 10 === 0) { // 0.1秒ごとにチェック
            console.log(`[速い問題確認チェック] 経過時間:${timeFromQuestion.toFixed(2)}秒, 視線速度X:${Math.abs(this.gazeVelocity.x).toFixed(2)}px/s, 閾値:${this.scoreSettings.gazeVelocityThreshold}px/s, 判定窓:${this.scoreSettings.questionConfirmWindow}秒`);
          }
          
          if (timeFromQuestion < this.scoreSettings.questionConfirmWindow) {
            // 視線速度の絶対値をチェック
            const absVelocityX = Math.abs(this.gazeVelocity.x);
            
            if (absVelocityX > this.scoreSettings.gazeVelocityThreshold) {
              this.questionConfirmed = true; // フラグを立てて一度だけ実行
              
              // タイムスタンプとして記録（スコアには反映しない）
              this.addTimestamp('quick_question_check', '速い問題確認', {
                timeFromQuestion: timeFromQuestion,
                gazeVelocityX: absVelocityX.toFixed(1),
                threshold: this.scoreSettings.gazeVelocityThreshold
              });
              
              console.log(`✅ [速い問題確認] 検出成功！ 問題表示後${timeFromQuestion.toFixed(1)}秒で視線速度${absVelocityX.toFixed(1)}px/sを検出しました`);
            }
          }
        }
        
        // 一定時間動きがない場合は減点
        const timeSinceMovement = (Date.now() - this.lastMovementTime) / 1000;
        if (timeSinceMovement > this.scoreSettings.movementStopThreshold) {
          const penalty = Math.min(20, (timeSinceMovement - this.scoreSettings.movementStopThreshold) * this.scoreSettings.movementStopPenalty);
          newScore -= penalty;
          reasons.push({ 
            text: `目線停止`, 
            change: -penalty, 
            type: 'negative',
            category: '目線',
            detail: `${timeSinceMovement.toFixed(1)}秒間目線の動きがありません`
          });
        }
        
        // 出題から回答までの時間を記録（スコアには反映しない）
        // ※通常は onResponseStarted() で即座に記録されるため、ここには到達しない
        if (this.questionDisplayTime && this.responseStartTime && !this.responseProcessed) {
          const responseTime = (this.responseStartTime - this.questionDisplayTime) / 1000;
          console.log(`[反応速度イベント] startTracking内で記録 - 回答時間: ${responseTime.toFixed(2)}秒`);
          console.log(`[反応速度イベント] 遅延判定閾値: ${this.scoreSettings.responseDelayThreshold}秒`);
          console.log(`[反応速度イベント] 素早い判定閾値: ${this.scoreSettings.quickResponseThreshold}秒`);
          
          if (responseTime > this.scoreSettings.responseDelayThreshold) {
            // タイムスタンプとしてのみ記録（スコアに反映しない）
            console.log(`[反応速度イベント] 回答遅延を記録: ${responseTime.toFixed(2)}秒`);
            this.addTimestamp('response_slow', '回答遅延', {
              responseTime: responseTime,
              threshold: this.scoreSettings.responseDelayThreshold,
              delay: responseTime - this.scoreSettings.responseDelayThreshold
            });
          } else if (responseTime < this.scoreSettings.quickResponseThreshold) {
            // タイムスタンプとしてのみ記録（スコアに反映しない）
            console.log(`[反応速度イベント] 素早い回答を記録: ${responseTime.toFixed(2)}秒`);
            this.addTimestamp('response_quick', '素早い回答', {
              responseTime: responseTime,
              threshold: this.scoreSettings.quickResponseThreshold
            });
          } else {
            // 通常範囲の回答速度も記録
            console.log(`[反応速度イベント] 通常の回答速度を記録: ${responseTime.toFixed(2)}秒`);
            this.addTimestamp('response_normal', '回答速度普通', {
              responseTime: responseTime,
              quickThreshold: this.scoreSettings.quickResponseThreshold,
              delayThreshold: this.scoreSettings.responseDelayThreshold
            });
          }
          // 一度処理したらフラグを立てる
          this.responseProcessed = true;
        }
        
      }
      
      // メモ入力があった場合は加点（前回チェック時からの増分のみ）
      if (this.noteInputs > this.lastNoteCount) {
        const newNotes = this.noteInputs - this.lastNoteCount;
        const noteBonus = newNotes * this.scoreSettings.noteInputBonus;
        newScore += noteBonus;
        reasons.push({ 
          text: `メモ入力`, 
          change: noteBonus, 
          type: 'positive',
          category: 'メモ',
          detail: `${newNotes}回のメモ入力がありました`
        });
        this.lastNoteCount = this.noteInputs;
      }
      
      // スコアを0-100の範囲に制限
      this.score = Math.max(0, Math.min(100, newScore));
      
      // ログに記録（スコアが変化した場合、または理由がある場合）
      if (Math.abs(this.score - oldScore) > 0.1 || reasons.length > 0) {
        this.addLog(reasons, oldScore, this.score);
        
        // タイムスタンプ記録（スコアが変化した場合のみ）
        if (Math.abs(this.score - oldScore) > 0.1) {
          const change = this.score - oldScore;
          const changeStr = change > 0 ? `+${change.toFixed(1)}` : change.toFixed(1);
          const reasonTexts = reasons.map(r => r.text).join(', ');
          
          this.addTimestamp('score_change', `集中度変化: ${changeStr}点 (${reasonTexts})`, {
            scoreChange: change,
            previousScore: oldScore,
            newScore: this.score,
            reasons: reasons
          });
        }
      }
    }
    
    addLog(reasons, oldScore, newScore) {
      // logs配列が未初期化の場合は初期化
      if (!this.logs) {
        this.logs = [];
      }
      
      const timestamp = new Date().toLocaleTimeString();
      const change = newScore - oldScore;
      
      // メインのログテキスト
      let logText = `[${timestamp}] ${oldScore.toFixed(0)} → ${newScore.toFixed(0)} (${change > 0 ? '+' : ''}${change.toFixed(0)})`;
      
      // 詳細な原因情報
      let detailText = '';
      if (reasons.length > 0) {
        const categoryGroups = {};
        reasons.forEach(r => {
          if (!categoryGroups[r.category]) {
            categoryGroups[r.category] = [];
          }
          categoryGroups[r.category].push(r);
        });
        
        const categoryTexts = Object.keys(categoryGroups).map(category => {
          const items = categoryGroups[category];
          const categoryChange = items.reduce((sum, item) => sum + item.change, 0);
          const itemTexts = items.map(item => 
            `${item.text}(${item.change > 0 ? '+' : ''}${item.change.toFixed(0)})`
          ).join(', ');
          
          return `【${category}】${itemTexts}`;
        });
        
        logText += ': ' + categoryTexts.join(' | ');
        
        // 詳細情報を別途作成
        detailText = reasons.map(r => `• ${r.detail}`).join('\n');
      }
      
      this.logs.unshift({
        text: logText,
        detail: detailText,
        reasons: reasons,
        type: this.determineLogType(change, reasons),
        timestamp: Date.now(),
        change: change
      });
      
      // ログは最新20件まで保持
      if (this.logs.length > 20) {
        this.logs = this.logs.slice(0, 20);
      }
      
      this.updateLogDisplay();
    }
    
    determineLogType(change, reasons) {
      // スコア変化量で基本的な判定
      if (change > 0) {
        return 'positive';
      } else if (change < 0) {
        return 'negative';
      } else {
        // 変化量が0の場合、理由の内容で判定
        if (reasons.length > 0) {
          const positiveReasons = reasons.filter(r => r.type === 'positive');
          const negativeReasons = reasons.filter(r => r.type === 'negative');
          
          if (positiveReasons.length > 0 && negativeReasons.length === 0) {
            return 'positive'; // プラス要因のみ（スコア上限による制限）
          } else if (negativeReasons.length > 0 && positiveReasons.length === 0) {
            return 'negative'; // マイナス要因のみ
          }
        }
        return 'neutral';
      }
    }
    
    updateLogDisplay() {
      if (!this.logElement) return;
      
      this.logElement.innerHTML = this.logs.map((log, index) => {
        const expandId = `log-expand-${index}`;
        return `
          <div class="log-entry ${log.type}" onclick="this.querySelector('.log-detail').style.display = this.querySelector('.log-detail').style.display === 'none' ? 'block' : 'none';">
            <div class="log-main">${log.text}</div>
            ${log.detail ? `<div class="log-detail" style="display: none;">${log.detail}</div>` : ''}
          </div>
        `;
      }).join('');
    }
    
    showDebugTab(tabName, clickedButton) {
      console.log('showDebugTab called with:', tabName);
      
      // すべてのタブを非表示
      document.querySelectorAll('.debug-tab-content').forEach(tab => {
        tab.style.display = 'none';
      });
      
      // すべてのタブボタンをinactiveに
      document.querySelectorAll('.debug-tab-btn').forEach(btn => {
        btn.classList.remove('active');
      });
      
      // 選択されたタブを表示
      const targetTab = document.getElementById(`debug-tab-${tabName}`);
      if (targetTab) {
        targetTab.style.display = 'block';
        console.log(`Showing tab: debug-tab-${tabName}`);
      } else {
        console.log(`Tab not found: debug-tab-${tabName}`);
      }
      
      // クリックされたボタンをactiveに
      if (clickedButton && clickedButton.classList) {
        clickedButton.classList.add('active');
      }
      
      // タイムスタンプタブが選択された場合は強制的に更新
      if (tabName === 'timestamp') {
        console.log('Timestamp tab selected, forcing update');
        this.updateTimestampDisplay();
      }
    }
    
    updateGauge() {
      // すべてのレベルをリセット
      Object.values(this.gaugeElements).forEach(element => {
        if (element && element.classList) {
          element.classList.remove('active');
        }
      });
      
      // 5秒窓の現在スコアを表示（リアルタイム）
      const currentScore = this.currentState ? this.currentState.score : this.displayScore;
      
      if (currentScore >= 75) {
        this.gaugeElements.green?.classList.add('active');
      } else if (currentScore >= 50) {
        this.gaugeElements.yellow?.classList.add('active');
      } else if (currentScore >= 25) {
        this.gaugeElements.orange?.classList.add('active');
      } else {
        this.gaugeElements.red?.classList.add('active');
      }
      
      if (this.gaugeElements.score) {
        this.gaugeElements.score.textContent = Math.round(currentScore) + '%';
      }
    }
    
    updateDebugInfo() {
      // debugElementsが初期化されていない場合は何もしない
      if (!this.debugElements) {
        return;
      }
      
      // 検出方式の表示
      if (this.debugElements.detectionMethod) {
        const method = this.useMediaPipe && this.mediaPipeInitialized ? 'MediaPipe (実際の眼球追跡)' : 'フォールバック (顔の向き)';
        this.debugElements.detectionMethod.textContent = method;
      }
      
      if (this.debugElements.faceDetected) {
        const detectionMethod = this.useMediaPipe && this.mediaPipeInitialized ? 'MediaPipe' : 'フォールバック';
        this.debugElements.faceDetected.textContent = this.faceDetected ? `検出 (${detectionMethod})` : `未検出 (${detectionMethod})`;
      }
      
      // 目線方向を分かりやすく表示
      if (this.debugElements.gazeX) {
        const horizontalDirection = this.gazeX > 5 ? '右' : 
                                   this.gazeX < -5 ? '左' : '中央';
        this.debugElements.gazeX.textContent = `${this.gazeX.toFixed(1)} (${horizontalDirection})`;
      }
      if (this.debugElements.gazeY) {
        const verticalDirection = this.gazeY > 5 ? '下' : 
                                 this.gazeY < -5 ? '上' : '中央';
        this.debugElements.gazeY.textContent = `${this.gazeY.toFixed(1)} (${verticalDirection})`;
      }
      
      // 総合的な目線方向を表示
      if (this.debugElements.gazeDirection) {
        let direction = '';
        
        // 垂直方向を先に判定
        if (this.gazeY < -5) direction += '上';
        else if (this.gazeY > 5) direction += '下';
        
        // 水平方向を後に判定
        if (this.gazeX < -5) direction += '左';
        else if (this.gazeX > 5) direction += '右';
        
        // 正面の場合
        if (!direction) direction = '正面';
        
        this.debugElements.gazeDirection.textContent = direction;
      }
      
      // 眼球データの詳細表示（MediaPipe使用時のみ）
      if (this.eyeballData && this.debugElements.eyeballDetails) {
        const data = this.eyeballData;
        let details = '';
        
        if (data.left.isValid && data.right.isValid) {
          details += `左目瞳孔: (${(data.left.pupilRatio.x * 100).toFixed(1)}%, ${(data.left.pupilRatio.y * 100).toFixed(1)}%)\n`;
          details += `右目瞳孔: (${(data.right.pupilRatio.x * 100).toFixed(1)}%, ${(data.right.pupilRatio.y * 100).toFixed(1)}%)\n`;
          details += `平均瞳孔: (${(data.avgPupilRatio.x * 100).toFixed(1)}%, ${(data.avgPupilRatio.y * 100).toFixed(1)}%)\n`;
          details += `生視線値: (${data.rawGaze.x.toFixed(3)}, ${data.rawGaze.y.toFixed(3)})\n`;
          details += `信頼度: L=${(data.left.confidence * 100).toFixed(0)}% R=${(data.right.confidence * 100).toFixed(0)}%\n\n`;
          
          // スムージング情報を追加
          details += `【スムージング処理】\n`;
          details += `スムージング後: (${this.gazeSmoothed.x.toFixed(1)}, ${this.gazeSmoothed.y.toFixed(1)})\n`;
          details += `生データ履歴: ${this.gazeRawHistory.length}/${this.smoothingWindowSize}フレーム\n`;
          const filteredCount = this.removeNoiseFromGazeData().length;
          details += `ノイズ除去後: ${filteredCount}フレーム\n`;
          details += `ノイズ除去率: ${this.gazeRawHistory.length > 0 ? ((this.gazeRawHistory.length - filteredCount) / this.gazeRawHistory.length * 100).toFixed(1) : 0}%\n\n`;
          
          // 変化量情報を追加
          details += `【視線の動き】\n`;
          details += `視線速度: (${this.gazeVelocity.x.toFixed(1)}, ${this.gazeVelocity.y.toFixed(1)}) px/s\n`;
          details += `視線速度大きさ: ${Math.sqrt(this.gazeVelocity.x * this.gazeVelocity.x + this.gazeVelocity.y * this.gazeVelocity.y).toFixed(1)} px/s\n`;
          details += `動き履歴: ${this.eyeMovementHistory.length}/5フレーム\n\n`;
          
          // 顔の向き情報を追加
          details += `【顔の向き】\n`;
          details += `顔向き: (${this.headPoseX.toFixed(1)}, ${this.headPoseY.toFixed(1)})\n`;
          details += `顔向き速度: (${this.headPoseVelocity.x.toFixed(1)}, ${this.headPoseVelocity.y.toFixed(1)}) deg/s\n`;
          details += `顔向き大きさ: ${Math.sqrt(this.headPoseX * this.headPoseX + this.headPoseY * this.headPoseY).toFixed(1)}`;
        } else {
          details = '眼球データ取得失敗 - フォールバックモード\n';
          details += `スムージング後: (${this.gazeSmoothed.x.toFixed(1)}, ${this.gazeSmoothed.y.toFixed(1)})\n`;
          details += `視線速度: (${this.gazeVelocity.x.toFixed(1)}, ${this.gazeVelocity.y.toFixed(1)}) px/s\n`;
          details += `顔向き: (${this.headPoseX.toFixed(1)}, ${this.headPoseY.toFixed(1)})`;
        }
        
        this.debugElements.eyeballDetails.textContent = details;
      }
      
      // 新しい集中度システムの表示
      if (this.debugElements.frontFacing) {
        const state = this.stateHistory.length > 0 ? this.stateHistory[this.stateHistory.length - 1] : null;
        if (state) {
          const displayText = `${this.displayScore.toFixed(0)}点 [${state.label}] (現在窓: ${this.currentWindowScore.toFixed(0)}点)`;
          this.debugElements.frontFacing.textContent = displayText;
          
          // デバッグログに詳細情報を表示
          if (this.debugElements.concentrationDetail) {
            const windowSize = this.stateHistory.length;
            const faceDetectedCount = this.recentGazeData.filter(d => d.faceDetected).length;
            const faceRate = this.recentGazeData.length > 0 ? (faceDetectedCount / this.recentGazeData.length * 100).toFixed(0) : 0;
            
            // 現在の視線と頭の角度
            const validData = this.recentGazeData.filter(d => d.faceDetected);
            const avgGazeX = validData.length > 0 ? validData.reduce((sum, d) => sum + d.gazeX, 0) / validData.length : 0;
            const avgGazeY = validData.length > 0 ? validData.reduce((sum, d) => sum + d.gazeY, 0) / validData.length : 0;
            const avgHeadY = validData.length > 0 ? validData.reduce((sum, d) => sum + (d.headPoseY || 0), 0) / validData.length : 0;
            const gazeDistance = Math.sqrt(avgGazeX * avgGazeX + avgGazeY * avgGazeY);
            
            let detailText = `【画面正面視判定システム】\n`;
            detailText += `表示スコア: ${this.displayScore.toFixed(0)}点 (前回1分間の確定値)\n`;
            detailText += `現在窓スコア: ${this.currentWindowScore.toFixed(0)}点 (計測中)\n`;
            detailText += `現在の状態: ${state.label} (${state.detail})\n`;
            detailText += `\n`;
            
            // 計算式の表示状態を管理
            if (!this.showCalculationDetail) {
              detailText += `📊 [クリックで計算式を表示]\n\n`;
            } else {
              detailText += `📊 [クリックで計算式を非表示]\n`;
              // スコア計算詳細を表示
              if (state.calculation) {
                const calc = state.calculation;
                detailText += `\n【スコア計算式】\n`;
                detailText += `基本スコア = 100 - (視線距離 × 2)\n`;
                detailText += `          = 100 - (${calc.gazeDistance.toFixed(1)} × 2)\n`;
                detailText += `          = ${calc.baseScore.toFixed(1)}点\n\n`;
                detailText += `頭角度ペナルティ = 角度が40°～45°の範囲外で減点\n`;
                detailText += `                = 角度 < 40° ? (40 - 角度) × 10\n`;
                detailText += `                = 角度 > 45° ? (角度 - 45) × 10\n`;
                detailText += `                = ${calc.headAngle.toFixed(1)}° → ${calc.headPenalty.toFixed(1)}点\n\n`;
                detailText += `顔検出ペナルティ = 顔検出率 < 50% ? スコア × (率 × 2) : 0\n`;
                detailText += `                = ${(calc.faceRate * 100).toFixed(0)}% ${calc.faceRate < 0.5 ? '<' : '>='} 50%\n`;
                detailText += `                = ${calc.faceRatePenalty.toFixed(1)}点\n\n`;
                detailText += `最終スコア = ${calc.baseScore.toFixed(1)} - ${calc.headPenalty.toFixed(1)} - ${calc.faceRatePenalty.toFixed(1)}\n`;
                detailText += `          = ${calc.finalScore.toFixed(1)}点\n\n`;
              }
            }
            
            // スコア要因の詳細分析
            let headStatus = '';
            let headPenaltyAmount = 0;
            if (avgHeadY < 40) {
              headPenaltyAmount = (40 - avgHeadY) * 10;
              headStatus = `上向きすぎ (-${headPenaltyAmount.toFixed(0)}点)`;
            } else if (avgHeadY > 45) {
              headPenaltyAmount = (avgHeadY - 45) * 10;
              headStatus = `下向きすぎ (-${headPenaltyAmount.toFixed(0)}点)`;
            } else {
              headStatus = `正常範囲 (0点)`;
            }
            
            const gazeScore = Math.max(0, 100 - (gazeDistance * 2));
            let faceStatus = '';
            if (faceRate < 50) {
              faceStatus = `低い (-${(gazeScore * (1 - faceRate / 50)).toFixed(0)}点)`;
            } else {
              faceStatus = `良好 (0点)`;
            }
            
            detailText += `【スコア要因の詳細】\n`;
            detailText += `┌─ 視線位置 (基本スコア)\n`;
            detailText += `│  中央距離: ${gazeDistance.toFixed(1)} → ${gazeScore.toFixed(0)}点\n`;
            detailText += `│  状態: ${gazeDistance < 5 ? '✓ 中央' : gazeDistance < 15 ? '△ やや外れ' : '✗ 大きく外れ'}\n`;
            detailText += `│\n`;
            detailText += `┌─ 頭の角度 (ペナルティ)\n`;
            detailText += `│  現在角度: ${avgHeadY.toFixed(1)}°\n`;
            detailText += `│  正常範囲: 40° ～ 45°\n`;
            detailText += `│  状態: ${headStatus}\n`;
            detailText += `│\n`;
            detailText += `└─ 顔検出率 (ペナルティ)\n`;
            detailText += `   検出率: ${faceRate}% (5秒平均)\n`;
            detailText += `   基準: 50%以上が必要\n`;
            detailText += `   状態: ${faceStatus}\n\n`;
            detailText += `【データ統計】\n`;
            detailText += `5秒窓データ: ${this.recentGazeData.length}件\n`;
            detailText += `1分窓データ: ${windowSize}件\n`;
            detailText += `次回確定まで: ${((this.concentrationSettings.windowUpdateInterval - (Date.now() - this.lastWindowUpdate)) / 1000).toFixed(0)}秒`;
            
            this.debugElements.concentrationDetail.textContent = detailText;
          }
        } else {
          this.debugElements.frontFacing.textContent = this.frontFacingRatio.toFixed(1);
        }
      }
      if (this.debugElements.lastMovement) {
        const timeSince = (Date.now() - this.lastMovementTime) / 1000;
        this.debugElements.lastMovement.textContent = timeSince.toFixed(1);
      }
      if (this.debugElements.noteInputs) {
        this.debugElements.noteInputs.textContent = this.noteInputs;
      }
    }
    
    onQuestionDisplayed() {
      this.questionDisplayTime = Date.now();
      this.responseStartTime = null;
      this.responseProcessed = false; // 新しい問題でフラグをリセット
      this.questionConfirmed = false; // 問題確認フラグもリセット
      
      console.log(`🎯 [問題表示] 問題が表示されました。速い問題確認の判定を開始します（時間窓: ${this.scoreSettings.questionConfirmWindow}秒）`);
      console.log(`   視線速度閾値: ${this.scoreSettings.gazeVelocityThreshold}px/s`);
      console.log(`   現在の視線速度X: ${this.gazeVelocity.x.toFixed(2)}px/s`);
      
      // タイムスタンプ記録
      this.addTimestamp('question_display', '問題表示', {
        questionDisplayed: true
      });
      
      // 問題表示をログに記録
      if (!this.logs) {
        this.logs = [];
      }
      const timestamp = new Date().toLocaleTimeString();
      this.logs.unshift({
        text: `[${timestamp}] 問題表示`,
        detail: '新しい問題が表示されました。目線の動きと反応時間の計測を開始します。',
        reasons: [{
          text: '問題表示',
          change: 0,
          type: 'neutral',
          category: 'イベント',
          detail: '新しい問題が表示されました。目線の動きと反応時間の計測を開始します。'
        }],
        type: 'neutral',
        timestamp: Date.now(),
        change: 0
      });
      
      // ログは最新20件まで保持
      if (this.logs.length > 20) {
        this.logs = this.logs.slice(0, 20);
      }
      
      this.updateLogDisplay();
    }
    
    onResponseStarted() {
      this.responseStartTime = Date.now();
      
      // タイムスタンプ記録
      const responseTime = this.questionDisplayTime ? 
        (this.responseStartTime - this.questionDisplayTime) / 1000 : 0;
      this.addTimestamp('answer_start', '回答開始', {
        responseTime: responseTime
      });
      
      // 反応速度イベントを即座に記録
      if (this.questionDisplayTime && this.responseStartTime && !this.responseProcessed) {
        console.log(`[反応速度イベント] 回答開始時に記録 - 回答時間: ${responseTime.toFixed(2)}秒`);
        console.log(`[反応速度イベント] 遅延判定閾値: ${this.scoreSettings.responseDelayThreshold}秒`);
        console.log(`[反応速度イベント] 素早い判定閾値: ${this.scoreSettings.quickResponseThreshold}秒`);
        
        if (responseTime > this.scoreSettings.responseDelayThreshold) {
          console.log(`[反応速度イベント] 回答遅延を記録: ${responseTime.toFixed(2)}秒`);
          this.addTimestamp('response_slow', '回答遅延', {
            responseTime: responseTime,
            threshold: this.scoreSettings.responseDelayThreshold,
            delay: responseTime - this.scoreSettings.responseDelayThreshold
          });
        } else if (responseTime < this.scoreSettings.quickResponseThreshold) {
          console.log(`[反応速度イベント] 素早い回答を記録: ${responseTime.toFixed(2)}秒`);
          this.addTimestamp('response_quick', '素早い回答', {
            responseTime: responseTime,
            threshold: this.scoreSettings.quickResponseThreshold
          });
        } else {
          console.log(`[反応速度イベント] 通常の回答速度を記録: ${responseTime.toFixed(2)}秒`);
          this.addTimestamp('response_normal', '回答速度普通', {
            responseTime: responseTime,
            quickThreshold: this.scoreSettings.quickResponseThreshold,
            delayThreshold: this.scoreSettings.responseDelayThreshold
          });
        }
        this.responseProcessed = true;
      }
      
      // 回答開始をログに記録
      const timestamp = new Date().toLocaleTimeString();
      const responseTimeStr = this.questionDisplayTime ? 
        ((Date.now() - this.questionDisplayTime) / 1000).toFixed(1) : '不明';
      
      this.logs.unshift({
        text: `[${timestamp}] 回答開始 (${responseTimeStr}s後)`,
        detail: `問題表示から${responseTimeStr}秒後に回答を開始しました。`,
        reasons: [{
          text: '回答開始',
          change: 0,
          type: 'neutral',
          category: 'イベント',
          detail: `問題表示から${responseTimeStr}秒後に回答を開始しました。`
        }],
        type: 'neutral',
        timestamp: Date.now(),
        change: 0
      });
      
      // ログは最新20件まで保持
      if (this.logs.length > 20) {
        this.logs = this.logs.slice(0, 20);
      }
      
      this.updateLogDisplay();
    }
    
    onNoteInput() {
      this.noteInputs++;
      
      // タイムスタンプ記録
      this.addTimestamp('interaction_note', `メモ入力（${this.noteInputs}回目）`, {
        noteCount: this.noteInputs
      });
      
      // メモ入力を即座にログに記録
      const timestamp = new Date().toLocaleTimeString();
      const bonus = 2; // メモ1回につき2点
      
      this.logs.unshift({
        text: `[${timestamp}] メモ入力 (+${bonus})`,
        detail: `メモエリアに入力があり、学習意欲が評価されました（累計: ${this.noteInputs}回）`,
        reasons: [{
          text: 'メモ入力',
          change: bonus,
          type: 'positive',
          category: 'メモ',
          detail: `メモエリアに入力があり、学習意欲が評価されました（累計: ${this.noteInputs}回）`
        }],
        type: 'positive',
        timestamp: Date.now(),
        change: bonus
      });
      
      // ログは最新20件まで保持
      if (this.logs.length > 20) {
        this.logs = this.logs.slice(0, 20);
      }
      
      this.updateLogDisplay();
    }
    
    // タイムスタンプ記録システム
    addTimestamp(eventType, description, additionalData = {}) {
      const currentTime = Date.now();
      const sessionElapsed = (currentTime - this.sessionStartTime) / 1000; // 秒
      
      // videoElementが未設定の場合は再取得を試みる
      if (!this.videoElement) {
        this.videoElement = document.getElementById('video-player');
        console.log('videoElement再取得:', this.videoElement ? 'Success' : 'Failed');
      }
      
      const videoTime = this.videoElement ? this.videoElement.currentTime : 0;
      
      // デバッグログ：特にメモ入力時のvideo_timeを確認
      if (eventType.includes('note') || eventType.includes('interaction')) {
        console.log(`[${eventType}] videoElement:`, this.videoElement);
        console.log(`[${eventType}] videoTime:`, videoTime);
        console.log(`[${eventType}] currentTime from element:`, this.videoElement?.currentTime);
      }
      
      const timestampEntry = {
        id: this.timestampLog.length + 1,
        timestamp: currentTime,
        sessionElapsed: sessionElapsed,
        videoTime: videoTime,
        eventType: eventType,
        description: description,
        videoState: this.videoState,
        playbackRate: this.videoElement ? this.videoElement.playbackRate : 1.0,
        ...additionalData,
        // concentrationScoreはadditionalDataで渡されていなければデフォルト値を使用
        concentrationScore: additionalData.score !== undefined ? additionalData.score : (additionalData.concentrationScore !== undefined ? additionalData.concentrationScore : this.displayScore)
      };
      
      this.timestampLog.push(timestampEntry);
      
      // デバッグログを追加
      console.log(`[タイムスタンプ追加] ${eventType}: ${description}`, {
        totalEvents: this.timestampLog.length,
        sessionElapsed: sessionElapsed.toFixed(1) + 's',
        entry: timestampEntry
      });
      
      // ログを最新1000件まで保持
      if (this.timestampLog.length > 1000) {
        this.timestampLog = this.timestampLog.slice(-1000);
      }
      
      // リアルタイム表示を更新
      this.updateTimestampDisplay();
      
      console.log(`[タイムスタンプ] ${eventType}: ${description}`, timestampEntry);
    }
    
    formatTime(seconds) {
      const minutes = Math.floor(seconds / 60);
      const secs = Math.floor(seconds % 60);
      return `${minutes}:${secs.toString().padStart(2, '0')}`;
    }
    
    updateTimestampDisplay() {
      const timestampElement = document.getElementById('timestamp-log');
      
      // デバッグ情報を追加
      console.log('updateTimestampDisplay called:', {
        timestampElement: !!timestampElement,
        timestampLogLength: this.timestampLog.length,
        recentEvents: this.timestampLog.slice(-3)
      });
      
      if (!timestampElement) {
        console.warn('timestamp-log element not found');
        return;
      }
      
      if (this.timestampLog.length === 0) {
        timestampElement.innerHTML = `
          <div class="timestamp-entry">
            <div class="timestamp-header">
              <span class="timestamp-time">タイムスタンプデータなし</span>
            </div>
            <div class="timestamp-body">
              <div class="timestamp-description">まだイベントが記録されていません。動画を操作するとタイムスタンプが記録されます。</div>
            </div>
          </div>
        `;
        return;
      }
      
      // 最新10件を表示
      const recentLogs = this.timestampLog.slice(-10).reverse();
      
      timestampElement.innerHTML = recentLogs.map(entry => {
        const timeStr = new Date(entry.timestamp).toLocaleTimeString();
        const sessionStr = this.formatTime(entry.sessionElapsed);
        const videoStr = this.formatTime(entry.videoTime);
        
        let className = 'timestamp-entry';
        if (entry.eventType.includes('score')) className += ' score-event';
        else if (entry.eventType.includes('video')) className += ' video-event';
        else if (entry.eventType.includes('interaction')) className += ' interaction-event';
        
        // 詳細情報の構築
        let detailsHtml = '';
        if (entry.details && Object.keys(entry.details).length > 0) {
          // quick_question_checkの場合は視線速度を強調表示
          if (entry.eventType === 'quick_question_check') {
            detailsHtml = `
              <div class="timestamp-details">
                <div class="detail-item highlight">
                  <span class="detail-label">視線速度X:</span>
                  <span class="detail-value">${entry.details.gazeVelocityX} px/s</span>
                </div>
                <div class="detail-item">
                  <span class="detail-label">視線速度Y:</span>
                  <span class="detail-value">${entry.details.gazeVelocityY} px/s</span>
                </div>
                <div class="detail-item">
                  <span class="detail-label">閾値:</span>
                  <span class="detail-value">${entry.details.threshold} px/s</span>
                </div>
                <div class="detail-item">
                  <span class="detail-label">問題表示から:</span>
                  <span class="detail-value">${entry.details.timeFromQuestion} 秒</span>
                </div>
              </div>
            `;
          } else {
            // その他のイベントの詳細情報
            const detailItems = Object.entries(entry.details)
              .map(([key, value]) => `
                <div class="detail-item">
                  <span class="detail-label">${key}:</span>
                  <span class="detail-value">${value}</span>
                </div>
              `).join('');
            if (detailItems) {
              detailsHtml = `<div class="timestamp-details">${detailItems}</div>`;
            }
          }
        }
        
        return `
          <div class="${className}">
            <div class="timestamp-header">
              <span class="timestamp-time">${timeStr}</span>
              <span class="timestamp-type">${entry.eventType}</span>
              <span class="concentration-score">スコア: ${entry.concentrationScore.toFixed(0)}</span>
            </div>
            <div class="timestamp-body">
              <div class="timestamp-description">${entry.description}</div>
              <div class="timestamp-times">
                <span>経過: ${sessionStr}</span>
                <span>動画: ${videoStr}</span>
                ${entry.playbackRate !== 1.0 ? `<span>速度: ${entry.playbackRate}x</span>` : ''}
              </div>
              ${detailsHtml}
            </div>
          </div>
        `;
      }).join('');
    }
    
    exportTimestampLog() {
      const data = this.prepareSessionData();
      
      const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `learning-session-${new Date().toISOString().slice(0, 19).replace(/:/g, '-')}.json`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    }
    
    prepareSessionData() {
      // 正しい動画IDの取得
      const pathParts = window.location.pathname.split('/');
      const videoId = pathParts[pathParts.length - 2]; // '/videos/{id}/player' から {id} を取得
      
      return {
        sessionInfo: {
          startTime: this.sessionStartTime,
          endTime: Date.now(),
          totalDuration: (Date.now() - this.sessionStartTime) / 1000,
          videoId: videoId
        },
        timestampLog: this.timestampLog,
        finalScore: this.displayScore // 新しい集中度システムのスコアを使用
      };
    }
    
    saveSessionToServer(useBeacon = false) {
      if (this.saveInProgress) {
        console.log('保存処理が既に実行中のためスキップ');
        return;
      }
      
      console.log('=== セッション保存開始 ===');
      console.log('useBeacon:', useBeacon);
      console.log('timestampLog length:', this.timestampLog.length);
      
      this.saveInProgress = true;
      const data = this.prepareSessionData();
      console.log('準備されたセッションデータ:', data);
      
      // 正しい動画IDの取得（URLパスから）
      const pathParts = window.location.pathname.split('/');
      const videoId = pathParts[pathParts.length - 2]; // '/videos/{id}/player' から {id} を取得
      console.log('URL pathname:', window.location.pathname);
      console.log('pathParts:', pathParts);
      console.log('videoId:', videoId);
      
      // videoIdが空または不正な場合は処理を中止
      if (!videoId || videoId.trim() === '' || videoId === 'player') {
        console.error('videoIdを取得できません。セッション保存を中止します。');
        return;
      }
      
      // 再開セッションのIDを取得（あれば）
      const videoPlayer = document.getElementById('video-player');
      const resumeSessionId = videoPlayer?.dataset?.sessionId;
      
      const payload = JSON.stringify({ 
        session_data: JSON.stringify(data),
        session_id: resumeSessionId || null
      });
      console.log('送信ペイロード長:', payload.length);
      
      if (useBeacon && navigator.sendBeacon) {
        // sendBeaconを使用（ページ離脱時により確実）
        const formData = new FormData();
        formData.append('session_data', JSON.stringify(data));
        
        // CSRF token の追加
        const csrfToken = document.querySelector('meta[name="csrf-token"]').content;
        formData.append('authenticity_token', csrfToken);
        
        // セッションIDがあれば追加
        if (resumeSessionId) {
          formData.append('session_id', resumeSessionId);
        }
        
        const beaconUrl = `/videos/${videoId}/management/save_session`;
        console.log('sendBeacon URL:', beaconUrl);
        const success = navigator.sendBeacon(beaconUrl, formData);
        if (success) {
          console.log('sendBeaconでセッションデータを送信しました');
        } else {
          console.warn('sendBeaconでの送信に失敗、fetchを試行');
          this.saveSessionToServer(false); // fallback
        }
        return;
      }
      
      // 通常のfetch使用
      console.log(`送信先URL: /videos/${videoId}/management/save_session`);
      console.log('送信するデータ:', data);
      
      // セッションIDがあればクエリパラメータに追加
      let fetchUrl = `/videos/${videoId}/management/save_session`;
      if (resumeSessionId) {
        fetchUrl += `?session_id=${resumeSessionId}`;
      }
      
      fetch(fetchUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
        },
        body: payload
      })
      .then(response => response.json())
      .then(result => {
        if (result.success) {
          console.log(`セッションデータを保存しました (${this.timestampLog.length - this.lastSaveEventCount}件):`, result.session_id);
          // 保存成功時の管理変数更新
          this.lastSaveTime = Date.now();
          this.lastSaveEventCount = this.timestampLog.length;
          localStorage.removeItem('pendingSessionData');
        } else {
          console.error('セッションデータ保存エラー:', result.error);
        }
      })
      .catch(error => {
        console.error('セッションデータ送信エラー:', error);
        this.saveToLocalStorageBackup(data);
      })
      .finally(() => {
        this.saveInProgress = false;
      });
    }
    
    saveToLocalStorageBackup(data) {
      try {
        // 正しい動画IDの取得
        const pathParts = window.location.pathname.split('/');
        const videoId = pathParts[pathParts.length - 2];
        
        const backupData = {
          ...data,
          videoId: videoId,
          saved: false,
          backupTime: Date.now()
        };
        localStorage.setItem('pendingSessionData', JSON.stringify(backupData));
        console.log('セッションデータをlocalStorageにバックアップしました');
      } catch (e) {
        console.error('localStorageバックアップ失敗:', e);
      }
    }
    
    initializeVideoTracking() {
      this.videoElement = document.getElementById('video-player');
      if (!this.videoElement) return;
      
      // ページロード時に localStorage から保存されたセッションIDを確認
      const pathParts = window.location.pathname.split('/');
      const videoId = pathParts[pathParts.length - 2];
      const sessionKey = `active_session_${videoId}`;
      const savedSessionId = localStorage.getItem(sessionKey);
      
      let isRestoredSession = false; // セッション復元フラグ
      let previousSessionElapsed = 0; // 前回のセッション経過時間
      
      console.log('[セッション復元] localStorage確認:', {
        videoId: videoId,
        sessionKey: sessionKey,
        savedSessionId: savedSessionId,
        allLocalStorageKeys: Object.keys(localStorage),
      });
      
      if (savedSessionId) {
        // localStorage に保存されたセッションIDがあれば使用
        console.log('[再開機能] localStorage から保存済みセッションIDを復元:', savedSessionId);
        this.videoElement.dataset.sessionId = savedSessionId;
        isRestoredSession = true;
        
        // 前回のセッション経過時間を取得
        const lastSessionDataStr = localStorage.getItem('lastTimestampLog');
        if (lastSessionDataStr) {
          try {
            const lastSessionData = JSON.parse(lastSessionDataStr);
            if (lastSessionData.sessionEndTime && lastSessionData.sessionStartTime) {
              previousSessionElapsed = (lastSessionData.sessionEndTime - lastSessionData.sessionStartTime) / 1000;
              // 【修正】sessionStartTime を「今」に設定（ページロード時点を起点）
              // 前回のセッション経過時間は別途記録して使う
              this.sessionStartTime = Date.now();
              
              console.log('[セッション復元] セッション時刻をリセット:', {
                previousSessionElapsed: previousSessionElapsed.toFixed(1) + '秒',
                newSessionStartTime: new Date(this.sessionStartTime),
                currentTime: new Date(Date.now())
              });
            }
          } catch (e) {
            console.warn('[セッション復元エラー] lastTimestampLog解析失敗:', e);
          }
        }
      } else {
        console.log('[再開機能] 新規セッションを開始します。ビデオAPI返却のsessionId:', this.videoElement.dataset.sessionId);
      }
      
      // 動画イベントリスナーを設定
      this.videoElement.addEventListener('play', () => {
        this.videoState = 'playing';
        this.addTimestamp('video_play', '動画再生開始', {
          previousState: 'paused'
        });
      });
      
      this.videoElement.addEventListener('pause', () => {
        this.videoState = 'paused';
        this.addTimestamp('video_pause', '動画一時停止', {
          previousState: 'playing'
        });
      });
      
      this.videoElement.addEventListener('seeked', () => {
        const currentTime = this.videoElement.currentTime;
        const timeDiff = Math.abs(currentTime - this.lastVideoTime);
        
        if (timeDiff > 2) { // 2秒以上のスキップ
          const direction = currentTime > this.lastVideoTime ? '前進' : '後退';
          this.addTimestamp('video_skip', `動画スキップ（${direction}）`, {
            from: this.lastVideoTime,
            to: currentTime,
            skipAmount: timeDiff,
            direction: direction
          });
        }
        
        this.lastVideoTime = currentTime;
      });
      
      this.videoElement.addEventListener('ratechange', () => {
        const newRate = this.videoElement.playbackRate;
        this.addTimestamp('video_speed_change', `再生速度変更`, {
          from: this.lastPlaybackRate,
          to: newRate,
          speedChange: newRate / this.lastPlaybackRate
        });
        this.lastPlaybackRate = newRate;
      });
      
      this.videoElement.addEventListener('ended', () => {
        this.videoState = 'stopped';
        this.addTimestamp('video_end', '動画視聴完了', {
          totalWatchTime: this.videoElement.duration,
          completionRate: 1.0
        });
      });
      
      // 定期的な動画時刻更新
      setInterval(() => {
        if (this.videoElement && this.videoState === 'playing') {
          this.lastVideoTime = this.videoElement.currentTime;
        }
      }, 1000);
      
      // セッション開始イベントを記録
      if (!isRestoredSession) {
        // 新規セッション: session_start を記録
        this.addTimestamp('session_start', '学習セッション開始');
        console.log('[セッション管理] session_start イベントを記録しました（新規セッション）');
      } else {
        // 復元セッション: session_resumed を記録（タイムスタンプカウントは継続）
        this.addTimestamp('session_resumed', '学習セッション再開', {
          prevSessionElapsedTime: previousSessionElapsed.toFixed(1),
          resumedAt: new Date(this.sessionStartTime).toISOString()
        });
        console.log('[セッション管理] session_resumed イベントを記録しました（既存セッション復元）', {
          previousSessionTime: previousSessionElapsed
        });
      }
    }
    
    initializeTimestampPanel() {
      // エクスポートボタン
      const exportBtn = document.getElementById('export-timestamp');
      if (exportBtn) {
        exportBtn.addEventListener('click', () => {
          this.exportTimestampLog();
        });
      }
      
      // サーバー保存ボタン
      const saveBtn = document.getElementById('save-to-server');
      if (saveBtn) {
        saveBtn.addEventListener('click', () => {
          this.saveSessionToServer();
          alert('セッションデータをサーバーに保存しました');
        });
      }
      
      // クリアボタン
      const clearBtn = document.getElementById('clear-timestamp');
      if (clearBtn) {
        clearBtn.addEventListener('click', () => {
          if (confirm('タイムスタンプログをクリアしますか？')) {
            this.timestampLog = [];
            this.updateTimestampDisplay();
            this.updateTimestampStats();
          }
        });
      }
      
      // 統計の定期更新
      setInterval(() => {
        this.updateTimestampStats();
      }, 1000);
    }
    
    updateTimestampStats() {
      const sessionDurationEl = document.getElementById('session-duration');
      const videoTimeEl = document.getElementById('current-video-time');
      const eventCountEl = document.getElementById('event-count');
      
      if (sessionDurationEl) {
        const sessionElapsed = (Date.now() - this.sessionStartTime) / 1000;
        sessionDurationEl.textContent = this.formatTime(sessionElapsed);
      }
      
      if (videoTimeEl && this.videoElement) {
        videoTimeEl.textContent = this.formatTime(this.videoElement.currentTime || 0);
      }
      
      if (eventCountEl) {
        eventCountEl.textContent = this.timestampLog.length;
      }
    }
    
    setupBatchSaving() {
      // 条件ベースの賢い保存システム
      setInterval(() => {
        this.checkAndSave();
      }, 15000); // 15秒間隔でチェック
      
      // 重要イベント時の即座保存
      this.setupCriticalEventSaving();
    }
    
    checkAndSave() {
      if (this.saveInProgress) return;
      
      const currentTime = Date.now();
      const timeSinceLastSave = (currentTime - this.lastSaveTime) / 1000;
      const newEvents = this.timestampLog.length - this.lastSaveEventCount;
      
      console.log(`=== 保存条件チェック ===`);
      console.log(`新しいイベント数: ${newEvents}`);
      console.log(`最後の保存からの経過時間: ${timeSinceLastSave}秒`);
      console.log(`総イベント数: ${this.timestampLog.length}`);
      
      // 保存条件（いずれかを満たす）- デバッグ用に条件を緩和
      const shouldSave = 
        newEvents >= 3 ||                     // 新しいイベントが3個以上（緩和）
        timeSinceLastSave >= 60 ||            // 1分経過（緩和）
        (newEvents >= 1 && timeSinceLastSave >= 30) ||  // 30秒経過 + 1イベント以上（緩和）
        this.hasHighPriorityEvents();         // 重要イベントがある
      
      console.log(`保存すべきか: ${shouldSave}`);
      
      if (shouldSave && newEvents > 0) {
        console.log('条件を満たしたため保存を実行します');
        this.saveSessionToServer();
      } else {
        console.log('保存条件を満たしていません');
      }
    }
    
    hasHighPriorityEvents() {
      // 最後の保存以降に重要なイベントがあるかチェック
      const recentEvents = this.timestampLog.slice(this.lastSaveEventCount);
      return recentEvents.some(event => 
        event.eventType.includes('question') ||
        event.eventType.includes('answer') ||
        event.eventType.includes('video_end') ||
        (event.eventType.includes('score_change') && Math.abs(event.additionalData?.scoreChange || 0) >= 5)
      );
    }
    
    setupCriticalEventSaving() {
      // 重要イベント時は即座に保存をスケジュール
      const originalAddTimestamp = this.addTimestamp.bind(this);
      this.addTimestamp = (eventType, description, additionalData = {}) => {
        // 元の処理を実行
        originalAddTimestamp(eventType, description, additionalData);
        
        // 重要イベントの場合は優先保存をスケジュール
        if (this.isCriticalEvent(eventType, additionalData)) {
          clearTimeout(this.criticalSaveTimeout);
          this.criticalSaveTimeout = setTimeout(() => {
            if (!this.saveInProgress) {
              this.saveSessionToServer();
            }
          }, 2000); // 2秒後に保存
        }
      };
    }
    
    isCriticalEvent(eventType, additionalData) {
      return (
        eventType.includes('session_end') ||
        eventType.includes('video_end') ||
        eventType.includes('question') ||
        eventType.includes('answer') ||
        (eventType.includes('score_change') && Math.abs(additionalData?.scoreChange || 0) >= 10)
      );
    }
    
    setupMemoryCleanup() {
      // 10分ごとにメモリクリーンアップを実行
      setInterval(() => {
        const now = Date.now();
        
        console.log('🧹 メモリクリーンアップを実行中...');
        
        // 各配列のサイズを記録
        const before = {
          recentGazeData: this.recentGazeData.length,
          stateHistory: this.stateHistory.length,
          gazeHistory: this.gazeHistory.length,
          gazeRawHistory: this.gazeRawHistory.length,
          eyeMovementHistory: this.eyeMovementHistory.length
        };
        
        // 古いデータを強制的にクリーンアップ
        const cutoff5sec = now - 6000; // 6秒以上前
        const cutoff60sec = now - 65000; // 65秒以上前
        
        this.recentGazeData = this.recentGazeData.filter(d => d.timestamp > cutoff5sec);
        this.stateHistory = this.stateHistory.filter(s => s.timestamp > cutoff60sec);
        
        // 履歴配列も念のためサイズ制限
        if (this.gazeHistory.length > 10) {
          this.gazeHistory = this.gazeHistory.slice(-3);
        }
        if (this.gazeRawHistory.length > 20) {
          this.gazeRawHistory = this.gazeRawHistory.slice(-8);
        }
        if (this.eyeMovementHistory.length > 10) {
          this.eyeMovementHistory = this.eyeMovementHistory.slice(-5);
        }
        
        const after = {
          recentGazeData: this.recentGazeData.length,
          stateHistory: this.stateHistory.length,
          gazeHistory: this.gazeHistory.length,
          gazeRawHistory: this.gazeRawHistory.length,
          eyeMovementHistory: this.eyeMovementHistory.length
        };
        
        console.log('🧹 クリーンアップ完了:', {
          before,
          after,
          freed: {
            recentGazeData: before.recentGazeData - after.recentGazeData,
            stateHistory: before.stateHistory - after.stateHistory
          }
        });
        
        // ガベージコレクションのヒント（あくまでヒント）
        if (window.gc) {
          console.log('🗑️ ガベージコレクションを実行');
          window.gc();
        }
        
      }, 10 * 60 * 1000); // 10分ごと
    }
    
    setupExitHandlers() {
      let isExiting = false;
      
      const saveOnExit = () => {
        if (isExiting) return; // 重複実行を防ぐ
        isExiting = true;
        
        this.addTimestamp('session_end', '学習セッション終了');
        
        // sendBeaconでの確実な保存を試行
        this.saveSessionToServer(true);
        
        // フォールバックとして同期保存も実行
        this.saveSessionToServerSync();
        
        // localStorageにもバックアップ保存
        try {
          // 正しい動画IDの取得
          const pathParts = window.location.pathname.split('/');
          const videoId = pathParts[pathParts.length - 2];
          
          const backupData = {
            sessionStartTime: this.sessionStartTime,
            sessionEndTime: Date.now(),
            timestampLog: this.timestampLog,
            finalScore: this.displayScore, // 新しい集中度システムのスコアを使用
            videoId: videoId,
            saved: false // サーバー保存成功フラグ
          };
          localStorage.setItem('pendingSessionData', JSON.stringify(backupData));
          localStorage.setItem('lastTimestampLog', JSON.stringify(backupData));
        } catch (e) {
          console.warn('localStorageへの保存に失敗:', e);
        }
      };
      
      // 複数のイベントで離脱を検知
      window.addEventListener('beforeunload', saveOnExit);
      window.addEventListener('pagehide', saveOnExit);
      
      // ブラウザタブの非表示化を検知
      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'hidden') {
          this.saveSessionToServer(); // 非同期保存
        }
      });
      
      // ブラウザフォーカス喪失を検知
      window.addEventListener('blur', () => {
        this.saveSessionToServer(); // 非同期保存
      });
      
      // 定期的な「生存確認」保存
      setInterval(() => {
        this.saveSessionToServer();
      }, 30000); // 30秒間隔
    }
    
    saveSessionToServerSync() {
      // 同期的なXHR要求（ページ離脱時用）
      try {
        const data = this.prepareSessionData();
        // 正しい動画IDの取得
        const pathParts = window.location.pathname.split('/');
        const videoId = pathParts[pathParts.length - 2];
        
        // 再開セッションのIDを取得（あれば）
        const videoPlayer = document.getElementById('video-player');
        const resumeSessionId = videoPlayer?.dataset?.sessionId;
        
        // セッションIDがあればクエリパラメータに追加
        let syncUrl = `/videos/${videoId}/management/save_session`;
        if (resumeSessionId) {
          syncUrl += `?session_id=${resumeSessionId}`;
        }
        
        const xhr = new XMLHttpRequest();
        xhr.open('POST', syncUrl, false); // 同期
        xhr.setRequestHeader('Content-Type', 'application/json');
        xhr.setRequestHeader('X-CSRF-Token', document.querySelector('meta[name="csrf-token"]').content);
        
        xhr.send(JSON.stringify({ 
          session_data: JSON.stringify(data)
        }));
        
        if (xhr.status === 200) {
          console.log('セッションデータを同期保存しました');
          // 保存成功をlocalStorageに記録
          const pendingData = localStorage.getItem('pendingSessionData');
          if (pendingData) {
            const parsed = JSON.parse(pendingData);
            parsed.saved = true;
            localStorage.setItem('pendingSessionData', JSON.stringify(parsed));
          }
        }
      } catch (error) {
        console.error('同期保存エラー:', error);
      }
    }
    
    // ページ読み込み時に未保存データをチェック
    checkPendingSessionData() {
      try {
        // 【修正】sessionStartTime の上書きは行わない
        // initializeVideoTracking() または コンストラクタ の初期化に任せる
        
        const pendingData = localStorage.getItem('pendingSessionData');
        if (pendingData) {
          const data = JSON.parse(pendingData);
          if (!data.saved && data.timestampLog && data.timestampLog.length > 0) {
            // 未保存のセッションデータがある場合、サーバーに送信
            console.log('未保存のセッションデータを発見、サーバーに送信中...');
            
            // 正しい動画IDの取得
            const pathParts = window.location.pathname.split('/');
            const currentVideoId = pathParts[pathParts.length - 2];
            if (data.videoId === currentVideoId) {
              fetch(`/videos/${currentVideoId}/management/save_session`, {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                  'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
                },
                body: JSON.stringify({ session_data: JSON.stringify({
                  sessionInfo: {
                    startTime: data.sessionStartTime,
                    endTime: data.sessionEndTime,
                    totalDuration: (data.sessionEndTime - data.sessionStartTime) / 1000,
                    videoId: data.videoId
                  },
                  timestampLog: data.timestampLog,
                  finalScore: data.finalScore
                })})
              })
              .then(response => response.json())
              .then(result => {
                if (result.success) {
                  console.log('未保存データの復旧に成功:', result.session_id);
                  localStorage.removeItem('pendingSessionData');
                }
              })
              .catch(error => {
                console.error('未保存データの復旧に失敗:', error);
              });
            }
          } else {
            // 既に保存済みの場合は削除
            localStorage.removeItem('pendingSessionData');
          }
        }
      } catch (e) {
        console.warn('未保存データのチェックでエラー:', e);
      }
    }
    
