<script>
// 初回アクセス時のみ自動リロード
if (!sessionStorage.getItem('videoPageLoaded')) {
  sessionStorage.setItem('videoPageLoaded', 'true');
  location.reload();
}

// 初期化管理用のグローバル変数
if (typeof window.videoPlayerInitState === 'undefined') {
  window.videoPlayerInitState = {
    isInitialized: false,
    retryCount: 0,
    maxRetries: 50,
    shouldStop: false  // 初期化停止フラグ
  };
}

// 初期化関数をグローバルスコープで定義
function initializeVideoPlayer() {
  // 停止フラグがセットされている場合は中断
  if (window.videoPlayerInitState.shouldStop) {
    console.log('初期化が停止されました（ページ遷移中）');
    return;
  }
  
  // すでに初期化済みの場合はスキップ
  if (window.videoPlayerInitState.isInitialized) {
    console.log('動画プレイヤーは既に初期化済みです');
    return;
  }
  
  // リトライ上限チェック
  if (window.videoPlayerInitState.retryCount > window.videoPlayerInitState.maxRetries) {
    console.error('動画プレイヤーの初期化に失敗しました（タイムアウト）');
    return;
  }
  
  window.videoPlayerInitState.retryCount++;
  
  // 現在のURLが動画プレイヤーページかチェック
  const currentPath = window.location.pathname;
  if (!currentPath.includes('/videos/') || !currentPath.includes('/player')) {
    console.log('動画プレイヤーページではありません。初期化を中止します。');
    return;
  }
  
  // MediaPipeライブラリが読み込まれているか確認
  if (typeof FaceMesh === 'undefined') {
    console.log('MediaPipe FaceMeshライブラリがまだ読み込まれていません。100ms後にリトライ... (試行: ' + window.videoPlayerInitState.retryCount + ')');
    setTimeout(initializeVideoPlayer, 100);
    return;
  }
  
  const videoPlayer = document.getElementById('video-player');
  if (!videoPlayer) {
    console.log('video要素がまだレンダリングされていません。100ms後にリトライ... (試行: ' + window.videoPlayerInitState.retryCount + ')');
    setTimeout(initializeVideoPlayer, 100);
    return;
  }
  
  // イベントリスナー重複登録チェック（この関数が2回目以降の呼び出しならスキップ）
  if (videoPlayer.dataset.listenersAttached === 'true') {
    console.log('動画プレイヤーイベントリスナーは既に登録済みです');
    return;
  }
  
  // イベントリスナー登録完了をマーク
  videoPlayer.dataset.listenersAttached = 'true';
  
  // 初期化完了フラグを設定
  window.videoPlayerInitState.isInitialized = true;
  console.log('動画プレイヤー初期化開始... (初期化条件クリア)');
  
  // グローバルエラーハンドリングを追加
  window.addEventListener('error', function(event) {
    console.error('Caught global error:', event.error);
  });
  
  // 集中度管理クラス
  class ConcentrationTracker {
    constructor() {
      this.score = 20;
      this.faceDetected = false;
      this.gazeX = 0;
      this.gazeY = 0;
      this.frontFacingRatio = 100;
      this.lastMovementTime = Date.now();
      
      // 視線データの平滑化用（3フレーム平均）
      this.gazeHistory = [];
      
      // 新しい集中度システム（5秒窓 + 1分窓）
      this.recentGazeData = []; // 過去5秒間の状態データ
      this.stateHistory = [];   // 過去60秒間の状態データ
      this.displayScore = 50;    // 前回の1分間のスコア（表示用）
      this.currentWindowScore = 50; // 現在計測中の1分間のスコア
      this.currentState = null;  // 現在の5秒窓の状態（インジケーター表示用）
      this.lastWindowUpdate = Date.now(); // 最後に1分窓を確定した時刻
      this.lastTimestampRecord = Date.now(); // 最後にタイムスタンプを記録した時刻
      this.lastRecordedScore = 50; // 最後に記録したスコア
      this.showCalculationDetail = false; // 計算式の表示フラグ
      
      // 集中度判定の設定
      this.concentrationSettings = {
        gazeCenterThreshold: 5,       // 視線中央判定の閾値
        stabilityWindow: 5,           // 安定性判定用の窓（秒）
        faceDetectionMinRate: 0.2,    // 離席と判定する顔検出率の閾値
        windowSize: 60,               // 1分間窓（秒）
        windowUpdateInterval: 60000,  // 1分ごとにスコア確定（ミリ秒）
        timestampInterval: 5000,      // 5秒ごとにタイムスタンプ記録（ミリ秒）
        scoreChangeThreshold: 10      // スコア変化がこの値以上なら即座に記録
