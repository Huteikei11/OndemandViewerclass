<div class="video-player-container">
  <div class="video-section">
    <% if @video.video_file.attached? %>
      <div class="question-indicator" id="question-indicator" style="display: none;">問題あり！</div>
      
      <!-- デバッグ情報パネル -->
      <div class="debug-panel" id="debug-panel" style="display: none;">
        <div class="debug-header">
          目線追跡デバッグ情報
          <button class="btn btn-sm btn-outline-light ms-2" id="toggle-camera-preview">カメラ</button>
        </div>
        
        <!-- タブナビゲーション -->
        <div class="debug-tabs">
          <button class="debug-tab-btn active" data-tab="info">基本情報</button>
          <button class="debug-tab-btn" data-tab="factors">スコア要因</button>
          <button class="debug-tab-btn" data-tab="settings">スコア設定</button>
          <button class="debug-tab-btn" data-tab="timestamp">タイムスタンプ</button>
        </div>
        
        <!-- 基本情報タブ -->
        <div id="debug-tab-info" class="debug-tab-content">
          <!-- カメラプレビュー -->
          <div class="camera-preview" id="camera-preview" style="display: none; margin-bottom: 10px;">
            <div class="camera-container" style="position: relative; display: inline-block;">
              <video id="debug-camera" width="320" height="240" autoplay muted></video>
              <canvas id="gaze-overlay-canvas" width="320" height="240" 
                      style="position: absolute; top: 0; left: 0; pointer-events: none;"></canvas>
            </div>
          </div>
          
          <div>検出方式: <span id="detection-method">初期化中...</span></div>
          <div>顔検出: <span id="face-detected">-</span></div>
          <div>目線方向X: <span id="gaze-x">-</span></div>
          <div>目線方向Y: <span id="gaze-y">-</span></div>
          <div>目線方向: <span id="gaze-direction">-</span></div>
          <div>集中度スコア: <span id="front-facing">-</span></div>
          <div>最後の動き: <span id="last-movement">-</span>秒前</div>
          <div>メモ入力回数: <span id="note-inputs">0</span></div>
          
          <!-- 新しい集中度システム詳細 -->
          <div class="concentration-details" style="margin-top: 10px; padding: 8px; background: rgba(76, 175, 80, 0.1); border-radius: 4px; border: 1px solid rgba(76, 175, 80, 0.3);">
            <div style="font-weight: bold; color: #4caf50; margin-bottom: 5px;">📊 安定版集中度システム</div>
            <pre id="concentration-detail" style="font-size: 9px; line-height: 1.3; margin: 0; white-space: pre-wrap; color: #e0e0e0;">データ収集中...</pre>
          </div>
          
          <!-- 眼球データ詳細 -->
          <div class="eyeball-details" style="margin-top: 10px; padding: 8px; background: rgba(255,255,255,0.1); border-radius: 4px;">
            <div style="font-weight: bold; color: #4fc3f7; margin-bottom: 5px;">🔍 眼球追跡データ</div>
            <pre id="eyeball-details" style="font-size: 9px; line-height: 1.2; margin: 0; white-space: pre-wrap;">眼球データ待機中...</pre>
          </div>
          
          <!-- 集中度変動ログ -->
          <div class="concentration-log">
            <div class="log-header">集中度変動ログ</div>
            <div class="log-content" id="concentration-log"></div>
          </div>
        </div>
        
        <!-- スコア要因タブ -->
        <div id="debug-tab-factors" class="debug-tab-content" style="display: none;">
          <div class="factors-header">スコア変動イベント説明</div>
          <div id="score-factors" class="score-factors">
            <div class="factor-category">
              <h7 class="category-title">📹 カメラ関連</h7>
              <div class="factor-item neutral">
                <div class="factor-header">顔未検出 (-2点)</div>
                <div class="factor-detail">カメラに顔が映っていない場合に減点されます</div>
              </div>
            </div>
            
            <div class="factor-category">
              <h7 class="category-title">👀 目線・注視</h7>
              <div class="factor-item positive">
                <div class="factor-header">集中注視 (+0.5点)</div>
                <div class="factor-detail">画面中央15px以内を注視している場合、5秒ごとに加点されます</div>
              </div>
              <div class="factor-item positive">
                <div class="factor-header">正面注視 (+1点)</div>
                <div class="factor-detail">正面を向いて学習している場合、5秒ごとに加点されます</div>
              </div>
              <div class="factor-item positive">
                <div class="factor-header">問題確認 (+5点)</div>
                <div class="factor-detail">問題表示後3秒以内に視線速度が10px/s以上になった場合に加点されます</div>
              </div>
              <div class="factor-item negative">
                <div class="factor-header">目線停止 (-1点/秒)</div>
                <div class="factor-detail">10秒以上目線の動き(10px以上)がない場合に減点されます</div>
              </div>
            </div>
            
            <div class="factor-category">
              <h7 class="category-title">⚡ 反応速度（記録のみ）</h7>
              <div class="factor-item neutral">
                <div class="factor-header">回答遅延 (スコア反映なし)</div>
                <div class="factor-detail">問題表示から30秒以上経過して回答した場合にタイムスタンプ記録されます（スコアには反映されません）</div>
              </div>
              <div class="factor-item neutral">
                <div class="factor-header">素早い回答 (スコア反映なし)</div>
                <div class="factor-detail">問題表示から5秒以内に回答した場合にタイムスタンプ記録されます（スコアには反映されません）</div>
              </div>
            </div>
            
            <div class="factor-category">
              <h7 class="category-title">📝 メモ活動</h7>
              <div class="factor-item positive">
                <div class="factor-header">メモ入力 (+3点/回)</div>
                <div class="factor-detail">新しいメモを入力するたびに加点されます</div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- スコア設定タブ -->
        <div id="debug-tab-settings" class="debug-tab-content" style="display: none;">
          <div class="settings-header">スコア調整設定</div>
          <div class="settings-content">
            
            <!-- 減点設定 -->
            <div class="settings-category">
              <h7 class="settings-category-title">減点設定</h7>
              
              <div class="setting-item">
                <label for="face-not-detected-penalty">顔未検出時の減点:</label>
                <input type="number" id="face-not-detected-penalty" value="2" min="0" max="10" step="0.1">
                <span class="setting-unit">点</span>
              </div>
              
              <div class="setting-item">
                <label for="movement-stop-penalty">目線停止時の減点:</label>
                <input type="number" id="movement-stop-penalty" value="1" min="0" max="5" step="0.1">
                <span class="setting-unit">点/秒</span>
              </div>
              
              <div class="setting-item">
                <label for="response-delay-penalty">回答遅延時の減点:</label>
                <input type="number" id="response-delay-penalty" value="1" min="0" max="5" step="0.1">
                <span class="setting-unit">点/秒</span>
              </div>
            </div>
            
            <!-- 加点設定 -->
            <div class="settings-category">
              <h7 class="settings-category-title">加点設定</h7>
              
              <div class="setting-item">
                <label for="center-gaze-bonus">中央注視時の加点:</label>
                <input type="number" id="center-gaze-bonus" value="0.5" min="0" max="5" step="0.1">
                <span class="setting-unit">点</span>
              </div>
              
              <div class="setting-item">
                <label for="question-confirm-bonus">問題確認時の加点:</label>
                <input type="number" id="question-confirm-bonus" value="5" min="0" max="20" step="0.5">
                <span class="setting-unit">点</span>
              </div>
              
              <div class="setting-item">
                <label for="quick-response-bonus">素早い回答時の加点:</label>
                <input type="number" id="quick-response-bonus" value="3" min="0" max="10" step="0.5">
                <span class="setting-unit">点</span>
              </div>
              
              <div class="setting-item">
                <label for="note-input-bonus">メモ入力時の加点:</label>
                <input type="number" id="note-input-bonus" value="3" min="0" max="10" step="0.5">
                <span class="setting-unit">点</span>
              </div>
              
              <div class="setting-item">
                <label for="front-facing-bonus">正面注視時の加点:</label>
                <input type="number" id="front-facing-bonus" value="1" min="0" max="5" step="0.1">
                <span class="setting-unit">点</span>
              </div>
            </div>
            
            <!-- 時間設定 -->
            <div class="settings-category">
              <h7 class="settings-category-title">時間間隔設定</h7>
              
              <div class="setting-item">
                <label for="movement-stop-threshold">目線停止判定時間:</label>
                <input type="number" id="movement-stop-threshold" value="10" min="1" max="60" step="1">
                <span class="setting-unit">秒</span>
              </div>
              
              <div class="setting-item">
                <label for="response-delay-threshold">回答遅延判定時間:</label>
                <input type="number" id="response-delay-threshold" value="30" min="5" max="120" step="1">
                <span class="setting-unit">秒</span>
              </div>
              
              <div class="setting-item">
                <label for="quick-response-threshold">素早い回答判定時間:</label>
                <input type="number" id="quick-response-threshold" value="5" min="1" max="30" step="0.5">
                <span class="setting-unit">秒</span>
              </div>
              
              <div class="setting-item">
                <label for="front-facing-interval">正面注視加点間隔:</label>
                <input type="number" id="front-facing-interval" value="5000" min="100" max="10000" step="100">
                <span class="setting-unit">ミリ秒</span>
              </div>
              
              <div class="setting-item">
                <label for="center-gaze-interval">集中注視加点間隔:</label>
                <input type="number" id="center-gaze-interval" value="3000" min="100" max="10000" step="100">
                <span class="setting-unit">ミリ秒</span>
              </div>
            </div>
            
            <!-- その他設定 -->
            <div class="settings-category">
              <h7 class="settings-category-title">その他設定</h7>
              
              <div class="setting-item">
                <label for="movement-detection-threshold">目線動き検出閾値:</label>
                <input type="number" id="movement-detection-threshold" value="13" min="1" max="50" step="1">
                <span class="setting-unit">ピクセル</span>
              </div>
              
              <div class="setting-item">
                <label for="center-gaze-threshold">中央注視判定範囲:</label>
                <input type="number" id="center-gaze-threshold" value="15" min="5" max="50" step="1">
                <span class="setting-unit">ピクセル</span>
              </div>
              
              <div class="setting-item">
                <label for="gaze-velocity-threshold">問題確認判定速度:</label>
                <input type="number" id="gaze-velocity-threshold" value="5" min="1" max="50" step="1">
                <span class="setting-unit">px/s</span>
              </div>
            </div>
            
            <!-- 設定操作ボタン -->
            <div class="settings-actions">
              <button class="btn btn-primary btn-sm" id="apply-settings">設定を適用</button>
              <button class="btn btn-secondary btn-sm" id="reset-settings">デフォルトに戻す</button>
              <button class="btn btn-info btn-sm" id="export-settings">設定をエクスポート</button>
              <button class="btn btn-success btn-sm" id="import-settings">設定をインポート</button>
              <input type="file" id="import-file" accept=".json" style="display: none;">
            </div>
          </div>
        </div>
        
        <!-- タイムスタンプタブ -->
        <div id="debug-tab-timestamp" class="debug-tab-content" style="display: none;">
          <div class="timestamp-header">
            <span>学習行動タイムスタンプ</span>
            <div class="timestamp-controls">
              <button class="btn btn-sm btn-success" id="export-timestamp">エクスポート</button>
              <button class="btn btn-sm btn-primary" id="save-to-server">サーバー保存</button>
              <button class="btn btn-sm btn-info" id="clear-timestamp">クリア</button>
            </div>
          </div>
          
          <div class="timestamp-stats">
            <div class="stat-item">
              <span class="stat-label">セッション時間:</span>
              <span id="session-duration">0:00</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">動画時刻:</span>
              <span id="current-video-time">0:00</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">イベント数:</span>
              <span id="event-count">0</span>
            </div>
          </div>
          
          <div class="timestamp-log" id="timestamp-log">
            <div class="timestamp-entry">
              <div class="timestamp-header">
                <span class="timestamp-time">セッション開始待機中...</span>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <video id="video-player" controls
             data-session-id="<%= @resume_session&.id %>"
             data-resume-time="<%= @resume_session&.last_video_time || 0 %>"
             data-can-resume="<%= @resume_session&.can_resume? || false %>"
             data-latest-session="<%= @latest_session_json %>">
        <source src="<%= url_for(@video.video_file) %>" type="<%= @video.video_file.content_type %>">
        Your browser does not support the video tag.
      </video>
      
      <!-- デバッグ情報（開発環境用） -->
      <% if Rails.env.development? %>
        <script>
          console.log('[ビュー] @resume_session 状態:', {
            present: <%= @resume_session.present?.to_s %>,
            id: <%= @resume_session&.id || 'null' %>,
            last_video_time: <%= @resume_session&.last_video_time || 0 %>,
            can_resume: <%= @resume_session&.can_resume?.to_s %>
          });
        </script>
      <% end %>
      
      <!-- 再開情報パネル -->
      <% if @resume_session && @resume_session.last_video_time > 0 %>
        <div class="resume-panel" id="resume-panel"
             data-session-id="<%= @resume_session.id %>"
             data-resume-time="<%= @resume_session.last_video_time %>"
             data-formatted-time="<%= @resume_session.formatted_resume_time %>">
          <div class="resume-content">
            <div class="resume-icon">▶</div>
            <div class="resume-text">
              <div class="resume-label">前回から再開できます</div>
              <div class="resume-time"><%= @resume_session.formatted_resume_time %>から再開</div>
            </div>
            <button class="btn btn-sm btn-primary" id="resume-button">再開する</button>
            <button class="btn btn-sm btn-outline-secondary" id="new-start-button">最初から見る</button>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="no-video">
        <p>動画が利用できません</p>
      </div>
    <% end %>
    
    <div class="video-info">
      <h1><%= @video.title %></h1>
      <div class="video-actions">
        <% if @video.pdf_file.attached? %>
          <a href="<%= url_for(@video.pdf_file) %>" target="_blank" class="btn btn-primary">講義資料を開く</a>
        <% end %>
        <%= link_to '戻る', root_path, class: "btn btn-secondary" %>
        
        <!-- 集中度ゲージ -->
        <div class="concentration-gauge" id="concentration-gauge">
          <div class="gauge-header">
            <span>集中度</span>
            <button class="btn btn-sm btn-outline-light" id="toggle-debug-info">デバッグ</button>
          </div>
          <div class="gauge-bar">
            <div class="gauge-level gauge-green" id="gauge-green"></div>
            <div class="gauge-level gauge-yellow" id="gauge-yellow"></div>
            <div class="gauge-level gauge-orange" id="gauge-orange"></div>
            <div class="gauge-level gauge-red" id="gauge-red"></div>
          </div>
          <div class="gauge-score" id="gauge-score">100%</div>
        </div>
      </div>
    </div>
  </div>
  
  <div class="side-panel">
    <div class="question-section" id="question-section">
      <div class="section-header">
        <h3>問題</h3>
      </div>
      
      <div class="question-content" id="question-container">
        <div class="waiting-message" id="waiting-message">
          <p>動画を再生すると、問題が表示されます</p>
          <% if @questions.any? %>
            <p><strong>設定されている問題数: <%= @questions.count %></strong></p>
          <% else %>
            <p><strong>この動画には問題がありません</strong></p>
          <% end %>
        </div>
        
        <div class="question-display" id="question-display" style="display: none;">
          <div class="question-text" id="question-text"></div>
          
          <div class="question-form" id="true-false-form" style="display: none;">
            <div class="options">
              <label class="option-label">
                <input type="radio" name="tf-answer" value="○"> ○
              </label>
              <label class="option-label">
                <input type="radio" name="tf-answer" value="×"> ×
              </label>
            </div>
            <button class="btn btn-primary" id="tf-submit">回答する</button>
          </div>
          
          <div class="question-form" id="multiple-choice-form" style="display: none;">
            <div class="options" id="mc-options"></div>
            <button class="btn btn-primary" id="mc-submit">回答する</button>
          </div>
          
          <div class="question-form" id="free-response-form" style="display: none;">
            <textarea id="free-response-answer" rows="3" class="form-control" placeholder="回答を入力してください"></textarea>
            <button class="btn btn-primary mt-2" id="fr-submit">回答する</button>
          </div>
          
          <div class="result-message" id="result-message" style="display: none;"></div>
        </div>
      </div>
    </div>
    
    <div class="notes-section">
      <div class="section-header">
        <h3>メモ</h3>
        <button class="btn btn-sm btn-primary" id="save-note-btn">保存</button>
      </div>
      
      <div class="notes-content">
        <textarea id="note-textarea" rows="10" class="form-control" placeholder="ここにメモを入力できます..."></textarea>
      </div>
    </div>
  </div>
</div>

<style>
  body {
    margin: 0;
    padding: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    background-color: #f8f9fa;
  }
  
  .video-player-container {
    display: flex;
    min-height: 100vh;
    background-color: #000;
  }
  
  .video-section {
    flex: 3;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
  }
  
  .question-indicator {
    position: absolute;
    top: 10px;
    right: 10px;
    background-color: rgba(255, 193, 7, 0.9);
    color: #000;
    padding: 5px 10px;
    border-radius: 4px;
    font-weight: bold;
    z-index: 101;
    display: none;
    animation: fadeIn 0.5s;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  
  /* 集中度ゲージ */
  .concentration-gauge {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    background-color: rgba(0, 0, 0, 0.8);
    color: white;
    padding: 10px;
    border-radius: 8px;
    margin-left: 10px;
    min-width: 100px;
  }
  
  .gauge-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
    font-size: 12px;
    font-weight: bold;
    width: 100%;
  }
  
  .gauge-bar {
    display: flex;
    flex-direction: column;
    height: 60px;
    width: 20px;
    border: 1px solid #555;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 5px;
  }
  
  .gauge-level {
    flex: 1;
    transition: opacity 0.3s ease;
    opacity: 0.3;
  }
  
  .gauge-level.active {
    opacity: 1;
  }
  
  .gauge-green { background-color: #28a745; }
  .gauge-yellow { background-color: #ffc107; }
  .gauge-orange { background-color: #fd7e14; }
  .gauge-red { background-color: #dc3545; }
  
  .gauge-score {
    text-align: center;
    font-size: 11px;
    font-weight: bold;
  }
  
  /* デバッグパネル */
  .debug-panel {
    position: absolute;
    top: 10px;
    right: 10px;
    background-color: rgba(0, 0, 0, 0.95);
    color: white;
    padding: 10px;
    border-radius: 8px;
    z-index: 99;
    max-width: 350px;
  }
  
  .debug-tabs {
    display: flex;
    margin-bottom: 10px;
    border-bottom: 1px solid #444;
  }
  
  .debug-tab-btn {
    background: none;
    border: none;
    color: #ccc;
    padding: 8px 12px;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.3s ease;
  }
  
  .debug-tab-btn.active {
    color: white;
    border-bottom-color: #007bff;
  }
  
  .debug-tab-btn:hover {
    color: white;
    background-color: rgba(255, 255, 255, 0.1);
  }
  
  .debug-tab-content {
    animation: fadeIn 0.3s ease;
  }
  
  .score-factors {
    max-height: 200px;
    overflow-y: auto;
    font-size: 12px;
  }
  
  .factor-item {
    background-color: rgba(255, 255, 255, 0.1);
    margin: 5px 0;
    padding: 8px;
    border-radius: 4px;
    border-left: 3px solid #007bff;
  }
  
  .factor-item.positive {
    border-left-color: #28a745;
  }
  
  .factor-item.negative {
    border-left-color: #dc3545;
  }
  
  .factor-item.neutral {
    border-left-color: #6c757d;
  }
  
  .factor-header {
    font-weight: bold;
    margin-bottom: 3px;
  }
  
  .factor-detail {
    font-size: 11px;
    color: #ccc;
  }
  
  .factor-category {
    margin-bottom: 15px;
  }
  
  .category-title {
    font-size: 13px;
    font-weight: bold;
    color: #fff;
    margin-bottom: 8px;
    display: block;
    border-bottom: 1px solid #444;
    padding-bottom: 3px;
  }
  
  .factors-header {
    font-weight: bold;
    margin-bottom: 8px;
    border-bottom: 1px solid #555;
    padding-bottom: 4px;
  }
  
  .debug-header {
    font-weight: bold;
    margin-bottom: 8px;
