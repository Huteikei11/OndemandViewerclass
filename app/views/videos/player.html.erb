        responseDelayPenalty: 1,
        centerGazeBonus: 0.5,
        questionConfirmBonus: 5,
        quickResponseBonus: 3,
        noteInputBonus: 3,
        frontFacingBonus: 1,
        movementStopThreshold: 10,
        responseDelayThreshold: 30,
        quickResponseThreshold: 5,
        questionConfirmWindow: 3,
