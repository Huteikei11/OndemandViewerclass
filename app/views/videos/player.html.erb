          console.log(`📸 [onFaceMeshResults] 呼び出し確認 - 顔検出: ${results.multiFaceLandmarks?.length > 0}, landmarks数: ${results.multiFaceLandmarks?.length || 0}`);
          this.lastOnFaceMeshLog = Date.now();
        }
        
        // デバッグ: 問題表示中はMediaPipe動作を確認
        if (this.questionDisplayTime) {
