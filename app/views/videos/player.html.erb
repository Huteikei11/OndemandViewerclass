// セッション追跡と保存
function startSessionTracking() {
  const videoPlayer = document.getElementById('video-player');
  if (!videoPlayer) {
    console.log('[セッション記録] videoPlayer 要素が見つかりません');
    return;
  }

  console.log('[セッション記録] 開始');
  
  // セッション情報を取得する関数（resumePanel が更新される可能性があるため）
  const getSessionId = () => {
    const resumePanel = document.getElementById('resume-panel');
    return resumePanel ? resumePanel.dataset.sessionId : null;
  };

  const sessionStartTime = new Date();
  let lastSaveTime = Date.now();
  const savingInterval = 5000; // 5秒ごとに保存

  videoPlayer.addEventListener('timeupdate', function() {
    const currentTime = Date.now();
    
    // 5秒ごとにセッション情報を保存
    if (currentTime - lastSaveTime >= savingInterval) {
      const videoTime = videoPlayer.currentTime;
      const sessionElapsed = Math.floor((currentTime - sessionStartTime) / 1000);
      const sessionId = getSessionId();
      
      if (sessionId && videoTime > 0) {
        console.log(`[セッション記録] 保存中 - 動画時刻: ${videoTime.toFixed(1)}秒, セッションID: ${sessionId}`);
        
        // 既存の save_session_data システムから last_video_time が更新される
        // ここでは単にログのみ
      }
      
      lastSaveTime = currentTime;
    }
  });

  // ページ離脱時にセッションを一時停止
  window.addEventListener('beforeunload', function() {
    const videoTime = videoPlayer.currentTime;
    const sessionElapsed = Math.floor((Date.now() - sessionStartTime) / 1000);
    const sessionId = getSessionId();
    
    console.log('[ページ離脱] セッション保存:', { videoTime, sessionElapsed, sessionId });
    
    // keep-aliveを使って非同期でセッションを保存
    if (navigator.sendBeacon && sessionId && videoTime > 0) {
      navigator.sendBeacon(
        `/api/sessions/${sessionId}/deactivate`,
        JSON.stringify({
          video_time: videoTime,
          session_elapsed: sessionElapsed
        })
      );
    }
  });
}

function setupResumeHandlers() {
  const videoPlayer = document.getElementById('video-player');
  const resumeButton = document.getElementById('resume-button');
  const newStartButton = document.getElementById('new-start-button');
  let resumePanel = document.getElementById('resume-panel');
  
  console.log('[再開機能] setupResumeHandlers 呼び出し', {
    resumeButton: !!resumeButton,
    newStartButton: !!newStartButton,
    resumePanel: !!resumePanel,
    videoPlayer: !!videoPlayer
  });
  
  // resume_panel がない場合、video 要素の data属性から復元
  if (!resumePanel && videoPlayer) {
    const latestSessionJson = videoPlayer.dataset.latestSession || '{}';
    const sessionId = videoPlayer.dataset.sessionId;
    const resumeTime = parseFloat(videoPlayer.dataset.resumeTime || 0);
    const canResume = videoPlayer.dataset.canResume === 'true';
    
    console.log('[再開機能] video 要素から復元情報を取得:', {
      latestSessionJson: latestSessionJson,
      sessionId: sessionId,
      resumeTime: resumeTime,
      canResume: canResume
    });
    
    // 前回のセッションで動画を視聴していた場合、resume panel を動的に作成
    if (sessionId && resumeTime > 0 && canResume) {
      try {
        const sessionData = JSON.parse(latestSessionJson);
        console.log('[再開機能] セッションデータを解析:', sessionData);
        
        // resume panel を動的作成
        const resumePanelDiv = document.createElement('div');
        resumePanelDiv.className = 'resume-panel';
        resumePanelDiv.id = 'resume-panel';
        resumePanelDiv.dataset.sessionId = sessionId;
        resumePanelDiv.dataset.resumeTime = resumeTime;
        resumePanelDiv.dataset.formattedTime = sessionData.formatted_resume_time;
        
        const minutes = Math.floor(resumeTime / 60);
        const seconds = Math.floor(resumeTime % 60);
        const formattedTime = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
        
        resumePanelDiv.innerHTML = `
          <div class="resume-content">
            <div class="resume-icon">▶</div>
            <div class="resume-text">
              <div class="resume-label">前回から再開できます</div>
              <div class="resume-time">${formattedTime}から再開</div>
            </div>
            <button class="btn btn-sm btn-primary" id="resume-button">再開する</button>
            <button class="btn btn-sm btn-outline-secondary" id="new-start-button">最初から見る</button>
          </div>
        `;
        
        // video要素の直後に挿入
        videoPlayer.parentNode.insertBefore(resumePanelDiv, videoPlayer.nextSibling);
        resumePanel = resumePanelDiv;
        
        console.log('[再開機能] 動的に resume panel を作成しました');
      } catch (e) {
        console.warn('[再開機能] セッションデータ解析に失敗:', e);
      }
    }
  }
  
  if (resumePanel) {
    console.log('[再開機能] 再開パネル検出:', {
      sessionId: resumePanel.dataset.sessionId,
      resumeTime: resumePanel.dataset.resumeTime,
      formattedTime: resumePanel.dataset.formattedTime
    });
  }
  
  if (resumeButton) {
    resumeButton.addEventListener('click', function() {
      if (videoPlayer && resumePanel) {
        const resumeTime = parseFloat(resumePanel.dataset.resumeTime || 0);
        const sessionId = resumePanel.dataset.sessionId;
        
        console.log('[再開機能] 再開ボタンクリック:', { resumeTime, sessionId });
        
        // 動画を再開位置に設定
        setTimeout(function() {
          videoPlayer.currentTime = resumeTime;
          videoPlayer.play();
          
          console.log('[再開機能] 動画を再開:', videoPlayer.currentTime);
          
          // セッションIDを video要素の data-session-id に明示的にセット
          // （ページリロード時に同じセッションで保存できるように）
          videoPlayer.dataset.sessionId = sessionId;
          console.log('[再開機能] video要素のsessionIdを更新:', sessionId);
          
          // セッションをアクティブ化するAPIリクエスト
          activateSession(sessionId);
        }, 100);
      }
    });
  }
  
  if (newStartButton) {
    newStartButton.addEventListener('click', function() {
      if (videoPlayer) {
        console.log('[再開機能] 最初から見るボタンクリック');
        
        // localStorage から保存されたセッションIDをクリア
        const pathParts = window.location.pathname.split('/');
        const videoId = pathParts[2];
        const sessionKey = `active_session_${videoId}`;
        localStorage.removeItem(sessionKey);
        console.log('[再開機能] localStorage のセッションIDをクリア:', sessionKey);
        
        // 前のセッションを終了し、新规セッションを開始
        resetSession();
        
        setTimeout(function() {
          videoPlayer.currentTime = 0;
          videoPlayer.play();
          console.log('[再開機能] 最初から動画を再生');
        }, 100);
      }
    });
  }
}

// セッションをアクティブ化（バックエンド）
function activateSession(sessionId) {
  if (!sessionId) {
    console.log('[セッション API] sessionId がありません');
    return;
  }
  
  // videoId との紐付けでセッションIDを記録
  const pathParts = window.location.pathname.split('/');
  const videoId = pathParts[2];
  const sessionKey = `active_session_${videoId}`;
  
  fetch(`/api/sessions/${sessionId}/activate`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
    }
  })
  .then(response => response.json())
  .then(data => {
    console.log('[セッション API] アクティブ化成功:', data);
    // セッションIDをlocalStorageに記録（ページリロード後も同じセッションを使用するため）
    localStorage.setItem(sessionKey, sessionId);
    console.log('[セッション API] localStorage にセッションID を記録:', sessionKey, sessionId);
  })
  .catch(error => console.error('[セッション API エラー]', error));
}

// セッションをリセット（新規セッション開始）
function resetSession() {
  const pathParts = window.location.pathname.split('/');
  const videoId = pathParts[2]; // /videos/{id}/player
  
  if (!videoId) {
    console.log('[セッション API] videoId が取得できません');
    return;
  }
  
  console.log('[セッション API] 新規セッション開始:', { videoId });
  
  fetch(`/api/videos/${videoId}/new-session`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
    }
  })
  .then(response => response.json())
  .then(data => {
    console.log('[セッション API] 新規作成成功:', data);
    
    // 新規セッションIDをデータ属性に更新
    const resumePanel = document.getElementById('resume-panel');
    const videoPlayer = document.getElementById('video-player');
    
    if (videoPlayer && data.session_id) {
      videoPlayer.dataset.sessionId = data.session_id;
      console.log('[セッション API] video要素のsessionIdを新しいセッションで更新:', data.session_id);
      
      // localStorage に新しいセッションIDを記録
      const sessionKey = `active_session_${videoId}`;
      localStorage.setItem(sessionKey, data.session_id);
      console.log('[セッション API] localStorage のセッションIDを更新:', sessionKey, data.session_id);
    }
    
    if (resumePanel) {
      // セッションを削除して再開パネルを消す
      resumePanel.style.display = 'none';
      console.log('[セッション API] 再開パネルを非表示にしました');
    }
  })
  .catch(error => console.error('[セッション API エラー]', error));
}
</script>
