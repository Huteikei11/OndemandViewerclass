    applySettingsFromUI() {
      try {
        // UIから設定値を取得して適用
        const newSettings = {};
        
        Object.keys(this.scoreSettings).forEach(key => {
          const elementId = key.replace(/([A-Z])/g, '-$1').toLowerCase();
          const element = document.getElementById(elementId);
          if (element) {
            const value = parseFloat(element.value);
            if (!isNaN(value)) {
