// ユーザー分類グラフの初期化
function initializeUserClassificationChart() {
  if (typeof Chart === 'undefined') {
    setTimeout(initializeUserClassificationChart, 100);
    return;
  }
  
  const ctx = document.getElementById('userClassificationChart');
  if (!ctx) return;
  
  // 既存チャートを破棄
  if (chartInstances.userClassification) {
    chartInstances.userClassification.destroy();
  }
  
  // AJAX で response_data を取得
  const videoId = <%= @video.id %>;
  
  Promise.all([
    // scoreTimelineData が未ロードの場合は fetch
    window.scoreTimelineData ? Promise.resolve(window.scoreTimelineData) :
      fetch(`/video_management/get_chart_data?video_id=${videoId}&chart_type=score_timeline`)
        .then(response => {
          if (!response.ok) throw new Error(`HTTP ${response.status} from scoreTimeline fetch`);
          return response.json();
        })
        .then(result => result.data || [])
        .catch(error => {
          console.error('[分類グラフ初期化] scoreTimeline AJAX エラー:', error);
          return [];  // エラー時は空配列を返す
        }),
    // responseData を fetch（チャンク読 込対応）
    fetch(`/video_management/get_chart_data?video_id=${videoId}&chart_type=response_data&response_page=0`)
      .then(response => {
        if (!response.ok) throw new Error(`HTTP ${response.status} from response_data fetch`);
        return response.json();
      })
      .then(result => {
        console.log('[分類グラフ初期化] responseData 取得（ページ 1）:', result.pagination);
        // チャンク読 込対応：複数ページを統合
        if (result.pagination && result.pagination.has_next) {
          return loadResponseDataChunks(result.data || [], result.pagination, videoId);
        }
        return result.data || [];
      })
      .catch(error => {
        console.error('[分類グラフ初期化] responseData AJAX エラー:', error);
        return [];  // エラー時は空配列を返す
      })
  ])
  .then(([scoreTimelineData, responseData]) => {
    window.scoreTimelineData = scoreTimelineData;
    window.responseData = responseData;
    
    console.log('[分類グラフ初期化] データ AJAX 取得完了:', {
      scoreTimelineDataLength: scoreTimelineData.length,
      responseDataLength: responseData.length,
      scoreTimelineData: scoreTimelineData.slice(0, 2),
      responseData: responseData.slice(0, 2)
    });
    
    initializeUserClassificationChartInternal(ctx, scoreTimelineData, responseData);
  })
  .catch(error => {
    console.error('[分類グラフ初期化] AJAX エラー:', error);
    alert('ユーザー分類グラフのデータ取得に失敗しました: ' + error.message);
  });
}

// ユーザー分類グラフ初期化の本体
function initializeUserClassificationChartInternal(ctx, scoreTimelineData, responseData) {
  console.log('[分類グラフ初期化] responseData:', {
    型: typeof responseData,
    isArray: Array.isArray(responseData),
    長さ: responseData ? responseData.length : 'null',
    最初の要素: responseData && responseData[0] ? responseData[0] : 'なし',
    JSON文字列: JSON.stringify(responseData).substring(0, 500)
  });
  
  // 既存のチャートインスタンスがあれば破棄
  if (chartInstances.userClassification) {
    try {
      chartInstances.userClassification.destroy();
      chartInstances.userClassification = null;
    } catch (e) {
      console.warn('[分類グラフ] 既存チャートの破棄エラー:', e.message);
    }
  }
  
  // ユーザー分類を保持するオブジェクト
  window.userClassifications = {
    groupA: [],
    groupB: [],
    groupC: [],
    groupD: []
  };
  
  // ユーザーIDとセッションIDのマッピング
  window.sessionUserMap = {};
  scoreTimelineData.forEach(session => {
    window.sessionUserMap[session.session_id] = {
      user_id: session.user_id,
      label: session.label
    };
  });
  
  // デフォルトカラー定義（グループごと）
  const groupColors = {
    groupA: 'rgba(13, 110, 253, 0.6)',   // 青
    groupB: 'rgba(40, 167, 69, 0.6)',    // 緑
    groupC: 'rgba(255, 193, 7, 0.6)',    // 黄
    groupD: 'rgba(220, 53, 69, 0.6)'     // 赤
  };
  
  const lineColor = 'rgba(128, 128, 128, 0.3)'; // グレー（未分類）
  
  // グラフ用のデータセットを作成
  const datasets = [];
  
  scoreTimelineData.forEach((session, sessionIndex) => {
    const sessionData = session.data.map(point => ({
      x: point.x,
      y: point.video_time || 0,
      score: point.y,
      video_time: point.video_time,
      color: '#999'
    }));
    
    datasets.push({
      label: session.label,
      data: sessionData,
      borderColor: lineColor,
      borderWidth: 2,
      showLine: true,
      tension: 0,
      pointRadius: 2,
      pointHoverRadius: 5,
      pointBackgroundColor: '#999',
      pointBorderColor: '#999',
      order: 2,
      sessionId: session.session_id,
      userId: session.user_id,
      classification: null // 分類状態を保持
    });
  });
  
  // グラフを作成する前にcanvas要素が有効か確認
  if (!ctx) {
    const canvasElement = document.getElementById('userClassificationChart');
    if (!canvasElement) {
      console.warn('[分類グラフ] Canvas要素が見つかりません');
      return;
    }
    ctx = canvasElement.getContext('2d');
  }
  
  // グラフを作成
  chartInstances.userClassification = new Chart(ctx, {
    type: 'scatter',
    data: { datasets },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        x: {
          type: 'linear',
          title: {
            display: true,
            text: 'セッション経過時間（秒）'
          },
          ticks: {
            callback: function(value) {
              const minutes = Math.floor(value / 60);
              const seconds = Math.floor(value % 60);
              return `${minutes}:${seconds.toString().padStart(2, '0')}`;
            }
          }
        },
        y: {
          type: 'linear',
          title: {
            display: true,
            text: '動画再生時間（秒）'
          },
          ticks: {
            callback: function(value) {
              const minutes = Math.floor(value / 60);
              const seconds = Math.floor(value % 60);
              return `${minutes}:${seconds.toString().padStart(2, '0')}`;
            }
          }
        }
      },
      plugins: {
        legend: {
          display: true,
          position: 'top'
        }
      }
    }
  });
  
  // クリックイベントを登録
  const canvasElement = ctx.canvas || document.getElementById('userClassificationChart');
  canvasElement.addEventListener('click', function(event) {
    const points = chartInstances.userClassification.getElementsAtEventForMode(event, 'nearest', { intersect: true }, true);
    if (points.length > 0) {
      classifyUserSession(points[0].datasetIndex);
    }
  });
}

// ユーザーをグループに分類
function classifyUserSession(datasetIndex) {
  const selectedGroup = document.querySelector('input[name="classificationGroup"]:checked').value;
  const dataset = chartInstances.userClassification.data.datasets[datasetIndex];
  
  if (!dataset) return;
  
  const sessionId = dataset.sessionId;
  const groupColors = {
    groupA: 'rgba(13, 110, 253, 0.8)',   // 青
    groupB: 'rgba(40, 167, 69, 0.8)',    // 緑
    groupC: 'rgba(255, 193, 7, 0.8)',    // 黄
    groupD: 'rgba(220, 53, 69, 0.8)'     // 赤
  };
  
  // 既に同じグループに分類されている場合は、分類を解除
  if (dataset.classification === selectedGroup) {
    console.log(`セッション ${sessionId} を ${selectedGroup} から削除しました`);
    
    // 分類を解除
    const index = window.userClassifications[selectedGroup].indexOf(sessionId);
    if (index > -1) {
      window.userClassifications[selectedGroup].splice(index, 1);
    }
    
    // グラフ表示をリセット
    dataset.classification = null;
    dataset.borderColor = 'rgba(128, 128, 128, 0.3)';
    dataset.borderWidth = 2;
    dataset.pointBackgroundColor = '#999';
    dataset.pointBorderColor = '#999';
    dataset.pointRadius = 2;
  } else {
    // 前の分類から外す
    if (dataset.classification) {
      const oldGroup = dataset.classification;
      const oldIndex = window.userClassifications[oldGroup].indexOf(sessionId);
      if (oldIndex > -1) {
        window.userClassifications[oldGroup].splice(oldIndex, 1);
      }
    }
    
    // 新しいグループに追加
    if (!window.userClassifications[selectedGroup].includes(sessionId)) {
      window.userClassifications[selectedGroup].push(sessionId);
    }
    
    // 分類状態を更新
    dataset.classification = selectedGroup;
    dataset.borderColor = groupColors[selectedGroup];
    dataset.borderWidth = 3;
    dataset.pointBackgroundColor = groupColors[selectedGroup];
    dataset.pointBorderColor = groupColors[selectedGroup];
    dataset.pointRadius = 3;
    
    console.log(`セッション ${sessionId} を ${selectedGroup} に分類しました`);
  }
  
  // チャート更新
  chartInstances.userClassification.update('none');
  
  // 統計を表示
  updateClassificationStats();
}

// 分類結果をリセット
function resetUserClassification() {
  if (!confirm('分類をすべてリセットしていいですか？')) {
    return;
  }
  
  window.userClassifications = {
    groupA: [],
    groupB: [],
    groupC: [],
    groupD: []
  };
  
  const lineColor = 'rgba(128, 128, 128, 0.3)' ;
  
  chartInstances.userClassification.data.datasets.forEach(dataset => {
    dataset.classification = null;
    dataset.borderColor = lineColor;
    dataset.borderWidth = 2;
    dataset.pointBackgroundColor = '#999';
    dataset.pointBorderColor = '#999';
    dataset.pointRadius = 2;
  });
  
  chartInstances.userClassification.update('none');
  
  document.getElementById('classificationStats').innerHTML = '';
}

// 分類ごとの統計を計算・表示
function updateClassificationStats() {
  const responseData = window.responseData || [];
  
  // responseDataが存在しないか空の場合は処理をスキップ
  if (!responseData || responseData.length === 0) {
    console.warn('回答データが利用できません', responseData);
    return;
  }
  
  console.log('[分類統計] 全回答データ:', {
    総数: responseData.length,
    セッション数: [...new Set(responseData.map(r => r.session_id))].length,
    サンプル: responseData.slice(0, 3)
  });
  
  const statsContainer = document.getElementById('classificationStats');
  
  const groupLabels = {
    groupA: 'グループA',
    groupB: 'グループB',
    groupC: 'グループC',
    groupD: 'グループD'
  };
  
  const groupBgColors = {
    groupA: '#007bff',
    groupB: '#28a745',
    groupC: '#ffc107',
    groupD: '#dc3545'
  };
  
  let html = '';
  
  Object.keys(window.userClassifications).forEach(group => {
    const sessionIds = window.userClassifications[group];
    
    if (sessionIds.length === 0) {
      html += `
        <div class="col-md-6 col-lg-3 mb-3">
          <div class="card" style="border-left: 4px solid ${groupBgColors[group]}">
            <div class="card-body">
              <h6 class="card-title">${groupLabels[group]}</h6>
              <p class="text-muted">分類なし</p>
            </div>
          </div>
        </div>
      `;
      return;
    }
    
    // このグループのセッションに関連する回答データを集計
    const groupResponses = responseData.filter(r => sessionIds.includes(r.session_id));
    
    console.log(`[分類統計] グループ ${group}:`, {
      セッション数: sessionIds.length,
      セッションIDs: sessionIds,
      型チェック: sessionIds.map(id => typeof id),
      該当回答数: groupResponses.length,
      回答の型チェック: responseData.slice(0, 1).map(r => ({ session_id: r.session_id, 型: typeof r.session_id })),
      詳細フィルタ: responseData.map(r => ({
        session_id: r.session_id,
        マッチ: sessionIds.includes(r.session_id),
        sessionIdsに含: sessionIds.includes(r.session_id)
      }))
    });
    
    if (groupResponses.length === 0) {
      html += `
        <div class="col-md-6 col-lg-3 mb-3">
          <div class="card" style="border-left: 4px solid ${groupBgColors[group]}">
            <div class="card-body">
              <h6 class="card-title">${groupLabels[group]}</h6>
              <p class="text-muted">セッション数: ${sessionIds.length}</p>
              <p class="text-muted">回答なし</p>
            </div>
          </div>
        </div>
      `;
      return;
    }
    
    // 統計計算
    const totalResponses = groupResponses.length;
    const correctResponses = groupResponses.filter(r => r.correct).length;
    const correctRate = ((correctResponses / totalResponses) * 100).toFixed(1);
    const avgResponseTime = (groupResponses.reduce((sum, r) => sum + (r.response_time || 0), 0) / totalResponses / 1000).toFixed(1);
    const avgResponsesPerSession = (totalResponses / sessionIds.length).toFixed(1);
    
    html += `
      <div class="col-md-6 col-lg-3 mb-3">
        <div class="card" style="border-left: 4px solid ${groupBgColors[group]}">
          <div class="card-body">
            <h6 class="card-title">${groupLabels[group]}</h6>
            <dl class="small mb-0">
              <dt>セッション数</dt>
              <dd>${sessionIds.length}件</dd>
              <dt>回答数</dt>
              <dd>${totalResponses}件</dd>
              <dt>平均回答数</dt>
              <dd><strong>${avgResponsesPerSession}回/セッション</strong></dd>
              <dt>正解数</dt>
              <dd>${correctResponses}件</dd>
              <dt>正解率</dt>
              <dd><strong style="color: ${groupBgColors[group]}">${correctRate}%</strong></dd>
              <dt>平均回答時間</dt>
              <dd>${avgResponseTime}秒</dd>
            </dl>
          </div>
        </div>
      </div>
    `;
  });
  
  statsContainer.innerHTML = html || '<p class="text-muted">分類したユーザーがありません</p>';
}

// Tab切り替え時に初期化
document.addEventListener('shown.bs.tab', function(e) {
  if (e.target.id === 'user-classification-tab') {
    initializeUserClassificationChart();
  }
});

// 初回読み込みとTurbo遷移の両方で実行
// DOMContentLoadedは通常のページ読み込み用
document.addEventListener('DOMContentLoaded', function() {
  // ページが完全に読み込まれるまで少し待機
  setTimeout(initializeAnalyticsCharts, 50);
});

// turbo:loadはTurbo遷移時用
document.addEventListener('turbo:load', function() {
  // Turbo遷移後も少し待機してからチャートを初期化
  setTimeout(initializeAnalyticsCharts, 50);
});

// turbo:renderはTurbo遷移のレンダリング完了時用（より確実）
document.addEventListener('turbo:render', function() {
  setTimeout(initializeAnalyticsCharts, 50);
});

// Turbo遷移前にチャートをクリーンアップ
document.addEventListener('turbo:before-render', function() {
  // 保持しているチャートインスタンスを破棄
  Object.keys(chartInstances).forEach(key => {
    try {
      if (chartInstances[key]) {
        chartInstances[key].destroy();
        delete chartInstances[key];
      }
    } catch (e) {
      console.error(`[Turbo] ${key} チャート破棄エラー:`, e);
    }
  });
});

// Turboキャッシュ前にチャートを完全にクリア
document.addEventListener('turbo:before-cache', function() {
  console.log('[Turbo キャッシュ] チャートをクリアします');
  isInitializingCharts = false;
  chartsInitialized = false;
  otherChartsInitialized = false;  // 他のチャート初期化フラグもリセット
  // 保持しているチャートインスタンスを破棄
  Object.keys(chartInstances).forEach(key => {
    try {
      if (chartInstances[key]) {
        chartInstances[key].destroy();
        delete chartInstances[key];
      }
    } catch (e) {
      console.error(`[Turbo キャッシュ] ${key} チャート破棄エラー:`, e);
    }
  });
  chartInstances = {};
});
<% end %>
</script>
