<div class="container">
  <div class="row">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><%= @video.title %> - 受講状況分析</h1>
        <div>
          <%= link_to "管理者追加", video_management_add_manager_path(video_id: @video), class: "btn btn-outline-primary" %>
          <%= link_to "動画編集", edit_video_path(@video), class: "btn btn-primary" %>
          <%= link_to "戻る", root_path, class: "btn btn-secondary" %>
        </div>
      </div>

      <!-- CSVエクスポートボタン -->
      <div class="card mb-4">
        <div class="card-body">
          <h5 class="card-title">📊 データエクスポート</h5>
          <p class="text-muted mb-3">分析データをCSV形式でダウンロードできます（個別セッションは学習セッション履歴から）</p>
          <div class="row">
            <div class="col-md-6 mb-2">
              <%= link_to video_management_export_summary_path(video_id: @video, format: :csv), class: "btn btn-success w-100", data: { turbo: false } do %>
                <i class="bi bi-file-earmark-spreadsheet"></i> 全体サマリー
              <% end %>
              <small class="text-muted d-block mt-1">動画全体の統計情報</small>
            </div>
            <div class="col-md-6 mb-2">
              <%= link_to video_management_export_questions_path(video_id: @video, format: :csv), class: "btn btn-success w-100", data: { turbo: false } do %>
                <i class="bi bi-file-earmark-spreadsheet"></i> 問題別統計
              <% end %>
              <small class="text-muted d-block mt-1">各問題の回答統計</small>
            </div>
          </div>
        </div>
      </div>

      <!-- 全体統計 -->
      <div class="row mb-4">
        <div class="col-md-3">
          <div class="card text-center">
            <div class="card-body">
              <h5 class="card-title">総回答数</h5>
              <h2 class="text-primary"><%= @total_responses %></h2>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card text-center">
            <div class="card-body">
              <h5 class="card-title">受講者数</h5>
              <h2 class="text-info"><%= @unique_users %></h2>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card text-center">
            <div class="card-body">
              <h5 class="card-title">正解数</h5>
              <h2 class="text-success"><%= @correct_responses %></h2>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card text-center">
            <div class="card-body">
              <h5 class="card-title">正答率</h5>
              <h2 class="text-warning"><%= @accuracy_rate %>%</h2>
            </div>
          </div>
        </div>
      </div>

      <!-- 問題別統計 -->
      <div class="card mb-4">
        <div class="card-header">
          <h3>問題別統計</h3>
        </div>
        <div class="card-body">
          <% if @question_stats.any? %>
            <div class="table-responsive">
              <table class="table table-striped">
                <thead>
                  <tr>
                    <th>問題</th>
                    <th>タイプ</th>
                    <th>時間位置</th>
                    <th>回答数</th>
                    <th>正解数</th>
                    <th>正答率</th>
                    <th>平均回答時間</th>
                  </tr>
                </thead>
                <tbody>
                  <% @question_stats.each do |stat| %>
                    <tr>
                      <td><%= truncate(stat[:question].content, length: 50) %></td>
                      <td>
                        <span class="badge <%= question_type_badge_class(stat[:question].question_type) %>">
                          <%= question_type_display(stat[:question].question_type) %>
                        </span>
                      </td>
                      <td><%= format_time_position(stat[:question].time_position) %></td>
                      <td><%= stat[:total_responses] %></td>
                      <td><%= stat[:correct_responses] %></td>
                      <td>
                        <% if stat[:accuracy_rate] >= 80 %>
                          <span class="text-success"><%= stat[:accuracy_rate] %>%</span>
                        <% elsif stat[:accuracy_rate] >= 60 %>
                          <span class="text-warning"><%= stat[:accuracy_rate] %>%</span>
                        <% else %>
                          <span class="text-danger"><%= stat[:accuracy_rate] %>%</span>
                        <% end %>
                      </td>
                      <td><%= stat[:average_response_time] %>秒</td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="text-muted">この動画には問題がありません。</p>
          <% end %>
        </div>
      </div>

      <!-- タイムラインデータ可視化グラフ -->
      <% if @learning_sessions && @learning_sessions.any? %>
        <div class="card mb-4">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h3 class="mb-0">学習タイムライン分析グラフ</h3>
            <small class="text-muted">💡 マウスホイールでズーム、ドラッグで移動、ダブルクリックでリセット</small>
          </div>
          <div class="card-body">
            <!-- グラフナビゲーション -->
            <ul class="nav nav-tabs mb-3" id="chartTabs" role="tablist">
              <li class="nav-item" role="presentation">
                <button class="nav-link active" id="score-timeline-tab" data-bs-toggle="tab" data-bs-target="#score-timeline" type="button">
                  集中スコア推移
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="hourly-activity-tab" data-bs-toggle="tab" data-bs-target="#hourly-activity" type="button">
                  時間帯別活動
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="user-scores-tab" data-bs-toggle="tab" data-bs-target="#user-scores" type="button">
                  ユーザー別スコア
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="video-density-tab" data-bs-toggle="tab" data-bs-target="#video-density" type="button">
                  動画イベント密度
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="video-operations-tab" data-bs-toggle="tab" data-bs-target="#video-operations" type="button">
                  動画操作マップ
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="user-operations-tab" data-bs-toggle="tab" data-bs-target="#user-operations" type="button">
                  ユーザー別操作
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="user-classification-tab" data-bs-toggle="tab" data-bs-target="#user-classification" type="button">
                  ユーザー分類分析
                </button>
              </li>
            </ul>

            <!-- グラフコンテンツ -->
            <div class="tab-content" id="chartTabsContent">
              <!-- 1. 集中スコア推移グラフ -->
              <div class="tab-pane fade show active" id="score-timeline" role="tabpanel">
                <div class="mb-3">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <button class="btn btn-sm btn-outline-info" type="button" data-bs-toggle="collapse" data-bs-target="#scoreTimelineTogglesCollapse" aria-expanded="true">
                      <i class="bi bi-chevron-down"></i> 表示するセッション
                    </button>
                    <div>
                      <button class="btn btn-sm btn-outline-primary" onclick="toggleAllSessions('scoreTimeline', true)">すべて表示</button>
                      <button class="btn btn-sm btn-outline-secondary" onclick="toggleAllSessions('scoreTimeline', false)">すべて非表示</button>
                    </div>
                  </div>
                  <div class="collapse show" id="scoreTimelineTogglesCollapse">
                    <div id="scoreTimelineSessionToggles" class="row"></div>
                  </div>
                  
                  <!-- ユーザーごとに色分けするトグル -->
                  <div class="mt-3 mb-3">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" id="colorByUserToggle" onchange="toggleColorByUser()">
                      <label class="form-check-label" for="colorByUserToggle">
                        <strong>ユーザーごとに色分け</strong>
                      </label>
                      <small class="text-muted d-block ms-4">セッションの線の色をユーザーで変更します（オフ時はスコア基準）</small>
                    </div>
                  </div>
                  
                  <!-- マーカーを非表示にするトグル -->
                  <div class="mt-3 mb-3">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" id="hideMarkersToggle" onchange="toggleMarkerVisibility()">
                      <label class="form-check-label" for="hideMarkersToggle">
                        <strong>マーカーを非表示にする</strong>
                      </label>
                      <small class="text-muted d-block ms-4">動画操作（一時停止、スキップ）と反応速度（回答）のマーカーを非表示にします</small>
                    </div>
                  </div>
                  
                  <!-- 動画時刻0のデータフィルター -->
                  <div class="mt-3 mb-3">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" id="hideVideoTime0" onchange="toggleVideoTime0Filter()">
                      <label class="form-check-label" for="hideVideoTime0">
                        動画時刻0秒のデータを非表示にする
                      </label>
                      <small class="text-muted d-block ms-4">動画が再生される前のデータポイントを除外します</small>
                    </div>
                  </div>
                </div>
                <div class="chart-container" style="position: relative; height: 800px;">
                  <canvas id="scoreTimelineChart"></canvas>
                </div>
                <p class="text-muted mt-2 text-center">
                  <small>各セッションの集中スコアの時間的推移を表示します。セッション経過時間（秒）に対するスコアの変化を確認できます。</small>
                </p>
              </div>

              <!-- 2. 時間帯別活動量グラフ -->
              <div class="tab-pane fade" id="hourly-activity" role="tabpanel">
                <div class="chart-container" style="position: relative; height: 400px;">
                  <canvas id="hourlyActivityChart"></canvas>
                </div>
                <p class="text-muted mt-2 text-center">
                  <small>1日の中でどの時間帯に学習活動が活発かを表示します。</small>
                </p>
              </div>
              
              <script>
                // 時間帯別活動タブクリック時に再度グラフを初期化
                document.getElementById('hourly-activity-tab')?.addEventListener('shown.bs.tab', function() {
                  console.log('[時間帯別活動タブ] クリック検出');
                  if (chartInstances.hourlyActivity) {
                    chartInstances.hourlyActivity.destroy();
                    chartInstances.hourlyActivity = null;
                  }
                  
                  // 再度グラフを初期化
                  if (chartsData && chartsData.hourly_activity_data) {
                    const ctx = document.getElementById('hourlyActivityChart');
                    const hourlyData = chartsData.hourly_activity_data;
                    
                    chartInstances.hourlyActivity = new Chart(ctx, {
                      type: 'bar',
                      data: {
                        labels: hourlyData.labels.map(h => h + '時'),
                        datasets: [{
                          label: 'イベント数',
                          data: hourlyData.values,
                          backgroundColor: 'rgba(54, 162, 235, 0.8)',
                          borderColor: 'rgba(54, 162, 235, 1)',
                          borderWidth: 1
                        }]
                      },
                      options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                          legend: {
                            display: true,
                            position: 'top'
                          }
                        },
                        scales: {
                          x: {
                            title: {
                              display: true,
                              text: '時間帯'
                            }
                          },
                          y: {
                            title: {
                              display: true,
                              text: 'イベント数'
                            },
                            beginAtZero: true,
                            ticks: {
                              stepSize: 1
                            }
                          }
                        }
                      }
                    });
                    console.log('[時間帯別活動タブ] グラフ再初期化完了');
                  }
                });
              </script>

              <!-- 4. ユーザー別平均スコアグラフ -->
              <div class="tab-pane fade" id="user-scores" role="tabpanel">
                <div class="chart-container" style="position: relative; height: 400px;">
                  <canvas id="userScoresChart"></canvas>
                </div>
                <p class="text-muted mt-2 text-center">
                  <small>各ユーザーの平均集中スコアを比較表示します。</small>
                </p>
              </div>
              
              <script>
                // ユーザースコアタブクリック時に再度グラフを初期化
                document.getElementById('user-scores-tab')?.addEventListener('shown.bs.tab', function() {
                  console.log('[ユーザースコアタブ] クリック検出');
                  if (chartInstances.userScores) {
                    chartInstances.userScores.destroy();
                    chartInstances.userScores = null;
                  }
                  
                  // 再度グラフを初期化
                  if (chartsData && chartsData.user_score_data) {
                    const ctx = document.getElementById('userScoresChart');
                    const scoreData = chartsData.user_score_data;
                    
                    chartInstances.userScores = new Chart(ctx, {
                      type: 'bar',
                      data: {
                        labels: scoreData.labels,
                        datasets: [{
                          label: '平均スコア',
                          data: scoreData.values,
                          backgroundColor: 'rgba(255, 159, 64, 0.8)',
                          borderColor: 'rgba(255, 159, 64, 1)',
                          borderWidth: 1
                        }]
                      },
                      options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                          legend: {
                            display: true,
                            position: 'top'
                          }
                        },
                        scales: {
                          x: {
                            title: {
                              display: true,
                              text: 'ユーザー'
                            }
                          },
                          y: {
                            title: {
                              display: true,
                              text: '平均スコア'
                            },
                            beginAtZero: true,
                            max: 100
                          }
                        }
                      }
                    });
                    console.log('[ユーザースコアタブ] グラフ再初期化完了');
                  }
                });
              </script>

              <!-- 5. 動画時間別イベント密度グラフ -->
              <div class="tab-pane fade" id="video-density" role="tabpanel">
                <div class="chart-container" style="position: relative; height: 400px;">
                  <canvas id="videoDensityChart"></canvas>
                </div>
                <p class="text-muted mt-2 text-center">
                  <small>動画のどの部分で学習活動が活発かを30秒単位で表示します。</small>
                </p>
              </div>
              
              <script>
                // 動画密度チャートタブクリック時に再度グラフを初期化
                document.getElementById('video-density-tab')?.addEventListener('shown.bs.tab', function() {
                  console.log('[動画密度タブ] クリック検出');
                  if (chartInstances.videoDensity) {
                    chartInstances.videoDensity.destroy();
                    chartInstances.videoDensity = null;
                  }
                  
                  // 再度グラフを初期化
                  if (chartsData && chartsData.video_time_density_data) {
                    const ctx = document.getElementById('videoDensityChart');
                    const densityData = chartsData.video_time_density_data;
                    
                    chartInstances.videoDensity = new Chart(ctx, {
                      type: 'line',
                      data: {
                        labels: densityData.labels,
                        datasets: [{
                          label: 'イベント数',
                          data: densityData.values,
                          backgroundColor: 'rgba(75, 192, 75, 0.2)',
                          borderColor: 'rgba(75, 192, 75, 1)',
                          borderWidth: 2,
                          tension: 0.1,
                          fill: true
                        }]
                      },
                      options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                          legend: {
                            display: true,
                            position: 'top'
                          }
                        },
                        scales: {
                          x: {
                            title: {
                              display: true,
                              text: '動画時刻（秒）'
                            }
                          },
                          y: {
                            title: {
                              display: true,
                              text: 'イベント集約度'
                            },
                            beginAtZero: true
                          }
                        }
                      }
                    });
                    console.log('[動画密度タブ] グラフ再初期化完了');
                  }
                });
              </script>

              <!-- 6. 動画操作マップ（全体） -->
              <div class="tab-pane fade" id="video-operations" role="tabpanel">
                <div class="mb-3">
                  <label for="operationsMapBins" class="form-label">横軸の分割数: <span id="operationsMapBinsValue">20</span></label>
                  <div class="d-flex align-items-center gap-2">
                    <input type="range" class="form-range" id="operationsMapBins" min="5" max="100" value="20" step="5">
                    <button class="btn btn-sm btn-outline-primary" onclick="updateOperationsMapBins()">更新</button>
                  </div>
                  <small class="text-muted">分割数を調整して、動画を何等分にして集計するかを変更できます。</small>
                </div>
                <div class="chart-container" style="position: relative; height: 400px;">
                  <canvas id="videoOperationsChart"></canvas>
                </div>
                <p class="text-muted mt-2 text-center">
                  <small>動画内のどの時間で一時停止やスキップ（シーク）が行われたかを表示します。棒が高いほど操作が多い箇所です。</small>
                </p>
              </div>

              <!-- 7. ユーザー別動画操作 -->
              <div class="tab-pane fade" id="user-operations" role="tabpanel">
                <div class="mb-3">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <button class="btn btn-sm btn-outline-info" type="button" data-bs-toggle="collapse" data-bs-target="#userOperationsTogglesCollapse" aria-expanded="true">
                      <i class="bi bi-chevron-down"></i> 表示するセッション
                    </button>
                    <div>
                      <button class="btn btn-sm btn-outline-primary" onclick="toggleAllSessions('userOperations', true)">すべて表示</button>
                      <button class="btn btn-sm btn-outline-secondary" onclick="toggleAllSessions('userOperations', false)">すべて非表示</button>
                    </div>
                  </div>
                  <div class="collapse show" id="userOperationsTogglesCollapse">
                    <div id="userOperationsSessionToggles" class="row"></div>
                  </div>
                </div>
                <div class="chart-container" style="position: relative; height: 400px;">
                  <canvas id="userOperationsChart"></canvas>
                </div>
                <p class="text-muted mt-2 text-center">
                  <small>各ユーザーが動画のどの時間で操作を行ったかをセッション別に表示します。</small>
                </p>
              </div>

              <!-- 8. ユーザー分類分析 -->
              <div class="tab-pane fade" id="user-classification" role="tabpanel">
                <div class="mb-3">
                  <div class="alert alert-info">
                    <strong>使い方：</strong>グラフのセッションラインをクリックして、ユーザーをグループに分類してください。
                    <button class="btn btn-sm btn-warning ms-2" onclick="resetUserClassification()">分類をリセット</button>
                  </div>
                  
                  <!-- グループ分類UI -->
                  <div class="mb-3">
                    <label><strong>分類対象グループ:</strong></label>
                    <div class="btn-group" role="group">
                      <input type="radio" class="btn-check" name="classificationGroup" id="groupA" value="groupA" checked>
                      <label class="btn btn-outline-primary" for="groupA">グループA</label>
                      
                      <input type="radio" class="btn-check" name="classificationGroup" id="groupB" value="groupB">
                      <label class="btn btn-outline-success" for="groupB">グループB</label>
                      
                      <input type="radio" class="btn-check" name="classificationGroup" id="groupC" value="groupC">
                      <label class="btn btn-outline-warning" for="groupC">グループC</label>
                      
                      <input type="radio" class="btn-check" name="classificationGroup" id="groupD" value="groupD">
                      <label class="btn btn-outline-danger" for="groupD">グループD</label>
                    </div>
                  </div>

                  <!-- マーカー非表示トグル -->
                  <div class="mt-3 mb-3">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" id="hideMarkersClassificationToggle" onchange="toggleMarkerVisibilityClassification()">
                      <label class="form-check-label" for="hideMarkersClassificationToggle">
                        <strong>マーカーを非表示にして線だけ表示</strong>
                      </label>
                      <small class="text-muted d-block ms-4">セッションラインのマーカー（ポイント）を非表示にエシステムを簡潔にします</small>
                    </div>
                  </div>

                  <!-- グラフ領域 -->
                  <div class="chart-container" style="position: relative; height: 400px; border: 2px dashed #ccc; padding: 10px; border-radius: 5px;">
                    <canvas id="userClassificationChart"></canvas>
                  </div>
                </div>

                <!-- 分類結果・統計表 -->
                <div class="mt-4">
                  <h5>分類結果と統計</h5>
                  <div id="classificationStats" class="row"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <!-- 学習セッション統計 -->
      <div class="row mb-4">
        <div class="col-md-3">
          <div class="card text-center">
            <div class="card-body">
              <h5 class="card-title">総学習セッション</h5>
              <h2 class="text-primary"><%= @total_sessions %></h2>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card text-center">
            <div class="card-body">
              <h5 class="card-title">完了セッション</h5>
              <h2 class="text-success"><%= @completed_sessions %></h2>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card text-center">
            <div class="card-body">
              <h5 class="card-title">平均学習時間</h5>
              <h2 class="text-info">
                <% if @average_session_duration && @average_session_duration > 0 %>
                  <%= (@average_session_duration / 60).round(1) %>分
                <% else %>
                  -
                <% end %>
              </h2>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card text-center">
            <div class="card-body">
              <h5 class="card-title">平均最終スコア</h5>
              <h2 class="text-warning">
                <% if @average_final_score %>
                  <%= @average_final_score.round(1) %>点
                <% else %>
                  -
                <% end %>
              </h2>
            </div>
          </div>
        </div>
      </div>

      <!-- 動画操作統計（1分以上のセッション平均） -->
      <div class="card mb-4">
        <div class="card-header">
          <h3>動画操作統計 <small class="text-muted">(1分以上のセッション平均)</small></h3>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-md-3">
              <div class="card text-center">
                <div class="card-body">
                  <h5 class="card-title">⏸️ 一時停止</h5>
                  <h2 class="text-warning"><%= @avg_pause_count %></h2>
                  <p class="text-muted">回/セッション</p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card text-center">
                <div class="card-body">
                  <h5 class="card-title">⏩ 前進スキップ</h5>
                  <h2 class="text-primary"><%= @avg_forward_seek_count %></h2>
                  <p class="text-muted">回/セッション</p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card text-center">
                <div class="card-body">
                  <h5 class="card-title">⏪ 後退スキップ</h5>
                  <h2 class="text-info"><%= @avg_backward_seek_count %></h2>
                  <p class="text-muted">回/セッション</p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card text-center">
                <div class="card-body">
                  <h5 class="card-title">⚡ 再生速度変更</h5>
                  <h2 class="text-success"><%= @avg_playback_rate_change_count %></h2>
                  <p class="text-muted">回/セッション</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 学習セッション一覧 -->
      <div class="card mb-4">
        <div class="card-header">
          <h3>学習セッション履歴</h3>
        </div>
        <div class="card-body">
          <% if @learning_sessions.any? %>
            <div class="table-responsive">
              <table class="table table-striped">
                <thead>
                  <tr>
                    <th>受講者</th>
                    <th>開始時刻</th>
                    <th>終了時刻</th>
                    <th>学習時間</th>
                    <th>最終スコア</th>
                    <th>イベント数</th>
                    <th title="一時停止回数">⏸️</th>
                    <th title="前進スキップ回数">⏩</th>
                    <th title="後退スキップ回数">⏪</th>
                    <th title="再生速度変更回数">⚡</th>
                    <th>エクスポート</th>
                    <th>詳細</th>
                    <th>操作</th>
                  </tr>
                </thead>
                <tbody>
                  <% @learning_sessions.each do |session| %>
                    <% operation_stats = session.video_operation_stats %>
                    <tr>
                      <td>
                        <%= session.user.name %>
                        <br><small class="text-muted"><%= session.user.email %></small>
                      </td>
                      <td><%= session.session_start_time.strftime("%Y/%m/%d %H:%M") %></td>
                      <td>
                        <% if session.session_end_time %>
                          <%= session.session_end_time.strftime("%Y/%m/%d %H:%M") %>
                        <% else %>
                          <span class="text-warning">進行中</span>
                        <% end %>
                      </td>
                      <td><%= session.format_duration %></td>
                      <td>
                        <% if session.final_score %>
                          <span class="badge <%= session.final_score >= 70 ? 'bg-success' : session.final_score >= 50 ? 'bg-warning' : 'bg-danger' %>">
                            <%= session.final_score.round(1) %>点
                          </span>
                        <% else %>
                          -
                        <% end %>
                      </td>
                      <td><%= session.total_events || session.timestamp_events.count %></td>
                      <td class="text-center"><%= operation_stats[:pause_count] %></td>
                      <td class="text-center"><%= operation_stats[:forward_seek_count] %></td>
                      <td class="text-center"><%= operation_stats[:backward_seek_count] %></td>
                      <td class="text-center"><%= operation_stats[:playback_rate_change_count] %></td>
                      <td>
                        <div class="btn-group-vertical btn-group-sm">
                          <%= link_to "📊", video_management_export_session_detail_path(video_id: @video, session_id: session.id, format: :csv), 
                              class: "btn btn-sm btn-outline-success", 
                              title: "セッション詳細CSV",
                              data: { turbo: false } %>
                          <%= link_to "📝", video_management_export_session_events_path(video_id: @video, session_id: session.id, format: :csv), 
                              class: "btn btn-sm btn-outline-success", 
                              title: "イベントタイムラインCSV",
                              data: { turbo: false } %>
                        </div>
                      </td>
                      <td>
                        <button class="btn btn-sm btn-primary" onclick="showSessionDetail(<%= session.id %>)">
                          タイムライン表示
                        </button>
                      </td>
                      <td>
                        <%= button_to "削除", 
                            video_management_destroy_session_path(video_id: @video, session_id: session.id), 
                            method: :delete, 
                            class: "btn btn-sm btn-danger",
                            data: { 
                              turbo_confirm: "本当にこのセッション（#{session.user.name}、#{session.session_start_time.strftime('%Y/%m/%d %H:%M')}）を削除しますか？関連するすべてのイベントデータも削除されます。" 
                            },
                            form: { style: "display: inline-block;" } %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="text-muted">まだ学習セッションがありません。</p>
          <% end %>
        </div>
      </div>

      <!-- 詳細な回答履歴 -->
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h3 class="mb-0">回答履歴</h3>
          <button class="btn btn-danger btn-sm" onclick="deleteSelectedResponses()">
            <i class="bi bi-trash"></i> 選択した回答を削除
          </button>
        </div>
        <div class="card-body">
          <% if @user_responses.any? %>
            <div class="table-responsive">
              <table class="table table-striped table-sm">
                <thead>
                  <tr>
                    <th>
                      <input type="checkbox" id="selectAllResponses" onchange="toggleAllResponses(this.checked)">
                    </th>
                    <th>受講者</th>
                    <th>問題</th>
                    <th>回答</th>
                    <th>正誤</th>
                    <th>回答時間</th>
                    <th>回答日時</th>
                  </tr>
                </thead>
                <tbody>
                  <% @user_responses.each do |response| %>
                    <tr id="response-<%= response.id %>">
                      <td>
                        <input type="checkbox" class="response-checkbox" value="<%= response.id %>">
                      </td>
                      <td>
                        <% if response.user %>
                          <%= response.user.name %>
                          <br><small class="text-muted"><%= response.user.email %></small>
                        <% else %>
                          <em>ゲストユーザー</em>
                        <% end %>
                      </td>
                      <td><%= truncate(response.question.content, length: 40) %></td>
                      <td><%= truncate(response.user_answer, length: 30) %></td>
                      <td>
                        <% if response.is_correct %>
                          <span class="badge bg-success">正解</span>
                        <% else %>
                          <span class="badge bg-danger">不正解</span>
                        <% end %>
                      </td>
                      <td>
                        <% if response.response_time %>
                          <%= (response.response_time / 1000.0).round(1) %>秒
                        <% else %>
                          -
                        <% end %>
                      </td>
                      <td><%= response.created_at.strftime("%Y/%m/%d %H:%M") %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="text-muted">まだ回答がありません。</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- セッション詳細モーダル -->
<div class="modal fade" id="sessionDetailModal" tabindex="-1">
  <div class="modal-dialog modal-xl">
    <div class="modal-content">
      <div class="modal-header">
        <div>
          <h5 class="modal-title">学習セッション詳細タイムライン</h5>
          <small class="text-muted">💡 マウスホイールでズーム、ドラッグで移動、ダブルクリックでリセット</small>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <!-- グラフエリア -->
        <div id="chartContainer" style="position: relative; height: 600px; margin-bottom: 20px;">
          <canvas id="timelineChart"></canvas>
        </div>
        
        <!-- タイムスタンプログ -->
        <div class="mt-4">
          <h6>詳細イベントログ</h6>
          <div id="timestampLog" style="max-height: 300px; overflow-y: auto;">
            <!-- JavaScriptで動的に生成 -->
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/hammerjs@2.0.8"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.0.1/dist/chartjs-plugin-zoom.min.js"></script>
<style>
  .timestamp-entry {
    padding: 8px;
    margin-bottom: 4px;
    border-left: 3px solid #007bff;
    background-color: #f8f9fa;
    border-radius: 4px;
  }
  
  .timestamp-entry.score-event {
    border-left-color: #28a745;
  }
  
  .timestamp-entry.video-event {
    border-left-color: #ffc107;
  }
  
  .timestamp-entry.interaction-event {
    border-left-color: #17a2b8;
  }
  
  .timestamp-header {
    display: flex;
    justify-content: space-between;
    font-weight: bold;
    margin-bottom: 4px;
  }
  
  .timestamp-description {
    font-size: 0.9em;
    color: #6c757d;
  }
  
  /* トグルボタンのアイコン回転アニメーション */
  [data-bs-toggle="collapse"] i.bi-chevron-down {
    transition: transform 0.3s ease;
  }
  
  [data-bs-toggle="collapse"][aria-expanded="false"] i.bi-chevron-down {
    transform: rotate(-90deg);
  }
</style>

<script>
// グローバルスコープ汚染を避けるための即時実行関数
(function() {
  'use strict';
  
  // トグルボタンのアイコン回転制御
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('[data-bs-toggle="collapse"]').forEach(button => {
      const targetId = button.getAttribute('data-bs-target');
      const target = document.querySelector(targetId);
      
      if (target) {
        target.addEventListener('show.bs.collapse', function() {
          button.setAttribute('aria-expanded', 'true');
        });
        
        target.addEventListener('hide.bs.collapse', function() {
          button.setAttribute('aria-expanded', 'false');
        });
      }
    });
  });
  
  let sessionDetailChart = null;

  window.showSessionDetail = function(sessionId) {
    // モーダルを表示
    const modalElement = document.getElementById('sessionDetailModal');
    const modal = new bootstrap.Modal(modalElement);
    
    // モーダルが完全に表示された後にデータを取得
    modalElement.addEventListener('shown.bs.modal', function onShown() {
      // イベントリスナーを一度だけ実行
      modalElement.removeEventListener('shown.bs.modal', onShown);
      
      // セッションデータを取得
      const url = '<%= video_management_session_detail_path(video_id: @video, session_id: 'PLACEHOLDER') %>'.replace('PLACEHOLDER', sessionId);
      console.log('Fetching session data from:', url);
      
      fetch(url, {
        headers: {
          'X-Requested-With': 'XMLHttpRequest',
          'Accept': 'application/json'
        }
      })
      .then(response => {
        console.log('Response status:', response.status);
        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }
        return response.json();
      })
      .then(data => {
        console.log('セッションデータ:', data);
        renderChart(data);
        renderTimestampLog(data);
      })
      .catch(error => {
        console.error('セッションデータ取得エラー:', error);
        alert('セッションデータの取得に失敗しました: ' + error.message);
      });
    });
    
    modal.show();
  };

  function renderChart(data) {
    const ctx = document.getElementById('timelineChart');
    if (!ctx) {
      console.error('timelineChart canvas が見つかりません');
      return;
    }
    
    console.log('グラフ描画開始:', data);
    
    // データが空の場合
    if (!data.timeline || data.timeline.length === 0) {
      console.warn('タイムラインデータが空です');
      ctx.parentElement.innerHTML = '<p class="text-muted text-center">このセッションにはタイムラインデータがありません</p>';
      return;
    }
    
    // 既存のチャートを削除
    if (sessionDetailChart) {
      sessionDetailChart.destroy();
    }
    
    try {
      // 集中度スコアで色を決定する関数
      const getColorByScore = (score) => {
        if (score <= 25) return '#dc3545'; // 赤
        if (score <= 50) return '#fd7e14'; // オレンジ
        if (score <= 75) return '#ffc107'; // 黄色
        return '#28a745'; // 緑
      };
      
      // タイムラインデータを時系列順に並べ、各点に色情報を追加
      const timelineData = data.timeline.map(e => ({
        x: e.x,
        y: e.video_time || 0,
        score: e.y,
        description: e.description,
        color: getColorByScore(e.y)
      }));
      
      // 動画操作イベントをスキップと停止に分類
      const skipOpsData = (data.video_operations || []).filter(op => 
        op.operation.includes('skip') || op.operation.includes('seek') || op.description.includes('スキップ') || op.description.includes('シーク')
      ).map(op => ({
        x: op.time,
        y: op.video_time || 0,
        description: op.description,
        operation: op.operation
      }));
      
      const pauseOpsData = (data.video_operations || []).filter(op => 
        op.operation.includes('pause') || op.operation.includes('stop') || op.description.includes('停止') || op.description.includes('一時停止')
      ).map(op => ({
        x: op.time,
        y: op.video_time || 0,
        description: op.description,
        operation: op.operation
      }));
      
      // その他の動画操作
      const otherOpsData = (data.video_operations || []).filter(op => 
        !op.operation.includes('skip') && !op.operation.includes('seek') && 
        !op.operation.includes('pause') && !op.operation.includes('stop') &&
        !op.description.includes('スキップ') && !op.description.includes('シーク') &&
        !op.description.includes('停止') && !op.description.includes('一時停止')
      ).map(op => ({
        x: op.time,
        y: op.video_time || 0,
        description: op.description,
        operation: op.operation
      }));
      
      // ユーザーインタラクション（問題回答、メモなど）
      const interactionsData = (data.interactions || []).map(i => ({
        x: i.time,
        y: i.video_time || 0,
        description: i.description,
        type: i.type
      }));
      
      // 反応速度マーカー（ピンク系の色）
      const quickResponseData = (data.response_markers?.quick || []).map(r => ({
        x: r.time,
        y: r.video_time || 0,
        description: r.description
      }));
      
      const normalResponseData = (data.response_markers?.normal || []).map(r => ({
        x: r.time,
        y: r.video_time || 0,
        description: r.description
      }));
      
      const slowResponseData = (data.response_markers?.slow || []).map(r => ({
        x: r.time,
        y: r.video_time || 0,
        description: r.description
      }));
      
      const datasets = [
        // 凡例用のダミーデータセット（最初に配置して凡例の順序を制御）
        { label: '集中度: 0-25 (低)', data: [], borderColor: '#dc3545', backgroundColor: '#dc3545', pointRadius: 5 },
        { label: '集中度: 26-50', data: [], borderColor: '#fd7e14', backgroundColor: '#fd7e14', pointRadius: 5 },
        { label: '集中度: 51-75', data: [], borderColor: '#ffc107', backgroundColor: '#ffc107', pointRadius: 5 },
        { label: '集中度: 76-100 (高)', data: [], borderColor: '#28a745', backgroundColor: '#28a745', pointRadius: 5 },
        {
          label: '視聴タイムライン',
          data: timelineData,
          borderColor: '#6c757d',
          borderWidth: 2,
          showLine: true,
          tension: 0,
          pointRadius: 4,
          pointHoverRadius: 7,
          pointBackgroundColor: timelineData.map(d => d.color),
          pointBorderColor: timelineData.map(d => d.color),
          order: 3
        },
        {
          label: 'スキップ/シーク',
          data: skipOpsData,
          borderColor: '#6f42c1',
          backgroundColor: '#6f42c1',
          pointRadius: 10,
          pointHoverRadius: 13,
          pointStyle: 'triangle',
          showLine: false,
          order: 2
        },
        {
          label: '一時停止',
          data: pauseOpsData,
          borderColor: '#6f42c1',
          backgroundColor: '#6f42c1',
          pointRadius: 10,
          pointHoverRadius: 13,
          pointStyle: 'rect',
          showLine: false,
          order: 2
        },
        {
          label: 'その他の操作',
          data: otherOpsData,
          borderColor: '#6f42c1',
          backgroundColor: '#6f42c1',
          pointRadius: 9,
          pointHoverRadius: 12,
          pointStyle: 'circle',
          showLine: false,
          order: 2
        },
        {
          label: 'ユーザー操作',
          data: interactionsData,
          borderColor: '#20c997',
          backgroundColor: '#20c997',
          pointRadius: 9,
          pointHoverRadius: 12,
          pointStyle: 'star',
          showLine: false,
          order: 1
        },
        {
          label: '素早い回答',
          data: quickResponseData,
          borderColor: '#ff65B2',
          backgroundColor: '#ff65B2',
          pointRadius: 11,
          pointHoverRadius: 14,
          pointStyle: 'triangle',
          showLine: false,
          order: 0
        },
        {
          label: '通常の回答',
          data: normalResponseData,
          borderColor: '#ff007F',
          backgroundColor: '#ff007F',
          pointRadius: 11,
          pointHoverRadius: 14,
          pointStyle: 'circle',
          showLine: false,
          order: 0
        },
        {
          label: '遅い回答',
          data: slowResponseData,
          borderColor: '#98004c',
          backgroundColor: '#98004c',
          pointRadius: 11,
          pointHoverRadius: 14,
          pointStyle: 'rectRot',
          showLine: false,
          order: 0
        }
      ];
      
      sessionDetailChart = new Chart(ctx, {
      type: 'scatter',
      data: { datasets },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          x: {
            type: 'linear',
            title: {
              display: true,
              text: 'セッション経過時間（秒）'
            },
            ticks: {
              callback: function(value) {
                const minutes = Math.floor(value / 60);
                const seconds = Math.floor(value % 60);
                return `${minutes}:${seconds.toString().padStart(2, '0')}`;
              }
            }
          },
          y: {
            type: 'linear',
            title: {
              display: true,
              text: '動画再生時間（秒）'
            },
            ticks: {
              callback: function(value) {
                const minutes = Math.floor(value / 60);
                const seconds = Math.floor(value % 60);
                return `${minutes}:${seconds.toString().padStart(2, '0')}`;
              }
            }
          }
        },
        plugins: {
          legend: {
            display: true,
            position: 'top'
          },
          zoom: {
            zoom: {
              wheel: {
                enabled: true,
              },
              pinch: {
                enabled: true
              },
              mode: 'xy',
            },
            pan: {
              enabled: true,
              mode: 'xy',
            }
          },
          tooltip: {
            callbacks: {
              label: function(context) {
                const rawData = context.raw;
                const videoMinutes = Math.floor(context.parsed.y / 60);
                const videoSeconds = Math.floor(context.parsed.y % 60);
                const videoTimeStr = `${videoMinutes}:${videoSeconds.toString().padStart(2, '0')}`;
                
                // 反応速度マーカーの場合
                if (context.dataset.label.includes('回答')) {
                  return `${context.dataset.label} | 動画: ${videoTimeStr}${rawData.description ? ' - ' + rawData.description : ''}`;
                }
                
                // 動画操作マーカーの場合
                if (context.datasetIndex >= 5 && context.datasetIndex <= 7) {
                  return `${rawData.description || context.dataset.label} | 動画: ${videoTimeStr}`;
                }
                
                // ユーザー操作の場合
                if (context.dataset.label === 'ユーザー操作') {
                  return `${rawData.description || rawData.type} | 動画: ${videoTimeStr}`;
                }
                
                // 通常のタイムラインポイント（集中度）
                return `集中度: ${rawData.score.toFixed(1)}点 | 動画: ${videoTimeStr}`;
              },
              title: function(context) {
                const minutes = Math.floor(context[0].parsed.x / 60);
                const seconds = Math.floor(context[0].parsed.x % 60);
                return `経過時間: ${minutes}:${seconds.toString().padStart(2, '0')}`;
              }
            }
          }
        }
      }
    });
    
    console.log('グラフ作成完了:', sessionDetailChart);
    
    // タイムラインのホバー時の視覚的フィードバック
    sessionDetailChart.options.onHover = function(event, activeElements) {
      // カーソルスタイルを変更
      event.native.target.style.cursor = activeElements.length > 0 ? 'pointer' : 'default';
    };
    
    // ダブルクリックでズームリセット
    ctx.ondblclick = function() {
      sessionDetailChart.resetZoom();
    };
    } catch (error) {
      console.error('グラフ作成エラー:', error);
      ctx.parentElement.innerHTML = '<p class="text-danger text-center">グラフの作成に失敗しました: ' + error.message + '</p>';
    }
  }

  function renderTimestampLog(data) {
    const logContainer = document.getElementById('timestampLog');
    
    // 全イベントを時系列順に結合
    const allEvents = [
      ...data.timeline.map(e => ({...e, category: 'timeline'})),
      ...data.score_changes.map(e => ({...e, category: 'score'})),
      ...data.video_operations.map(e => ({...e, category: 'video'})),
      ...data.interactions.map(e => ({...e, category: 'interaction'}))
    ].sort((a, b) => (a.time || a.x) - (b.time || b.x));
    
    logContainer.innerHTML = allEvents.map(event => {
      const time = event.time || event.x;
      const category = event.category;
      
      return `
        <div class="timestamp-entry ${category}-event">
          <div class="timestamp-header">
            <span>${formatTime(time)}</span>
            <span class="badge bg-secondary">${category}</span>
          </div>
          <div class="timestamp-description">
            ${event.description || event.reason || event.operation || event.type}
          </div>
        </div>
      `;
    }).join('');
  }

  function formatTime(seconds) {
    const minutes = Math.floor(seconds / 60);
    const secs = Math.floor(seconds % 60);
    return `${minutes}:${secs.toString().padStart(2, '0')}`;
  }
  
  // 個別の回答を削除する関数
  window.deleteResponse = function(responseId) {
    if (!confirm('この回答を削除してもよろしいですか？\nこの操作は取り消せません。')) {
      return;
    }
    
    const token = document.querySelector('meta[name="csrf-token"]').content;
    
    fetch('/video_management/delete_response', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': token
      },
      body: JSON.stringify({ response_id: responseId })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        // テーブル行を削除
        const row = document.getElementById('response-' + responseId);
        if (row) {
          row.remove();
        }
        alert('回答を削除しました。');
      } else {
        alert('回答の削除に失敗しました: ' + (data.error || '不明なエラー'));
      }
    })
    .catch(error => {
      console.error('削除エラー:', error);
      alert('回答の削除中にエラーが発生しました。');
    });
  };
  
  // 全選択/全解除
  window.toggleAllResponses = function(checked) {
    document.querySelectorAll('.response-checkbox').forEach(checkbox => {
      checkbox.checked = checked;
    });
  };
  
  // 選択した回答をまとめて削除
  window.deleteSelectedResponses = function() {
    const checkboxes = document.querySelectorAll('.response-checkbox:checked');
    const responseIds = Array.from(checkboxes).map(cb => parseInt(cb.value));
    
    if (responseIds.length === 0) {
      alert('削除する回答を選択してください。');
      return;
    }
    
    if (!confirm(`選択した${responseIds.length}件の回答を削除してもよろしいですか？\nこの操作は取り消せません。`)) {
      return;
    }
    
    const token = document.querySelector('meta[name="csrf-token"]').content;
    
    fetch('/video_management/delete_responses', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': token
      },
      body: JSON.stringify({ response_ids: responseIds })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        // 削除された回答の行を削除
        responseIds.forEach(id => {
          const row = document.getElementById('response-' + id);
          if (row) {
            row.remove();
          }
        });
        // 全選択チェックボックスをリセット
        document.getElementById('selectAllResponses').checked = false;
        alert(`${data.deleted_count}件の回答を削除しました。`);
      } else {
        alert('回答の削除に失敗しました: ' + (data.error || '不明なエラー'));
      }
    })
    .catch(error => {
      console.error('削除エラー:', error);
      alert('回答の削除中にエラーが発生しました。');
    });
  };
})();

