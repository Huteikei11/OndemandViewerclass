// チャンク読み込み（512MB 制約対応）
async function loadScoreTimelineChunks(initialData, pagination) {
  let allData = initialData;
  const videoId = <%= @video.id %>;
  
  for (let page = 1; page < pagination.total_pages; page++) {
    try {
      console.log(`[scoreTimeline] チャンク読 込: ページ ${page + 1}/${pagination.total_pages}`);
      const response = await fetch(
        `/video_management/get_chart_data?video_id=${videoId}&chart_type=score_timeline&session_page=${page}`,
        { signal: scoreTimelineAbortController.signal }
      );
      
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const result = await response.json();
      allData = allData.concat(result.data || []);
    } catch (error) {
      console.warn(`[scoreTimeline] ページ ${page} 読み込みエラー:`, error);
      break;  // エラーでも進行中のデータで続行
    }
  }
  
  return allData;
}

