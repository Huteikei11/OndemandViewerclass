function toggleSession(chartType, sessionId) {
  const chart = chartInstances[chartType];
  if (!chart) return;
  
  // このセッションに属する全てのデータセット（スコアライン＋操作マーカー）を切り替え
  let newHiddenState = null;
  
  chart.data.datasets.forEach((dataset, index) => {
    if (dataset.sessionId === sessionId) {
      const meta = chart.getDatasetMeta(index);
      // 最初のデータセットの状態を基準に切り替え
      if (newHiddenState === null) {
        newHiddenState = !meta.hidden;
      }
      meta.hidden = newHiddenState;
    }
  });
  
  chart.update();
}

function deleteSelectedSessions(chartType) {
  // チェックされているセッションIDを取得
  const checkboxes = document.querySelectorAll(`input[id^="${chartType}_session_"]:checked`);
  const sessionIds = Array.from(checkboxes).map(cb => {
    const match = cb.id.match(/session_(\d+)$/);
    return match ? parseInt(match[1]) : null;
  }).filter(id => id !== null);
  
  if (sessionIds.length === 0) {
    alert('削除するセッションを選択してください。');
    return;
  }
  
  if (!confirm(`選択した${sessionIds.length}件のセッションを削除してもよろしいですか？\nこの操作は取り消せません。`)) {
    return;
  }
  
  // CSRFトークンを取得
  const token = document.querySelector('meta[name="csrf-token"]').content;
  
  // バックエンドに削除リクエストを送信
  fetch('/video_management/delete_sessions', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': token
    },
    body: JSON.stringify({ session_ids: sessionIds })
  })
  .then(response => response.json())
  .then(data => {
    if (data.success) {
      let message = `${data.deleted_count}件のセッションを削除しました。`;
      if (data.deleted_responses_count > 0) {
        message += `\n関連する${data.deleted_responses_count}件の回答履歴も削除されました。`;
      }
      alert(message);
      // ページをリロードして更新
      window.location.reload();
    } else {
      alert('セッションの削除に失敗しました: ' + (data.error || '不明なエラー'));
    }
  })
  .catch(error => {
    console.error('削除エラー:', error);
    alert('セッションの削除中にエラーが発生しました。');
  });
}

