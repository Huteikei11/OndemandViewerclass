      }
    }
    
    // 操作マーカー（一時停止、スキップ）
    if (dataset.label.includes('操作')) {
      if (checkbox.checked) {
        dataset.pointRadius = 0;
        dataset.pointHoverRadius = 0;
        console.log(`[マーカートグル] データセット ${index} (操作) を非表示`);
      } else {
        dataset.pointRadius = 3;
        dataset.pointHoverRadius = 5;
        console.log(`[マーカートグル] データセット ${index} (操作) を表示`);
      }
    }
    
    // 反応速度マーカー（素早い回答、通常回答、遅延、速い問題確認）
    if (dataset.label.includes('反応速度')) {
      if (checkbox.checked) {
        dataset.pointRadius = 0;
        dataset.pointHoverRadius = 0;
        console.log(`[マーカートグル] データセット ${index} (反応速度) を非表示`);
      } else {
        dataset.pointRadius = 9;
        dataset.pointHoverRadius = 11;
        console.log(`[マーカートグル] データセット ${index} (反応速度) を表示`);
      }
    }
  });
  
  chart.update('none');
  console.log('[マーカートグル] グラフ更新完了');
}

function toggleMarkerVisibilityClassification() {
  const checkbox = document.getElementById('hideMarkersClassificationToggle');
  const chart = chartInstances.userClassification;
  
  if (!chart) {
    console.warn('[分類マーカートグル] チャートインスタンスが見つかりません');
    return;
  }
  
  console.log('[分類マーカートグル] 実行開始', {
    checked: checkbox.checked,
    datasetCount: chart.data.datasets.length
  });
  
  // 各データセットのマーカー表示を制御
  chart.data.datasets.forEach((dataset, index) => {
    if (!dataset.label) return;
    
    // すべてのセッションラインのマーカーを制御
    if (checkbox.checked) {
      // チェック時：マーカー非表示
      dataset.pointRadius = 0;
      dataset.pointHoverRadius = 0;
      console.log(`[分類マーカートグル] データセット ${index} (${dataset.label}) マーカー非表示`);
    } else {
      // チェック解除時：マーカー表示
      dataset.pointRadius = 2;
      dataset.pointHoverRadius = 5;
      console.log(`[分類マーカートグル] データセット ${index} (${dataset.label}) マーカー表示`);
    }
  });
  
  chart.update('none');
  console.log('[分類マーカートグル] グラフ更新完了');
}

function initializeAnalyticsCharts() {
  // 既に初期化中なら返す
  if (isInitializingCharts) {
    console.log('[グラフ初期化] 既に初期化中のためスキップ');
    return;
  }
  
  // Chart.jsが読み込まれているか確認
  if (typeof Chart === 'undefined') {
    console.log('Chart.js is not loaded yet. Retrying...');
    setTimeout(initializeAnalyticsCharts, 100);
    return;
  }
  
  // canvas要素が存在するか確認
  const scoreTimelineCtx = document.getElementById('scoreTimelineChart');
  if (!scoreTimelineCtx) {
    console.log('Canvas elements not ready yet. Retrying...');
    setTimeout(initializeAnalyticsCharts, 100);
    return;
  }
  
  // 初期化フラグをセット
  isInitializingCharts = true;
  
  // 初期化済みの場合は前のチャートを確実に破棄
  if (chartsInitialized) {
    console.log('[グラフ初期化] 前のチャートを破棄...');
    Object.keys(chartInstances).forEach(key => {
      try {
        if (chartInstances[key]) {
          chartInstances[key].destroy();
          delete chartInstances[key];
        }
      } catch (e) {
        console.error(`[グラフ初期化] ${key} チャート破棄エラー:`, e);
      }
    });
    chartInstances = {};
  }
  
  // ビデオIDを定義
  const videoId = <%= @video.id %>;
  
  // 共通のChart.jsオプション
  const commonOptions = {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: {
        display: true,
        position: 'top'
      }
    }
  };

  // 1. 集中スコア推移グラフ
  if (scoreTimelineCtx) {
    // 前のscoreTimeline fetchをキャンセル
    if (scoreTimelineAbortController) {
      scoreTimelineAbortController.abort();
      console.log('[scoreTimeline] 前の AJAX リクエストをキャンセルしました');
    }
    scoreTimelineAbortController = new AbortController();
    
    // scoreTimelineの既存チャートを確実に破棄
    if (chartInstances.scoreTimeline) {
      try {
        chartInstances.scoreTimeline.destroy();
        delete chartInstances.scoreTimeline;
        console.log('[scoreTimeline] 既存チャートを破棄しました');
      } catch (e) {
        console.error('[scoreTimeline] チャート破棄エラー:', e);
      }
    }
    
    // AJAX でデータを取得
    fetch(`/video_management/get_chart_data?video_id=${videoId}&chart_type=score_timeline`, {
      signal: scoreTimelineAbortController.signal
    })
      .then(response => {
        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }
        return response.json();
      })
      .then(result => {
        if (!result.data || !Array.isArray(result.data)) {
          console.error('[scoreTimeline] Invalid data format:', result);
          throw new Error('Invalid data format from server');
        }
        
        // チャートが既に存在しないか確認（他の初期化がないか確認）
        if (chartInstances.scoreTimeline) {
          console.warn('[scoreTimeline] 既に別の初期化でチャートが作成されています。スキップします。');
          return;
        }
        
        const scoreTimelineData = result.data || [];
        
        // チャンク読み込み対応：複数ページを統合
        if (result.pagination && result.pagination.has_next) {
          console.log('[scoreTimeline] チャンク読み込み開始: ページ 1/' + result.pagination.total_pages);
          return loadScoreTimelineChunks(scoreTimelineData, result.pagination);
        }
        
        return scoreTimelineData;
      })
      .then(scoreTimelineData => {
        // 分類グラフから利用できるようにグローバル変数に保存
        window.scoreTimelineData = scoreTimelineData;
        console.log('[scoreTimeline] window.scoreTimelineData に保存完了:', scoreTimelineData.length, 'セッション');
        
        const videoOperationsMarkers = <%= raw @video_operations_markers.to_json %>;
        const responseTimeMarkers = <%= raw @response_time_markers.to_json %>;
        
        // ここから Chart 初期化開始
    
    // ユーザーごとの色を決定する関数（20色パレット）
    const userColors = [
      // 既存の明るい色（前半10色）
      '#FF6B6B', // 赤
      '#4ECDC4', // 青緑
      '#45B7D1', // 青
      '#FFA07A', // オレンジ
      '#98D8C8', // 緑
      '#F7DC6F', // 黄色
      '#BB8FCE', // 紫
      '#85C1E2', // 薄い青
      '#F8B88B', // 薄いオレンジ
      '#AED6F1', // 薄い青2
      // 追加の10色（濃い彩度で区別性向上）
      '#E74C3C', // 濃い赤
      '#16A085', // 濃い青緑
      '#2E86C1', // 濃い青
      '#E67E22', // 濃いオレンジ
      '#27AE60', // 濃い緑
      '#F39C12', // 濃い黄色
      '#8E44AD', // 濃い紫
      '#2980B9', // 濃い青
      '#C0392B', // 深い赤
      '#1ABC9C'  // ターコイズ
    ];
    
    // ユーザーIDごとにカラーを割り当てるマップを作成
    window.colorByUserLineColors = {};
    const uniqueUserIds = [...new Set(scoreTimelineData.map(s => s.user_id))];
    
    // ユーザー数が色パレットを超える場合、警告を表示
    if (uniqueUserIds.length > userColors.length) {
      console.warn(`⚠️ 警告: ユーザー数(${uniqueUserIds.length})が色パレット(${userColors.length})を超えています。一部のユーザーが同じ色になります`);
    }
    
    uniqueUserIds.forEach((userId, index) => {
      window.colorByUserLineColors[userId] = userColors[index % userColors.length];
    });
    
    console.log('[分析グラフ] ユーザーカラーマップ作成:', window.colorByUserLineColors);
    console.log(`[分析グラフ] ユーザー数: ${uniqueUserIds.length}, 色数: ${userColors.length}`);
    
    // 線の色をグレーに統一
    const lineColor = 'rgba(128, 128, 128, 0.5)'; // グレー
    const operationColor = '#6f42c1'; // 紫色
    const responseQuickColor = '#ff65B2'; // 薄いピンク色（素早い回答用）
    const responseNormalColor = '#ff007F'; // ピンク色（普通の回答用）
    const responseSlowColor = '#98004c'; // 薄暗いピンク色（遅延用）
    const quickCheckColor = '#17a2b8'; // 水色（速い問題確認用）

    // 集中度スコアで色を決定する関数
    const getColorByScore = (score) => {
      if (score <= 25) return '#dc3545'; // 赤
      if (score <= 50) return '#fd7e14'; // オレンジ
      if (score <= 75) return '#ffc107'; // 黄色
      return '#28a745'; // 緑
    };

    // データセットを作成（セッションごとにグループ化）
    const datasets = [];
    const sessionDatasetGroups = {}; // セッションIDごとのデータセットインデックスを記録
    
    // 各セッションのデータを追加
    scoreTimelineData.forEach((session, sessionIndex) => {
      const sessionData = session.data.map(point => ({
        x: point.x,
        y: point.video_time || 0,
        score: point.y,
        video_time: point.video_time,
        color: getColorByScore(point.y)
      }));
      
      // 集中スコアラインを追加
      const lineDatasetIndex = datasets.length;
      datasets.push({
        label: session.label,
        data: sessionData,
        borderColor: lineColor,
        borderWidth: 2,
        showLine: true,
        tension: 0,
        pointRadius: 1,
        pointHoverRadius: 5,
        pointBackgroundColor: sessionData.map(d => d.color),
        pointBorderColor: sessionData.map(d => d.color),
        order: 2,
        sessionId: session.session_id,
        userId: session.user_id // ユーザーIDも保存
      });
      
      // このセッションに属するデータセットのインデックスを記録
      sessionDatasetGroups[session.session_id] = [lineDatasetIndex];
      
      // 対応する動画操作マーカーをまとめて追加
      const ops = videoOperationsMarkers.find(o => o.session_id === session.session_id);
      if (ops) {
        // すべての操作マーカーを1つの配列にまとめる
        const allOperations = [];
        
        // スキップ/シークマーカー（三角形）
        if (ops.skip && ops.skip.length > 0) {
          ops.skip.forEach(point => {
            allOperations.push({ ...point, style: 'triangle', type: 'スキップ' });
          });
        }
        
        // 一時停止マーカー（四角形）
        if (ops.pause && ops.pause.length > 0) {
          ops.pause.forEach(point => {
            allOperations.push({ ...point, style: 'rect', type: '一時停止' });
          });
        }
        
        // その他の操作マーカー（円形）
        if (ops.other && ops.other.length > 0) {
          ops.other.forEach(point => {
            allOperations.push({ ...point, style: 'circle', type: 'その他' });
          });
        }
        
        // すべての操作を1つのデータセットとして追加
        if (allOperations.length > 0) {
          sessionDatasetGroups[session.session_id].push(datasets.length);
          datasets.push({
            label: `${ops.label} - 操作`,
            data: allOperations,
            backgroundColor: operationColor,
            borderColor: operationColor,
            pointRadius: 3,
            pointHoverRadius: 5,
            pointStyle: function(context) {
              const point = context.raw;
              if (!point) return 'circle';
              return point.style || 'circle';
            },
            showLine: false,
            order: 1,
            sessionId: session.session_id
          });
        }
      }
      
      // 反応速度マーカーを追加
      const resp = responseTimeMarkers.find(r => r.session_id === session.session_id);
      console.log(`[反応速度デバッグ] セッション ${session.session_id} のマーカー検索結果:`, resp);
      if (resp) {
        const allResponses = [];
        
        // 素早い回答マーカー（上向き三角▲、薄いピンク）
        if (resp.quick && resp.quick.length > 0) {
          console.log(`[反応速度デバッグ] セッション ${session.session_id}: quick=${resp.quick.length}件追加`);
          resp.quick.forEach(point => {
            allResponses.push({ ...point, style: 'triangle', type: '素早い回答', color: responseQuickColor });
          });
        }
        
        // 通常の回答速度マーカー（円形○、ピンク）
        if (resp.normal && resp.normal.length > 0) {
          console.log(`[反応速度デバッグ] セッション ${session.session_id}: normal=${resp.normal.length}件追加`);
          resp.normal.forEach(point => {
            allResponses.push({ ...point, style: 'circle', type: '回答速度普通', color: responseNormalColor });
          });
        }
        
        // 回答遅延マーカー（下向き三角▼、薄暗いピンク）
        if (resp.slow && resp.slow.length > 0) {
          console.log(`[反応速度デバッグ] セッション ${session.session_id}: slow=${resp.slow.length}件追加`);
          resp.slow.forEach(point => {
            allResponses.push({ ...point, style: 'rectRot', type: '回答遅延', color: responseSlowColor });
          });
        }
        
        // 速い問題確認マーカー（星型★、水色）
        if (resp.quick_check && resp.quick_check.length > 0) {
          console.log(`[速い問題確認デバッグ] セッション ${session.session_id}: quick_check=${resp.quick_check.length}件追加`);
          resp.quick_check.forEach(point => {
            allResponses.push({ ...point, style: 'star', type: '速い問題確認', color: quickCheckColor });
          });
        }
        
        console.log(`[反応速度デバッグ] セッション ${session.session_id}: 合計 ${allResponses.length}件の反応速度マーカー`)
        
        if (allResponses.length > 0) {
          console.log(`[反応速度デバッグ] セッション ${session.session_id}: データセット追加 (${allResponses.length}件)`, allResponses);
          sessionDatasetGroups[session.session_id].push(datasets.length);
          const responseDataset = {
            label: `${resp.label} - 反応速度`,
            data: allResponses,
            pointRadius: 9,
            pointHoverRadius: 11,
            pointStyle: function(context) {
              const point = context.raw;
              if (!point) return 'circle';
              return point.style || 'circle';
            },
            pointBackgroundColor: function(context) {
              const point = context.raw;
              if (!point) return responseNormalColor;
              return point.color || responseNormalColor;
            },
            pointBorderColor: function(context) {
              const point = context.raw;
              if (!point) return responseNormalColor;
              return point.color || responseNormalColor;
            },
            showLine: false,
            order: 1,
            sessionId: session.session_id
          };
          datasets.push(responseDataset);
          console.log(`[反応速度デバッグ] データセット追加完了:`, responseDataset);
        } else {
          console.log(`[反応速度デバッグ] セッション ${session.session_id}: マーカーが0件のためスキップ`);
        }
      } else {
        console.log(`[反応速度デバッグ] セッション ${session.session_id}: マーカーデータが見つかりません`);
      }
    });

    // オリジナルデータを深いコピーで保存（フィルタリング前の状態）
    originalScoreTimelineDatasets = JSON.parse(JSON.stringify(datasets));
    
    // Chart を初期化（try-catchで例外をキャッチ）
    try {
      chartInstances.scoreTimeline = new Chart(scoreTimelineCtx, {
        type: 'scatter',
        data: { datasets },
      options: {
        ...commonOptions,
        scales: {
          x: {
            type: 'linear',
            title: {
              display: true,
              text: 'セッション経過時間（秒）'
            },
            ticks: {
              callback: function(value) {
                const minutes = Math.floor(value / 60);
                const seconds = Math.floor(value % 60);
                return `${minutes}:${seconds.toString().padStart(2, '0')}`;
              }
            }
          },
          y: {
            type: 'linear',
            title: {
              display: true,
              text: '動画再生時間（秒）'
            },
            ticks: {
              callback: function(value) {
                const minutes = Math.floor(value / 60);
                const seconds = Math.floor(value % 60);
                return `${minutes}:${seconds.toString().padStart(2, '0')}`;
              }
            },
            beginAtZero: true
          }
        },
        plugins: {
          ...commonOptions.plugins,
          zoom: {
            zoom: {
              wheel: {
                enabled: true,
              },
              pinch: {
                enabled: true
              },
              mode: 'xy',
            },
            pan: {
              enabled: true,
              mode: 'xy',
            }
          },
          tooltip: {
            callbacks: {
              label: function(context) {
                const point = context.raw;
                const videoMinutes = Math.floor(context.parsed.y / 60);
                const videoSeconds = Math.floor(context.parsed.y % 60);
                
                // 動画操作マーカーの場合
                if (context.dataset.label.includes('操作')) {
                  const operationType = point.type || '操作';
                  return `${operationType} | 動画: ${videoMinutes}:${videoSeconds.toString().padStart(2, '0')}${point.description ? ' - ' + point.description : ''}`;
                }
                
                // 反応速度マーカーの場合
                if (context.dataset.label.includes('反応速度')) {
                  const responseType = point.type || '反応';
                  
                  // 速い問題確認の場合は視線速度データを表示
                  if (point.type === '速い問題確認' && point.details) {
                    const gazeVelocityX = point.details.gazeVelocityX || 'N/A';
                    const gazeVelocityY = point.details.gazeVelocityY || 'N/A';
                    const threshold = point.details.threshold || 5;
                    const timeFromQuestion = point.details.timeFromQuestion || 'N/A';
                    return [
                      `${responseType} | 動画: ${videoMinutes}:${videoSeconds.toString().padStart(2, '0')}`,
                      `視線速度X: ${gazeVelocityX} px/s (閾値: ${threshold} px/s)`,
                      `視線速度Y: ${gazeVelocityY} px/s`,
                      `問題表示から: ${timeFromQuestion} 秒`
                    ];
                  }
                  
                  // その他の反応速度マーカー
                  const responseTime = point.response_time ? ` (${point.response_time.toFixed(1)}秒)` : '';
                  return `${responseType}${responseTime} | 動画: ${videoMinutes}:${videoSeconds.toString().padStart(2, '0')}${point.description ? ' - ' + point.description : ''}`;
                }
                
                // 集中スコアラインの場合
                const score = point.score !== undefined ? point.score : 0;
                return `${context.dataset.label} - 集中度: ${score.toFixed(1)}点 | 動画: ${videoMinutes}:${videoSeconds.toString().padStart(2, '0')}`;
              },
              title: function(context) {
                const minutes = Math.floor(context[0].parsed.x / 60);
                const seconds = Math.floor(context[0].parsed.x % 60);
                return `経過時間: ${minutes}:${seconds.toString().padStart(2, '0')}`;
              }
            }
          }
        }
      }
    });
    } catch (chartError) {
      console.error('[scoreTimeline] チャート作成エラー:', chartError);
      // チャート作成に失敗した場合は、このセッションはスキップ
    }
    
    // 以下のコードはチャート作成成功時のみ実行
    if (chartInstances.scoreTimeline) {
      // マーカーホバー時に同じセッションのラインの色を変更
      let currentHoveredSessionId = null;
      
      chartInstances.scoreTimeline.options.onHover = function(event, activeElements) {
        if (activeElements.length > 0) {
          const hoveredDatasetIndex = activeElements[0].datasetIndex;
          const hoveredDataset = this.data.datasets[hoveredDatasetIndex];
          const hoveredSessionId = hoveredDataset.sessionId;
          
          // 既に同じセッションをホバー中なら何もしない
          if (currentHoveredSessionId === hoveredSessionId) {
            return;
          }
          
          currentHoveredSessionId = hoveredSessionId;
          
          // すべてのラインを元の色に戻してから、ホバー中のセッションのラインを青色に
          this.data.datasets.forEach((dataset) => {
            if (dataset.showLine) {
              if (dataset.sessionId === hoveredSessionId) {
                dataset.borderColor = 'rgba(54, 162, 235, 0.8)'; // 青色
                dataset.borderWidth = 3;
              } else {
                dataset.borderColor = lineColor;
                dataset.borderWidth = 2;
              }
            }
          });
          
          this.update('none'); // アニメーションなしで更新
        } else {
          // ホバーが外れた場合は元の色に戻す
          if (currentHoveredSessionId !== null) {
            currentHoveredSessionId = null;
            
            this.data.datasets.forEach((dataset) => {
              if (dataset.showLine) {
                dataset.borderColor = lineColor;
                dataset.borderWidth = 2;
              }
            });
            
            this.update('none');
          }
        }
      };
      
      // セッション切り替えトグルを作成
      createSessionToggles('scoreTimeline', scoreTimelineData);
      
      // ダブルクリックでズームリセット
      scoreTimelineCtx.ondblclick = function() {
        chartInstances.scoreTimeline.resetZoom();
      };
    }
    })  // fetch の .then() コールバック終了
    .catch(error => {
      // AbortError（キャンセル）の場合はログを少なめに
      if (error.name === 'AbortError') {
        console.log('[scoreTimeline] AJAX がキャンセルされました（新しい初期化が開始されたため）');
      } else {
        console.error('[scoreTimeline] AJAX エラー:', error);
      }
      isInitializingCharts = false;
      chartsInitialized = true;
    });
  }

  // その他のチャートは従来の ERB inline JSON で初期化される

  // 4. ユーザー別平均スコアグラフ
  const userScoresCtx = document.getElementById('userScoresChart');
  if (userScoresCtx) {
    const userData = <%= raw @user_score_data.to_json %>;
    
    if (userData && userData.labels && userData.values && userData.labels.length > 0) {
      chartInstances.userScores = new Chart(userScoresCtx, {
