// 動画操作マップの分割数を更新
function updateOperationsMapBins() {
  const bins = parseInt(document.getElementById('operationsMapBins').value);
  
  if (!originalOperationsMapData || !chartInstances.videoOperations) {
    console.error('動画操作マップのデータがありません');
    return;
  }
  
  // 新しい分割数でデータを再集計
  const newData = rebinOperationsData(originalOperationsMapData, bins);
  
  // チャートを更新
  chartInstances.videoOperations.data.labels = newData.map(d => d.label);
  chartInstances.videoOperations.data.datasets[0].data = newData.map(d => d.pause);
  chartInstances.videoOperations.data.datasets[1].data = newData.map(d => d.seek);
  chartInstances.videoOperations.data.datasets[2].data = newData.map(d => d.response);
  chartInstances.videoOperations.update('none');
}

// 操作データを指定された分割数で再集計
function rebinOperationsData(originalData, bins) {
  if (!originalData || originalData.length === 0) return [];
  
  // 全操作データを展開
  const allOperations = [];
  originalData.forEach(item => {
    // 一時停止操作
    for (let i = 0; i < item.pause; i++) {
      allOperations.push({ type: 'pause', time: item.time });
    }
    // スキップ操作
    for (let i = 0; i < item.seek; i++) {
      allOperations.push({ type: 'seek', time: item.time });
    }
    // 問題回答
    const responseCount = item.response || 0;
    for (let i = 0; i < responseCount; i++) {
      allOperations.push({ type: 'response', time: item.time });
    }
  });
  
  // 最大時間を取得
  const maxTime = Math.max(...originalData.map(d => d.time));
  const binSize = maxTime / bins;
  
  // 新しいビンを作成
  const newData = [];
  for (let i = 0; i < bins; i++) {
    const startTime = i * binSize;
    const endTime = (i + 1) * binSize;
    const startMin = Math.floor(startTime / 60);
    const startSec = Math.floor(startTime % 60);
    const endMin = Math.floor(endTime / 60);
    const endSec = Math.floor(endTime % 60);
    
    // この範囲の操作をカウント
    const pause = allOperations.filter(op => 
      op.type === 'pause' && op.time >= startTime && op.time < endTime
    ).length;
    const seek = allOperations.filter(op => 
      op.type === 'seek' && op.time >= startTime && op.time < endTime
    ).length;
    const response = allOperations.filter(op => 
      op.type === 'response' && op.time >= startTime && op.time < endTime
    ).length;
    
    newData.push({
      label: `${startMin}:${startSec.toString().padStart(2, '0')}-${endMin}:${endSec.toString().padStart(2, '0')}`,
      time: startTime,
      pause: pause,
      seek: seek,
      response: response
    });
  }
  
  return newData;
}

